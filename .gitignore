# aeb modules: the .aeb/lib SDK symlink farm is generated by `aeb --init`
# (re-creatable, machine-specific) — ignore it, but KEEP our tracked
# consumer-local module (.aeb/lib/aetherui/), which is real source.
.aeb/lib/*
!.aeb/lib/aetherui/
.aeb/lib/aetherui/*
!.aeb/lib/aetherui/module.ae
