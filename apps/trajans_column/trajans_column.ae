// trajans_column.ae — interactive isometric diagram of Trajan's Column.
//
// ─── Provenance ──────────────────────────────────────────────────────────────
// The vector geometry was TRANSPILED by aevg's own SVG transpiler from
//   ~/scm/tsyne/tsyne/cosyne/test/svg/Trajans-Column-lower-animated.svg
// (an Inkscape drawing), then this file weaves the interaction by hand. The
// Tsyne intermediate is ~/scm/tsyne/tsyne/ported-apps/trajans-column/. Under
// aether-ui's own licence.
// ─────────────────────────────────────────────────────────────────────────────
//
// The AeVG showcase for the DECLARATIVE / CVG surface no prior app exercised:
//   • 40 multi-stop linear/radial gradients (fill("url(#…)")) on 500+ paths,
//     rendered through the transpiler+renderer pipeline,
//   • click-to-explore: click a stone block → its wireframe construction lines
//     appear (vg.on_click toggles activeBlock; vg.visible_when gates each
//     block's #444444 wire group on it),
//   • a one-shot proof that aevg can transpile a real, complex Inkscape SVG and
//     keep it hand-editable enough to layer interactivity on top.
//
//   DISPLAY=:0 ./build/trajans_column
//
// The 10 blocks (1a/1b … 4a/4b, 5, 6) are the column's drum sections; clicking
// the same block again deselects. State is a heap *Col carrying the active id.

import ui
import ui (window, vstack, text, enable_test_server, aether_ui_text_set_string)
import vg.live (vg)
import vg
import vg (view_box, circle, rect, line, path, text_sized, g, fill, stroke, opacity,
    transform, on_click, visible_when)
import std.string
import std.os (os_getenv, now_monotonic_ms)

extern malloc(size: int) -> ptr

// ─── Interaction state ────────────────────────────────────────────────────────
// active: the selected block id (0 = none, else 1..10 mapping the block list).
// status: the label handle for the "Exploring …" line.
struct Col {
    active: int
    status: int
}
mk_col() -> *Col {
    c = malloc(16) as *Col
    c.active = 0
    c.status = 0
    return c
}

// Block ids: 1=1a 2=1b 3=2a 4=2b 5=3a 6=3b 7=4a 8=4b 9=5 10=6.
B_1A() -> int { return 1 }
B_1B() -> int { return 2 }
B_2A() -> int { return 3 }
B_2B() -> int { return 4 }
B_3A() -> int { return 5 }
B_3B() -> int { return 6 }
B_4A() -> int { return 7 }
B_4B() -> int { return 8 }
B_5()  -> int { return 9 }
B_6()  -> int { return 10 }

block_name(id: int) -> string {
    if id == 1 { return "Block 1A" }
    if id == 2 { return "Block 1B" }
    if id == 3 { return "Block 2A" }
    if id == 4 { return "Block 2B" }
    if id == 5 { return "Block 3A" }
    if id == 6 { return "Block 3B" }
    if id == 7 { return "Block 4A" }
    if id == 8 { return "Block 4B" }
    if id == 9 { return "Block 5" }
    return "Block 6"
}

// Click a block face: toggle selection, update the status line.
click_block(c: *Col, id: int) {
    if c.active == id {
        c.active = 0
        if c.status != 0 { aether_ui_text_set_string(c.status, "Click a block to explore") }
    } else {
        c.active = id
        if c.status != 0 {
            aether_ui_text_set_string(c.status, string.concat("Exploring ", block_name(id)))
        }
    }
}

// A wireframe group is visible when its block (or block pair) is the active one.
// Used as visible_when predicates — closures capture `c` and a target id set.
show_for(c: *Col, a: int) -> int { if c.active == a { return 1 } return 0 }
show_for2(c: *Col, a: int, b: int) -> int {
    if c.active == a { return 1 }
    if c.active == b { return 1 }
    return 0
}

main() {
    c = mk_col()
    window("Trajan's Column", 820, 940) {
        vstack(4) {
            c.status = text("Click a block to explore")
            vg(view_box(0.0, 0.0, 1000.0, 1100.0), 800, 880) {
            // Make the scene refreshing so a click re-evaluates the visible_when
            // predicates (the per-block wireframe gates) and redraws each frame.
            _anchor = rect(0.0, 0.0, 0.0, 0.0)
            _scene = vg.node_scene(_anchor)
            vg.scene_set_refreshing(_scene, 1)
            g() { transform("translate(-700,-1420)")
                path("M 1091.72 2133.35 L 1155.2 2157.03 L 1166.16 2146.58 L 1266.98 2184.19 L 1335.52 2118.84 L 1171.22 2057.55 L 1091.72 2133.35 Z") { fill("#d8c0a6") on_click() callback { click_block(c, B_1B()) } }
                path("M 1171.22 2057.55 L 1171.22 2006.3 L 1091.72 2082.1 L 1091.72 2133.35 L 1171.22 2057.55 Z") { fill("#d2bda5") }
                path("M 1171.22 2057.55 L 1171.22 2006.3 L 1335.52 2067.59 L 1335.52 2118.84 L 1171.22 2057.55 Z") { fill("#e3d2c0") }
