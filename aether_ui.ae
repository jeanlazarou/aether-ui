// ---------------------------------------------------------------------------
// DSL wrappers — builder-pattern functions with _ctx auto-injection
// ---------------------------------------------------------------------------

// Top-level root containers — no _ctx (for use outside trailing blocks).
root_vstack(spacing: int) {
    return aether_ui_vstack_create(spacing)
}

root_hstack(spacing: int) {
    return aether_ui_hstack_create(spacing)
}

// ─── Surfaces — "DSL with Scope" (window / render_to / record) ────
//
// A surface is the ambient destination a widget/drawing block populates.
// It replaces the old `app_run(title, w, h, root)` trailing call: instead
// of building a tree then handing it to a run function, you open a surface
// scope and the children populate it. The surface's *kind* decides its
// lifecycle:
//
//   window(title, w, h) { … }   — LIVED: owns the event loop; the builder
//                                  body runs the loop AFTER the block, ending
//                                  only when the window closes.
//   render_to(target, w, h) {…} — BOUNDED: draws once into a target
//                                  (buffer / PNG / PDF / paper), returns.
//   record(w, h) { … }          — BOUNDED: captures calls for tests, returns.
//
// All three are `builder` functions (per docs/closures-and-builder-dsl.md):
// the trailing block runs FIRST (children attach to the surface container
// the `with` factory pushed as _ctx), then the function body runs — the
// "configure then execute" lifecycle. Only `window`'s body runs a loop;
// the bounded surfaces' bodies finalize and return.
//
// Interactive verbs (onclick/onhover) used inside a bounded surface are
// diagnostic-inert: they render but the handler never fires (no event loop
// to deliver to). The diagnostic is COLLECTED on the surface by default
// (readable via surface_diagnostics); routing to stderr or a hard fail is
// an explicit opt-in (see surface_diag_to_stderr / surface_diag_fail).

// Zero-arg `with` factories — one per kind (the factory can't take args).
_surface_window_factory()   -> int { return aether_ui_surface_container_new_impl(0) }
_surface_render_factory()   -> int { return aether_ui_surface_container_new_impl(1) }
_surface_record_factory()   -> int { return aether_ui_surface_container_new_impl(2) }

// window — a lived surface. Children populate the window; the body then
// creates the app, mounts them, and runs the event loop until the window
// closes. `_builder` is the populated content-container handle.
builder window(title: string, w: int, h: int) with _surface_window_factory {
    if _builder != 0 {
        aether_ui_surface_run_impl(_builder, title, w, h)
    }
}

// render_to — a bounded surface. Children draw into `target`; the body
// flushes a single render pass to it and returns. (Rasterize/print wiring
// lands with the vg drawing layer; for now the surface scopes + collects.)
builder render_to(target: ptr, w: int, h: int) with _surface_render_factory {
    // bounded: no loop. Flush any deferred vg scenes so their command buffers
    // are built (with final colours) before the single render pass to target.
    aether_ui_surface_flush_deferred_impl()
    _u = target
}

// record — a bounded test surface. Children draw into a recording; the body
// returns the container handle so a test can inspect what was built and the
// collected diagnostics. Returns the container handle.
builder record(w: int, h: int): int with _surface_record_factory {
    // Flush deferred vg scenes so a recording captures the drawn shapes.
    aether_ui_surface_flush_deferred_impl()
    if _builder != 0 { return _builder }
    return 0
}

// Read how many interactive-verb-on-bounded-surface diagnostics a surface
// collected (the default sink). 0 for a live window.
surface_diagnostics(container_handle: int) -> int {
    return aether_ui_surface_diag_count_impl(container_handle)
}

// register_deferred_flush(cb) — register a flush closure the enclosing surface
// body drains after its block closes (before a window's loop blocks). The
// AeVG `vg { … }` scope uses this to draw its recorded shapes with final
// colours; see docs and vg_live.ae. Boxes the closure so C can invoke it.
register_deferred_flush(cb: fn) {
    boxed = box_closure(cb)
    aether_ui_register_deferred_flush_impl(boxed)
}

// canvas_on_resize(cid, cb) — fire cb(w, h) when the canvas allocation changes.
// AeVG's vg{} scope uses this to rescale its scene on window resize. cb takes
// the new width and height as ints.
canvas_on_resize(cid: int, cb: fn) {
    boxed = box_closure(cb)
    aether_ui_canvas_on_resize_impl(cid, boxed)
}

// canvas_on_click(cid, cb) — fire cb(x, y) (canvas-local px) on a single click.
// AeVG's vg{} scope uses this to dispatch_click into its scene and hit-test
// the tracked shape elements. cb takes the click coords as floats.
canvas_on_click(cid: int, cb: fn) {
    boxed = box_closure(cb)
    aether_ui_canvas_on_click_impl(cid, boxed)
}

// canvas_on_move(cid, cb) — fire cb(x, y) (canvas-local px) on every pointer
// motion over the canvas. For hover hit-testing (e.g. a status line tracking
// the item under the cursor). No-op on backends without live motion delivery.
canvas_on_move(cid: int, cb: fn) {
    boxed = box_closure(cb)
    aether_ui_canvas_on_move_impl(cid, boxed)
}

// canvas_on_key(cid, cb) — fire cb(key_name) on a key press while the canvas
// has focus. key_name is the GDK/platform key name string (e.g. "Left",
// "space", "a"). Drives game-style input (falling-blocks, etc.); the canvas is
// made focusable and grabs focus on registration. Real on GTK4; no-op on
// backends without a key bridge yet (macos/win32 stubs).
canvas_on_key(cid: int, cb: fn) {
    boxed = box_closure(cb)
    aether_ui_canvas_on_key_impl(cid, boxed)
}

// canvas_on_release(cid, cb) — fire cb(x, y) (canvas-local px) when the pointer
// button is released. Pairs with canvas_on_click (press) + canvas_on_move to
// form a press→drag→release swipe (the Rubik's cube uses it to read a swipe's
// direction). Real on GTK4; no-op on backends without a release bridge yet.
canvas_on_release(cid: int, cb: fn) {
    boxed = box_closure(cb)
    aether_ui_canvas_on_release_impl(cid, boxed)
}

// window_run — the explicit-root window form, sibling to `window {…}`.
// Use it when the root is built imperatively (not via the ambient
// block context) — e.g. a grid whose cells are grid_place'd into a
// pre-created root_grid. Creates the window surface around the
// already-built root and runs the loop. (The `window {…}` block form
// is preferred when the tree is built declaratively inside the block.)
window_run(title: string, w: int, h: int, root_handle: int) {
    app_handle = aether_ui_app_create(title, w, h)
    aether_ui_app_set_body(app_handle, root_handle)
    aether_ui_app_run_raw(app_handle)
}

// app_run — retained alias of window_run for any un-migrated caller.
// New code uses window(…){…} (declarative) or window_run(…) (explicit
// root). Will be removed once nothing references it.
app_run(title: string, width: int, height: int, root_handle: int) {
    window_run(title, width, height, root_handle)
}

// Split-form app lifecycle: create returns a handle, then caller can
// attach a menu bar or other app-level wiring before calling start.
app_create(title: string, width: int, height: int) {
    return aether_ui_app_create(title, width, height)
}

// Finalize + run. Mirrors app_run for apps that need the split path.
app_start(app_handle: int, root_handle: int) {
    aether_ui_app_set_body(app_handle, root_handle)
    aether_ui_app_run_raw(app_handle)
}

// --- Layout containers ---

vstack(_ctx: ptr, spacing: int) {
    handle = aether_ui_vstack_create(spacing)
    if _ctx != 0 {
        aether_ui_widget_add_child_ctx(_ctx, handle)
    }
    return handle
}

hstack(_ctx: ptr, spacing: int) {
    handle = aether_ui_hstack_create(spacing)
    if _ctx != 0 {
        aether_ui_widget_add_child_ctx(_ctx, handle)
    }
    return handle
}

scrollview(_ctx: ptr) {
    handle = aether_ui_scrollview_create()
    if _ctx != 0 {
        aether_ui_widget_add_child_ctx(_ctx, handle)
    }
    return handle
}

zstack(_ctx: ptr) {
    handle = aether_ui_zstack_create()
    if _ctx != 0 {
        aether_ui_widget_add_child_ctx(_ctx, handle)
    }
    return handle
}

form(_ctx: ptr) {
    handle = aether_ui_form_create()
    if _ctx != 0 {
        aether_ui_widget_add_child_ctx(_ctx, handle)
    }
    return handle
}

section(_ctx: ptr, title: string) {
    handle = aether_ui_form_section_create(title)
    if _ctx != 0 {
        aether_ui_widget_add_child_ctx(_ctx, handle)
    }
    // Return handle+1 (inner box) so children go inside the section
    return handle + 1
}

navstack(_ctx: ptr) {
    handle = aether_ui_navstack_create()
    if _ctx != 0 {
        aether_ui_widget_add_child_ctx(_ctx, handle)
    }
    return handle
}

nav_push(nav_handle: int, title: string, body_handle: int) {
    aether_ui_navstack_push(nav_handle, title, body_handle)
}

nav_pop(nav_handle: int) {
    aether_ui_navstack_pop(nav_handle)
}

// --- Leaf widgets ---

text(_ctx: ptr, label: string) {
    handle = aether_ui_text_create(label)
    if _ctx != 0 {
        aether_ui_widget_add_child_ctx(_ctx, handle)
    }
    return handle
}

// button with immediate block — use for styling + onclick:
//   button("C") { bg_color(0.9,0.6,0.6,1.0); onclick() callback { call(clear) } }
button(_ctx: ptr, label: string) {
    handle = aether_ui_button_create_plain(label)
    if _ctx != 0 {
        aether_ui_widget_add_child_ctx(_ctx, handle)
    }
    return handle
}

// btn — quick callback-only form:
//   btn("=") callback { call(equals) }
btn(_ctx: ptr, label: string, on_press: fn) {
    boxed = box_closure(on_press)
    handle = aether_ui_button_create(label, boxed)
    if _ctx != 0 {
        aether_ui_widget_add_child_ctx(_ctx, handle)
    }
    return handle
}

spacer(_ctx: ptr) {
    handle = aether_ui_spacer_create()
    if _ctx != 0 {
        aether_ui_widget_add_child_ctx(_ctx, handle)
    }
    return handle
}

divider(_ctx: ptr) {
    handle = aether_ui_divider_create()
    if _ctx != 0 {
        aether_ui_widget_add_child_ctx(_ctx, handle)
    }
    return handle
}

