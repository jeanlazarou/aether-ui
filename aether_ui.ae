    return handle
}

// --- Styling (Group 4) ---

// --- Context-aware styling (use inside trailing blocks) ---
// These receive _ctx from the builder context stack, so they apply
// to the current widget automatically:
//   button("OK") { bg_color(0.2, 0.6, 0.3, 1.0) }

bg_color(_ctx: ptr, r: float, g: float, b: float, a: float) {
    aether_ui_set_bg_color_ctx(_ctx, r, g, b, a)
}

text_color(_ctx: ptr, r: float, g: float, b: float) {
    aether_ui_set_text_color_ctx(_ctx, r, g, b)
}

font_size(_ctx: ptr, size: float) {
    aether_ui_set_font_size_ctx(_ctx, size)
}

font_bold(_ctx: ptr) {
    aether_ui_set_font_bold_ctx(_ctx, 1)
}

corner_radius(_ctx: ptr, radius: float) {
    aether_ui_set_corner_radius_ctx(_ctx, radius)
}

opacity(_ctx: ptr, val: float) {
    aether_ui_set_opacity_ctx(_ctx, val)
}

enabled(_ctx: ptr, val: int) {
    aether_ui_set_enabled_ctx(_ctx, val)
}

tooltip(_ctx: ptr, text: string) {
    aether_ui_set_tooltip_ctx(_ctx, text)
}

onclick(_ctx: ptr, handler: fn) {
    boxed = box_closure(handler)
    aether_ui_set_onclick_ctx(_ctx, boxed)
}

// --- Explicit-handle styling (use outside blocks) ---

// --- Explicit-handle styling (use outside blocks). Each returns its
// handle so calls chain via UFCS: title.style_font_size(20).style_font_bold()
// (x.f(args) desugars to f(x, args) — Aether #928/#934). Existing flat
// calls keep working; UFCS is a last-resort fallback. ---

style_bg_color(handle: int, r: float, g: float, b: float, a: float) -> int {
    aether_ui_set_bg_color(handle, r, g, b, a)
    return handle
}

style_text_color(handle: int, r: float, g: float, b: float) -> int {
    aether_ui_set_text_color(handle, r, g, b)
    return handle
}

style_font_size(handle: int, size: float) -> int {
    aether_ui_set_font_size(handle, size)
    return handle
}

style_font_bold(handle: int) -> int {
    aether_ui_set_font_bold(handle, 1)
    return handle
}

style_bg_gradient(handle: int, r1: float, g1: float, b1: float,
                   r2: float, g2: float, b2: float, vertical: int) -> int {
    aether_ui_set_bg_gradient(handle, r1, g1, b1, r2, g2, b2, vertical)
    return handle
}

style_corner_radius(handle: int, radius: float) -> int {
    aether_ui_set_corner_radius(handle, radius)
    return handle
}

style_opacity(handle: int, val: float) -> int {
    aether_ui_set_opacity(handle, val)
    return handle
}

style_enabled(handle: int, val: int) -> int {
    aether_ui_set_enabled(handle, val)
    return handle
}

style_tooltip(handle: int, text: string) -> int {
    aether_ui_set_tooltip(handle, text)
    return handle
}

edge_insets(handle: int, top: float, right: float, bottom: float, left: float) -> int {
    aether_ui_set_edge_insets(handle, top, right, bottom, left)
    return handle
}

width(handle: int, w: int) -> int {
    aether_ui_set_width(handle, w)
    return handle
}

height(handle: int, h: int) -> int {
    aether_ui_set_height(handle, h)
    return handle
}

distribution(handle: int, dist: int) -> int {
    aether_ui_set_distribution(handle, dist)
    return handle
}

alignment(handle: int, align: int) -> int {
    aether_ui_set_alignment(handle, align)
    return handle
}

fill_width(handle: int) -> int {
    aether_ui_match_parent_width(handle)
    return handle
}

fill_height(handle: int) -> int {
    aether_ui_match_parent_height(handle)
    return handle
}

// margin — in-block modifier: applies to the ambient element (_ctx).
// Inside `vstack(4) { margin(12, 12, 12, 12); … }` it pads the vstack,
// no named handle needed (parallels bg_color / onclick). Outside a
// block, `_ctx` is 0 and the call is a no-op; use margin_of for an
// explicit target.
margin(_ctx: ptr, top: int, right: int, bottom: int, left: int) {
    if _ctx != 0 {
        aether_ui_set_margin_ctx(_ctx, top, right, bottom, left)
    }
}

// margin_of — explicit-target form: pad a specific widget handle
// (e.g. a child captured by name, not the ambient one).
margin_of(handle: int, top: int, right: int, bottom: int, left: int) -> int {
    aether_ui_set_margin(handle, top, right, bottom, left)
    return handle
}

// --- System integration (Group 5) ---

alert(title: string, msg: string) {
    aether_ui_alert_impl(title, msg)
}

clipboard_write(text: string) {
    aether_ui_clipboard_write_impl(text)
}

open_url(url: string) {
