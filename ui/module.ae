// Alignment constants (matching perry/macOS NSLayoutAttribute values)
const ALIGN_LEADING  = 5
const ALIGN_CENTER   = 9
const ALIGN_FILL     = 7
const ALIGN_TOP      = 3
const ALIGN_BOTTOM   = 4
const ALIGN_CENTER_Y = 12

// Distribution constants
const DIST_FILL         = 0
const DIST_FILL_EQUALLY = 1

