// Aether UI — Declarative widget DSL for Aether
// Port of aether-ui (Rust) to Aether + C (GTK4 backend).
//
// Uses Aether's trailing-block builder pattern (same as TinyWeb) to create
// widget trees declaratively. The _ctx: ptr parameter auto-injects the
// parent widget handle so children are wired up automatically.
//
// Build with:
//   ./build.sh your_app.ae build/your_app

exports (
    ALIGN_LEADING, ALIGN_CENTER, ALIGN_FILL, ALIGN_TOP, ALIGN_BOTTOM, ALIGN_CENTER_Y,
    DIST_FILL, DIST_FILL_EQUALLY,
    root_vstack, root_hstack,
    window, window_run, render_to, record, surface_diagnostics,
    register_deferred_flush, canvas_on_resize, canvas_on_click, canvas_on_move, canvas_on_key,
    canvas_on_release,
    _surface_window_factory, _surface_render_factory, _surface_record_factory,
    app_run, app_create, app_start,
    vstack, hstack, scrollview, zstack, form, section, navstack,
    splitview, split_position, split_set_position, on_layout, weight, rtl, wrap,
    tabs, tab, on_tab_change, tab_select, tab_selected,
    nav_push, nav_pop,
    text, text_wrapped, text_anchor, button, btn, spacer, divider,
    textfield, textfield_bound, securefield, toggle, toggle_group, slider, picker, picker_add,
    textarea, textarea_set_text, textarea_get_text, progressbar,
    ui_state, ui_get, ui_set, text_bound,
    ui_state_s, ui_get_s, ui_set_s, ui_state_i, ui_get_i, ui_set_i,
    ui_state_b, ui_get_b, ui_set_b,
    ui_state_list, ui_get_list, ui_set_list, each_bind, computed_s,
    bind_text, bind_text_fmt, bind_enabled, bind_hidden, bind_value,
    set_text, get_text, set_toggle, get_toggle,
    set_button_label, set_hidden, context_menu_item, context_menu_item_accel,
    shortcut, shortcut_when, shortcut_chord, widget_shortcut, focus, focused_widget,
    set_slider, get_slider, set_progress,
    bg_color, text_color, font_size, font_bold, corner_radius,
    opacity, enabled, tooltip, onclick,
    style_bg_color, style_text_color, style_font_size, style_font_bold,
    style_bg_gradient, style_corner_radius, style_opacity,
    style_enabled, style_tooltip,
    create_styles, st_color, st_bg, st_font_size, st_bold, st_weight,
    st_radius, st_font_family, st_opacity, st_gradient, st_insets,
    apply_styles, style_id, styles_for_mode,
    use_styles, current_styles, use_styles_pair, on_appearance_change,
    load_styles,
    ui_states, add_state, set_state, current_state,
    undoable, undo, redo, undo_depth, redo_depth, undo_label,
    enable_undo_shortcuts,
    style_font_weight, style_font_family,
    a11y_role, a11y_label, a11y_description,
    edge_insets, width, height, distribution, alignment,
    fill_width, fill_height, margin, margin_of,
    alert, clipboard_write, open_url, open_file, save_file, is_dark_mode,
    timer, timer_cancel,
    window_create, window_set_body, window_show, window_close,
    overlay, overlay_modal, dismiss_overlay, overlay_is_live, toast, style_shadow,
    transition_overlay, overlay_is_exiting,
    overlay_material, overlay_material_effective,
    transition,
    canvas_on_hover,
    edge,
    vg_tooltip_show, vg_tooltip_hide, vg_tooltip_drawn,
    each, each_update, each_count, each_parent,
    listbox, listbox_multi, listbox_reorderable, listbox_update, listbox_move,
    listbox_items,
    listbox_select, listbox_selected, listbox_is_selected, listbox_count,
    on_row_double_click, on_reorder,
    on_select, add_css_class, remove_css_class,
    table_cols, table_col, table_col_delegate, table, table_update,
    table_select, table_selected, table_count, table_on_select, table_bind,
    on_sort,
    tree, tree_node, tree_add_child, tree_set_expanded, tree_refresh,
    tree_visible_count,
    vlist, vlist_set, vlist_scroll_to, vlist_count, vlist_window_first,
    vlist_scrollable, vlist_container,
    sheet_create, sheet_set_body, sheet_present, sheet_dismiss,
    image, image_from_bytes, image_size,
    canvas_create, canvas_begin_path, canvas_move_to, canvas_line_to,
    canvas_stroke, canvas_stroke_cj, canvas_fill_rect, canvas_clip_rect, canvas_clear, canvas_redraw, canvas_write_png,
    canvas_arc, canvas_close_path, canvas_fill, canvas_fill_text, canvas_stroke_text,
    canvas_group_begin, canvas_group_end, canvas_read_pixel,
    canvas_draw_image, canvas_draw_image_scaled, canvas_fill_linear_gradient, canvas_fill_radial_gradient,
    on_hover, on_double_click, on_click,
    remove_child, clear_children,
    enable_test_server, enable_test_server_root, seal_widget, seal_subtree,
    menu_bar, menu, menu_item, menu_item_accel, menu_separator,
    menu_bar_add, attach_menu_bar, attach_menu_bar_to_window, menu_popup,
    root_grid, grid, grid_place,
    tray_icon, tray_set_tooltip, tray_set_menu,
    tray_set_icon_for_state, tray_set_icon_template, tray_seal,
    app_run_headless,
    notify, notify_full, notify_request_permission
)

import std.string   // overlay_anchor_code parses the anchor string
import std.list     // each_update walks the items list
import std.os (os_getenv)   // transition honours AETHER_UI_NO_ANIMATION
import std.intarr   // listbox row-handle tracking
import std.intarr (intarr_new_raw, intarr_get_raw, intarr_set_raw, intarr_free)
import std.fs      // load_styles (AeCS theme files)

extern malloc(size: int) -> ptr   // EachGroup allocation (house pattern, vg/module.ae:84)

