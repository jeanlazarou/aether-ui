extern aether_ui_tray_seal_impl(tray_id: int)
extern aether_ui_app_run_headless_impl()
extern aether_ui_notify_impl(title: string, body: string) -> int
extern aether_ui_notify_full_impl(title: string, body: string,
                                  icon_path: string, tag: string,
                                  boxed_closure: ptr) -> int
extern aether_ui_notify_request_permission_impl() -> int

// ---------------------------------------------------------------------------
// DSL wrappers — builder-pattern functions with _ctx auto-injection
// ---------------------------------------------------------------------------

// Top-level root containers — no _ctx (for use outside trailing blocks).
root_vstack(spacing: int) {
    return aether_ui_vstack_create(spacing)
}

root_hstack(spacing: int) {
    return aether_ui_hstack_create(spacing)
}

// ─── Surfaces — "DSL with Scope" (window / render_to / record) ────
//
// A surface is the ambient destination a widget/drawing block populates.
// It replaces the old `app_run(title, w, h, root)` trailing call: instead
// of building a tree then handing it to a run function, you open a surface
// scope and the children populate it. The surface's *kind* decides its
// lifecycle:
//
//   window(title, w, h) { … }   — LIVED: owns the event loop; the builder
//                                  body runs the loop AFTER the block, ending
//                                  only when the window closes.
//   render_to(target, w, h) {…} — BOUNDED: draws once into a target
//                                  (buffer / PNG / PDF / paper), returns.
//   record(w, h) { … }          — BOUNDED: captures calls for tests, returns.
//
// All three are `builder` functions (per docs/closures-and-builder-dsl.md):
// the trailing block runs FIRST (children attach to the surface container
// the `with` factory pushed as _ctx), then the function body runs — the
// "configure then execute" lifecycle. Only `window`'s body runs a loop;
// the bounded surfaces' bodies finalize and return.
//
// Interactive verbs (onclick/onhover) used inside a bounded surface are
// diagnostic-inert: they render but the handler never fires (no event loop
// to deliver to). The diagnostic is COLLECTED on the surface by default
// (readable via surface_diagnostics); routing to stderr or a hard fail is
// an explicit opt-in (see surface_diag_to_stderr / surface_diag_fail).

// Zero-arg `with` factories — one per kind (the factory can't take args).
_surface_window_factory()   -> int { return aether_ui_surface_container_new_impl(0) }
_surface_render_factory()   -> int { return aether_ui_surface_container_new_impl(1) }
_surface_record_factory()   -> int { return aether_ui_surface_container_new_impl(2) }

// window — a lived surface. Children populate the window; the body then
// creates the app, mounts them, and runs the event loop until the window
// closes. `_builder` is the populated content-container handle.
builder window(title: string, w: int, h: int) with _surface_window_factory {
    if _builder != 0 {
        aether_ui_surface_run_impl(_builder, title, w, h)
    }
}

// render_to — a bounded surface. Children draw into `target`; the body
// flushes a single render pass to it and returns. (Rasterize/print wiring
// lands with the vg drawing layer; for now the surface scopes + collects.)
builder render_to(target: ptr, w: int, h: int) with _surface_render_factory {
    // bounded: no loop. Flush any deferred vg scenes so their command buffers
    // are built (with final colours) before the single render pass to target.
    aether_ui_surface_flush_deferred_impl()
    _u = target
}

// record — a bounded test surface. Children draw into a recording; the body
// returns the container handle so a test can inspect what was built and the
// collected diagnostics. Returns the container handle.
builder record(w: int, h: int): int with _surface_record_factory {
    // Flush deferred vg scenes so a recording captures the drawn shapes.
    aether_ui_surface_flush_deferred_impl()
    if _builder != 0 { return _builder }
    return 0
}

// Read how many interactive-verb-on-bounded-surface diagnostics a surface
// collected (the default sink). 0 for a live window.
surface_diagnostics(container_handle: int) -> int {
    return aether_ui_surface_diag_count_impl(container_handle)
}

// register_deferred_flush(cb) — register a flush closure the enclosing surface
// body drains after its block closes (before a window's loop blocks). The
// AeVG `vg { … }` scope uses this to draw its recorded shapes with final
// colours; see docs and vg_live.ae. Boxes the closure so C can invoke it.
register_deferred_flush(cb: fn) {
    boxed = box_closure(cb)
    aether_ui_register_deferred_flush_impl(boxed)
}

// canvas_on_resize(cid, cb) — fire cb(w, h) when the canvas allocation changes.
// AeVG's vg{} scope uses this to rescale its scene on window resize. cb takes
// the new width and height as ints.
canvas_on_resize(cid: int, cb: fn) {
    boxed = box_closure(cb)
    aether_ui_canvas_on_resize_impl(cid, boxed)
}

// canvas_on_click(cid, cb) — fire cb(x, y) (canvas-local px) on a single click.
// AeVG's vg{} scope uses this to dispatch_click into its scene and hit-test
// the tracked shape elements. cb takes the click coords as floats.
canvas_on_click(cid: int, cb: fn) {
    boxed = box_closure(cb)
    aether_ui_canvas_on_click_impl(cid, boxed)
}

// canvas_on_move(cid, cb) — fire cb(x, y) (canvas-local px) on every pointer
// motion over the canvas. For hover hit-testing (e.g. a status line tracking
// the item under the cursor). No-op on backends without live motion delivery.
canvas_on_move(cid: int, cb: fn) {
    boxed = box_closure(cb)
    aether_ui_canvas_on_move_impl(cid, boxed)
}

// canvas_on_key(cid, cb) — fire cb(key_name) on a key press while the canvas
// has focus. key_name is the GDK/platform key name string (e.g. "Left",
// "space", "a"). Drives game-style input (falling-blocks, etc.); the canvas is
// made focusable and grabs focus on registration. Real on GTK4; no-op on
// backends without a key bridge yet (macos/win32 stubs).
canvas_on_key(cid: int, cb: fn) {
    boxed = box_closure(cb)
    aether_ui_canvas_on_key_impl(cid, boxed)
}

// canvas_on_release(cid, cb) — fire cb(x, y) (canvas-local px) when the pointer
// button is released. Pairs with canvas_on_click (press) + canvas_on_move to
// form a press→drag→release swipe (the Rubik's cube uses it to read a swipe's
// direction). Real on GTK4; no-op on backends without a release bridge yet.
canvas_on_release(cid: int, cb: fn) {
    boxed = box_closure(cb)
    aether_ui_canvas_on_release_impl(cid, boxed)
}

// window_run — the explicit-root window form, sibling to `window {…}`.
// Use it when the root is built imperatively (not via the ambient
// block context) — e.g. a grid whose cells are grid_place'd into a
// pre-created root_grid. Creates the window surface around the
// already-built root and runs the loop. (The `window {…}` block form
// is preferred when the tree is built declaratively inside the block.)
window_run(title: string, w: int, h: int, root_handle: int) {
    app_handle = aether_ui_app_create(title, w, h)
    aether_ui_app_set_body(app_handle, root_handle)
    aether_ui_app_run_raw(app_handle)
}

// app_run — retained alias of window_run for any un-migrated caller.
// New code uses window(…){…} (declarative) or window_run(…) (explicit
// root). Will be removed once nothing references it.
app_run(title: string, width: int, height: int, root_handle: int) {
    window_run(title, width, height, root_handle)
}

// Split-form app lifecycle: create returns a handle, then caller can
// attach a menu bar or other app-level wiring before calling start.
app_create(title: string, width: int, height: int) {
    return aether_ui_app_create(title, width, height)
}

// Finalize + run. Mirrors app_run for apps that need the split path.
app_start(app_handle: int, root_handle: int) {
    aether_ui_app_set_body(app_handle, root_handle)
    aether_ui_app_run_raw(app_handle)
}

// --- Layout containers ---

vstack(_ctx: ptr, spacing: int) {
    handle = aether_ui_vstack_create(spacing)
    if _ctx != 0 {
        aether_ui_widget_add_child_ctx(_ctx, handle)
    }
    _style_on_create(handle)   // use_styles: arrive themed
    return handle
}

hstack(_ctx: ptr, spacing: int) {
    handle = aether_ui_hstack_create(spacing)
    if _ctx != 0 {
        aether_ui_widget_add_child_ctx(_ctx, handle)
    }
    _style_on_create(handle)   // use_styles: arrive themed
    return handle
}

scrollview(_ctx: ptr) {
    handle = aether_ui_scrollview_create()
    if _ctx != 0 {
        aether_ui_widget_add_child_ctx(_ctx, handle)
    }
    return handle
}

// splitview(orient) { pane1  pane2 } — a native user-draggable two-pane
// splitter (GtkPaned on Linux). orient "h" = panes side by side (the
// divider is vertical), "v" = panes stacked. EXACTLY TWO children: the
// first two widgets declared in the block become the panes; any further
// attach is silently dropped. Splitter position: split_position /
// split_set_position (px from the left/top edge), and the driver route
// POST /widget/{id}/split_position?px= so specs can drag it.
// win32/macOS: renders as a plain stack for now (no draggable divider).
splitview(_ctx: ptr, orient: string) {
    vertical = 0
    if orient == "v" { vertical = 1 }
    handle = aether_ui_splitview_create(vertical)
    if _ctx != 0 {
        aether_ui_widget_add_child_ctx(_ctx, handle)
    }
    return handle
}

// Splitter position in px from the start edge; -1 if handle isn't a
// splitview (or on backends without a real splitter).
split_position(handle: int) -> int {
    return aether_ui_split_position_impl(handle)
}

split_set_position(handle: int, px: int) {
    aether_ui_split_set_position_impl(handle, px)
}

// weight(child, n) — proportional main-axis sharing among a stack's
// children (Flutter Expanded semantics, HONESTLY): children WITHOUT a
// weight keep their natural size; weighted children split the LEFTOVER
// space n : m. Children that expand along the axis (spacer()) count as
// weight 1. Calling weight() swaps the parent stack onto our own layout
// manager (GtkBoxLayout has no weight concept) — per-stack opt-in, other
// stacks are untouched. GTK4 only; no-op on win32/macOS for now.
weight(handle: int, n: int) {
    aether_ui_widget_weight_impl(handle, n)
}

// rtl(stack, on) — lay an hstack's children right-to-left (first child on the
// right). For localized UIs (Arabic/Hebrew). on: 1 = RTL, 0 = back to LTR.
rtl(handle: int, on: int) {
    aether_ui_set_rtl(handle, on)
}

// wrap { … } — flow container: children lay out left-to-right and wrap
// to the next line when the width runs out (GtkFlowBox). NB the backend
// interposes a "wrapitem" wrapper widget between the wrap and each child
// in the widget tree. win32/macOS: renders as a plain hstack for now.
wrap(_ctx: ptr) {
    handle = aether_ui_wrap_create()
    if _ctx != 0 {
        aether_ui_widget_add_child_ctx(_ctx, handle)
    }
    return handle
}

// on_layout(stack, cb) — the generalized GeometryReader: cb(w, h) fires
// after the stack's allocation SETTLES and CHANGES (not per frame; idle
// stays zero-cost). Safe to build/mutate widgets from inside — that's the
// point (the hook is deferred off the allocation pass). STACKS ONLY
// (vstack/hstack) v1; for canvases use canvas_on_resize, which this
// generalizes but does not replace. GTK4 only for now; no-op elsewhere.
on_layout(handle: int, cb: fn) {
    boxed = box_closure(cb)
    aether_ui_on_layout_impl(handle, boxed)
}

zstack(_ctx: ptr) {
    handle = aether_ui_zstack_create()
    if _ctx != 0 {
        aether_ui_widget_add_child_ctx(_ctx, handle)
    }
    return handle
}

form(_ctx: ptr) {
    handle = aether_ui_form_create()
    if _ctx != 0 {
        aether_ui_widget_add_child_ctx(_ctx, handle)
    }
    return handle
}

section(_ctx: ptr, title: string) {
    handle = aether_ui_form_section_create(title)
    if _ctx != 0 {
        aether_ui_widget_add_child_ctx(_ctx, handle)
    }
    // Return handle+1 (inner box) so children go inside the section
    return handle + 1
}

navstack(_ctx: ptr) {
    handle = aether_ui_navstack_create()
    if _ctx != 0 {
        aether_ui_widget_add_child_ctx(_ctx, handle)
    }
    return handle
}

nav_push(nav_handle: int, title: string, body_handle: int) {
    aether_ui_navstack_push(nav_handle, title, body_handle)
}

nav_pop(nav_handle: int) {
    aether_ui_navstack_pop(nav_handle)
}

// tabs { tab("A") {…}  tab("B") {…} } — a native tab strip over a page
// stack (GtkStackSwitcher + GtkStack). Each tab() adds a titled page and
// returns its inner container, so the tab's block children lay out inside
// it (same _ctx auto-injection as splitview's panes). The trailing block
// is the IMMEDIATE builder block (it builds the pages), so — like every
// container — the change callback is a SEPARATE registration:
// on_tab_change(tv) callback |i|, mirroring on_layout. Read/drive:
// tab_selected(tv) / tab_select(tv, i) and the driver route
// POST /widget/{id}/tab_select?i=N; widget JSON carries "tabSelected" and
// "tabCount". win32/macOS: pages render stacked (no strip) for now —
// tab_selected answers -1 there so a spec can tell.
tabs(_ctx: ptr) {
    handle = aether_ui_tabs_create(0)
    if _ctx != 0 {
        aether_ui_widget_add_child_ctx(_ctx, handle)
    }
    return handle
}

// tab(title) — add a titled page to the enclosing tabs; the returned handle
// is the page's inner container, which the DSL injects as _ctx for this
// tab's block children. Called INSIDE a tabs {} block (its _ctx is the
// tabs handle).
tab(_ctx: ptr, title: string) {
    return aether_ui_tab_add(_ctx, title)
}

// on_tab_change(tv) callback |i| — fire cb(index) when the visible tab
// changes (strip click OR tab_select). Registered after the tabs {} block,
// exactly like on_layout registers the resize hook on a built stack.
on_tab_change(tabs_handle: int, cb: fn) {
    boxed = box_closure(cb)
    aether_ui_tabs_set_on_change(tabs_handle, boxed)
}

// Programmatically switch the active tab (0-based).
tab_select(tabs_handle: int, index: int) {
    aether_ui_tabs_select(tabs_handle, index)
}

// The 0-based index of the visible tab; -1 if not a tabs composite.
tab_selected(tabs_handle: int) -> int {
    return aether_ui_tabs_selected(tabs_handle)
}

// --- Leaf widgets ---

text(_ctx: ptr, label: string) {
    handle = aether_ui_text_create(label)
    if _ctx != 0 {
        aether_ui_widget_add_child_ctx(_ctx, handle)
    }
    _style_on_create(handle)   // use_styles: arrive themed
    return handle
}

// text_wrapped(label, wrap_px): a multi-line label that wraps at wrap_px.
text_wrapped(_ctx: ptr, label: string, wrap_px: int) {
    handle = aether_ui_text_wrapped_create(label, wrap_px)
    if _ctx != 0 {
        aether_ui_widget_add_child_ctx(_ctx, handle)
    }
    _style_on_create(handle)   // use_styles: arrive themed
    return handle
}

// text_anchor(label_handle, anchor): "start" | "middle" | "end". Sets the
// horizontal alignment of a text/label widget.
text_anchor(handle: int, anchor: string) {
    a = 0
    if string.equals(anchor, "middle") == 1 { a = 1 }
    if string.equals(anchor, "center") == 1 { a = 1 }
    if string.equals(anchor, "end") == 1    { a = 2 }
    if string.equals(anchor, "right") == 1  { a = 2 }
    aether_ui_text_set_anchor(handle, a)
}

// button with immediate block — use for styling + onclick:
//   button("C") { bg_color(0.9,0.6,0.6,1.0); onclick() callback { call(clear) } }
button(_ctx: ptr, label: string) {
    handle = aether_ui_button_create_plain(label)
    if _ctx != 0 {
        aether_ui_widget_add_child_ctx(_ctx, handle)
    }
    return handle
}

// btn — quick callback-only form:
//   btn("=") callback { call(equals) }
btn(_ctx: ptr, label: string, on_press: fn) {
    boxed = box_closure(on_press)
    handle = aether_ui_button_create(label, boxed)
    if _ctx != 0 {
        aether_ui_widget_add_child_ctx(_ctx, handle)
    }
    _style_on_create(handle)   // use_styles: arrive themed
    return handle
}

spacer(_ctx: ptr) {
    handle = aether_ui_spacer_create()
    if _ctx != 0 {
        aether_ui_widget_add_child_ctx(_ctx, handle)
    }
    return handle
}

divider(_ctx: ptr) {
    handle = aether_ui_divider_create()
    if _ctx != 0 {
        aether_ui_widget_add_child_ctx(_ctx, handle)
    }
    _style_on_create(handle)   // use_styles: arrive themed
    return handle
}

// --- Input widgets (Group 2) ---

textfield(_ctx: ptr, placeholder: string, on_change: fn) {
    boxed = box_closure(on_change)
    handle = aether_ui_textfield_create(placeholder, boxed)
    if _ctx != 0 {
        aether_ui_widget_add_child_ctx(_ctx, handle)
    }
    _style_on_create(handle)   // use_styles: arrive themed
    return handle
}

// textfield_bound(placeholder, string_state): a field two-way bound to a
// string state in one call — the SwiftUI `TextField("…", text: $state)` idiom.
// Typing updates the state; ui_set_s(state, …) fills the field. No callback.
textfield_bound(_ctx: ptr, placeholder: string, state_handle: int) {
    handle = aether_ui_textfield_create(placeholder, 0)
    if _ctx != 0 {
        aether_ui_widget_add_child_ctx(_ctx, handle)
    }
    aether_ui_bind_value(state_handle, handle)
    return handle
}

securefield(_ctx: ptr, placeholder: string, on_change: fn) {
    boxed = box_closure(on_change)
    handle = aether_ui_securefield_create(placeholder, boxed)
    if _ctx != 0 {
        aether_ui_widget_add_child_ctx(_ctx, handle)
    }
    return handle
}

toggle(_ctx: ptr, label: string, on_change: fn) {
    boxed = box_closure(on_change)
    handle = aether_ui_toggle_create(label, boxed)
    if _ctx != 0 {
        aether_ui_widget_add_child_ctx(_ctx, handle)
    }
    _style_on_create(handle)   // use_styles: arrive themed
    return handle
}

// toggle_group(handle, group_with) — put a toggle in a mutual-exclusion
// group with another: exactly one member is active, and GTK renders the
// members as RADIO buttons (round indicator). Chain each member to the
// group's first toggle. Radio groups beat a picker for few-option choices
// on ChromeOS: GtkDropDown's list is a popover, which sommelier never
// displays. (Win32/macOS: stubbed — plain checkboxes, no exclusivity yet.)
toggle_group(handle: int, group_with: int) {
    aether_ui_toggle_set_group(handle, group_with)
}

slider(_ctx: ptr, min_val: float, max_val: float, initial: float, on_change: fn) {
    boxed = box_closure(on_change)
    handle = aether_ui_slider_create(min_val, max_val, initial, boxed)
    if _ctx != 0 {
        aether_ui_widget_add_child_ctx(_ctx, handle)
    }
    _style_on_create(handle)   // use_styles: arrive themed
    return handle
}

picker(_ctx: ptr, on_change: fn) {
    boxed = box_closure(on_change)
    handle = aether_ui_picker_create(boxed)
    if _ctx != 0 {
        aether_ui_widget_add_child_ctx(_ctx, handle)
    }
    _style_on_create(handle)   // use_styles: arrive themed
    return handle
}

picker_add(_ctx: ptr, picker_handle: int, item: string) {
    aether_ui_picker_add_item(picker_handle, item)
}

textarea(_ctx: ptr, placeholder: string, on_change: fn) {
    boxed = box_closure(on_change)
    handle = aether_ui_textarea_create(placeholder, boxed)
    if _ctx != 0 {
        aether_ui_widget_add_child_ctx(_ctx, handle)
    }
    _style_on_create(handle)   // use_styles: arrive themed
    return handle
}

// Programmatic get/set for a textarea's content — the on_change callback
// already hands back live edits, so these are for the OTHER direction:
// loading a preset/file into the box, or reading its content outside a
// change event (e.g. a "Run" button reading the current script).
textarea_set_text(handle: int, text: string) {
    aether_ui_textarea_set_text(handle, text)
}
textarea_get_text(handle: int) -> string {
    return aether_ui_textarea_get_text(handle)
}

progressbar(_ctx: ptr, fraction: float) {
    handle = aether_ui_progressbar_create(fraction)
    if _ctx != 0 {
        aether_ui_widget_add_child_ctx(_ctx, handle)
    }
    _style_on_create(handle)   // use_styles: arrive themed
    return handle
}

// --- Reactive state ---

ui_state(initial: float) {
    return aether_ui_state_create(initial)
}

ui_get(handle: int) {
    return aether_ui_state_get(handle)
}

ui_set(handle: int, value: float) -> int {
    aether_ui_state_set(handle, value)
    return handle
}

text_bound(_ctx: ptr, state_handle: int, prefix: string, suffix: string) {
    handle = aether_ui_text_create("")
    aether_ui_state_bind_text(state_handle, handle, prefix, suffix)
    if _ctx != 0 {
        aether_ui_widget_add_child_ctx(_ctx, handle)
    }
    return handle
}

// ── Typed state (item 8; docs/design/reactivity-unification.md) ──────
// One handle space, tagged cells. ui_state/ui_get/ui_set above are the
// float facet, unchanged. Cross-type get/set is a no-op/zero read —
// never a coercion. A set walks that state's bindings immediately
// (push; call from the main thread like every other ui verb).

ui_state_s(initial: string) {
    return aether_ui_state_create_s(initial)
}
ui_get_s(handle: int) -> string {
    return aether_ui_state_get_s(handle)
}
ui_set_s(handle: int, value: string) -> int {
    aether_ui_state_set_s(handle, value)
    return handle
}

ui_state_i(initial: int) {
    return aether_ui_state_create_i(initial)
}
ui_get_i(handle: int) -> int {
    return aether_ui_state_get_i(handle)
}
ui_set_i(handle: int, value: int) -> int {
    aether_ui_state_set_i(handle, value)
    return handle
}

ui_state_b(initial: int) {
    return aether_ui_state_create_b(initial)
}
ui_get_b(handle: int) -> int {
    return aether_ui_state_get_b(handle)
}
ui_set_b(handle: int, value: int) -> int {
    aether_ui_state_set_b(handle, value)
    return handle
}

// ── List-typed state + each_bind ────────────────────────────────────
// A LIST state holds a std.list ptr. each_bind(group, list_state) makes an
// each() group track it: every ui_set_list re-runs each_update automatically,
// so the write site is one call, not each_update at every mutation.
//   rows = ui_state_list(my_list)
//   results = each("v", 4, |it, i, parent| { … })
//   each_bind(results, rows)
//   ui_set_list(rows, new_list)      // the each list refreshes itself
ui_state_list(list_ptr: ptr) -> int {
    return aether_ui_state_create_list(list_ptr)
}
ui_get_list(handle: int) -> ptr {
    return aether_ui_state_get_list(handle)
}
ui_set_list(handle: int, list_ptr: ptr) -> int {
    aether_ui_state_set_list(handle, list_ptr)
    return handle
}
each_bind(each_group: ptr, list_state: int) {
    // Re-run each_update whenever the list-state changes.
    aether_ui_state_on_change(list_state, box_closure(|| {
        each_update(each_group, aether_ui_state_get_list(list_state))
    }))
    // Seed once from the current value.
    each_update(each_group, aether_ui_state_get_list(list_state))
}

// ── Computed / derived state ────────────────────────────────────────
// computed_s(recompute, a, b): register `recompute` to run whenever input
// state a or b changes. `recompute` is a void closure that reads the inputs
// and writes a derived state (via ui_set_s) — matching the codebase's
// void-callback idiom (a closure's return value isn't consumed through `fn`).
// It also runs once immediately to seed the derived cell.
//   full = ui_state_s("")
//   computed_s(|| { ui_set_s(full, string.concat(ui_get_s(first), ui_get_s(last))) },
//              first, last)
//   bind_text(lbl, full)
computed_s(recompute: fn, a: int, b: int) {
    recompute()   // seed the derived cell now
    boxed = box_closure(recompute)
    aether_ui_state_on_change(a, boxed)
    if b != a { aether_ui_state_on_change(b, boxed) }
}

// ── Property bindings: state → widget property, no imperative set_*
// at every write site. Data-carrying links (no closures — fmt is a
// decimals int). The widget shows the current value immediately.
//
//   bind_text(lbl, st)            // smart: int-valued floats → "42"
//   bind_text_fmt(lbl, st, 1)     // float cells: "%.1f"
//   bind_enabled(btn, bst, 0)     // sensitive while bst is truthy
//   bind_enabled(btn, bst, 1)     // inverted: ghosted while truthy
//   bind_hidden(w, bst, 0)        // hidden while truthy
//
// Truthiness: bool/int/float ≠ 0; string non-empty.
// bind_value(field, string_state): two-way. Typing in the field updates the
// state; setting the state updates the field. One line replaces the
// change-callback + explicit set idiom. Field must be a textfield/securefield
// (an editable), state must be a string cell (ui_state_s).
//   name = ui_state_s("")
//   f = textfield("Name…"); bind_value(f, name)
//   // now ui_get_s(name) tracks the field, and ui_set_s(name, x) fills it.
bind_value(widget: int, state_handle: int) {
    aether_ui_bind_value(state_handle, widget)
}
bind_text(widget: int, state_handle: int) {
    aether_ui_bind_text_impl(state_handle, widget, 0 - 1)
}
bind_text_fmt(widget: int, state_handle: int, decimals: int) {
    aether_ui_bind_text_impl(state_handle, widget, decimals)
}
bind_enabled(widget: int, state_handle: int, invert: int) {
    aether_ui_bind_enabled_impl(state_handle, widget, invert)
}
bind_hidden(widget: int, state_handle: int, invert: int) {
    aether_ui_bind_hidden_impl(state_handle, widget, invert)
}

// --- Widget accessors ---

set_text(handle: int, text: string) -> int {
    aether_ui_textfield_set_text(handle, text)
    return handle
}

// Update a button's label in place (breadcrumb navs, toggling captions).
set_button_label(handle: int, label: string) -> int {
    aether_ui_button_set_label(handle, label)
    return handle
}

// Show/hide any widget by handle (1 = hidden). Layout reflows around it.
set_hidden(handle: int, hidden: int) -> int {
    aether_ui_widget_set_hidden(handle, hidden)
    return handle
}

// Append a right-click context-menu item to a widget; cb fires when chosen.
//   context_menu_item(row, "Copy path") callback { ... }
// GTK4 has the full popover implementation; AppKit/Win32 are no-op stubs.
// shortcut("Ctrl+R") callback { … } — a per-window accelerator (Swing
// InputMap WHEN_IN_FOCUSED_WINDOW; SwiftUI .keyboardShortcut). Fires no
// matter which widget has focus: an entry swallows plain keys but never
// modified combos. Combo syntax "Ctrl+R" / "Shift+Delete" / "F5" /
// "Escape" (GTK's "<Control>r" also accepted). Register any time —
// pre-window registrations attach when the window appears. Driver:
// POST /window/key?combo= fires the same closure (no fake input
// events); GET /focus and POST /widget/{id}/focus round out the story.
// GTK4 only for now; no-op elsewhere.
shortcut(combo: string, cb: fn) {
    boxed = box_closure(cb)
    aether_ui_shortcut_impl(combo, boxed)
}

// shortcut_when(combo, enabled, cb): a conditional/scoped shortcut. `enabled`
// is a predicate (|-> int); when it returns 0 the combo is inert and the key
// propagates as if unbound — so the same combo can mean different things (or
// nothing) depending on app state. GTK4 real; win32 stub; macOS degrades to a
// plain shortcut for now.
//   shortcut_when("Ctrl+W", || panel_open, || close_panel())
shortcut_when(combo: string, enabled: fn, cb: fn) {
    aether_ui_shortcut_when_impl(combo, box_closure(cb), box_closure(enabled))
}

// shortcut_chord(first, second, cb): a two-key sequence (VSCode/Emacs style).
// Pressing `first` then `second` within ~1.5s fires cb. GTK4 real; win32/macOS
// stub for now.
//   shortcut_chord("Ctrl+K", "Ctrl+S", || save_all())
shortcut_chord(first: string, second: string, cb: fn) {
    aether_ui_shortcut_chord_impl(first, second, box_closure(cb))
}

// focused_widget() -> the registry handle of the widget with keyboard focus
// (0 = none). The building block for per-widget shortcut scopes.
focused_widget() -> int {
    return aether_ui_focused_widget()
}

// widget_shortcut(widget, combo, cb): a shortcut active ONLY while `widget`
// (or a descendant) has keyboard focus — a per-widget scope. E.g. Enter in a
// search box, arrow keys in a list. Built on shortcut_when + a focus check, so
// it's inert (the key propagates) when focus is elsewhere.
//   widget_shortcut(search_box, "Enter", || run_search())
widget_shortcut(widget: int, combo: string, cb: fn) {
    shortcut_when(combo, || { return focused_widget() == widget }, cb)
}

// focus(handle) — explicit keyboard-focus grab. The default Tab order
// is the BUILD order (GTK's focus chain over the widget tree) — that
// default is the feature; this is the override for dialog-primary-
// field flows.
focus(handle: int) {
    aether_ui_focus_impl(handle)
}

// context_menu_item_accel — a context-menu item that DISPLAYS its
// keyboard combo. Display only: pairing the behaviour is the app also
// registering ui.shortcut with the same combo.
context_menu_item_accel(handle: int, label: string, accel: string, cb: fn) -> int {
    boxed = box_closure(cb)
    aether_ui_context_menu_item_accel_impl(handle, label, accel, boxed)
    return handle
}

context_menu_item(handle: int, label: string, cb: fn) -> int {
    boxed = box_closure(cb)
    aether_ui_context_menu_item_impl(handle, label, boxed)
    return handle
}

get_text(handle: int) {
    return aether_ui_textfield_get_text(handle)
}

set_toggle(handle: int, active: int) -> int {
    aether_ui_toggle_set_active(handle, active)
    return handle
}

get_toggle(handle: int) {
    return aether_ui_toggle_get_active(handle)
}

set_slider(handle: int, value: float) -> int {
    aether_ui_slider_set_value(handle, value)
    return handle
}

get_slider(handle: int) {
    return aether_ui_slider_get_value(handle)
}

set_progress(handle: int, fraction: float) -> int {
    aether_ui_progressbar_set_fraction(handle, fraction)
    return handle
}

// --- Styling (Group 4) ---

// --- Context-aware styling (use inside trailing blocks) ---
// These receive _ctx from the builder context stack, so they apply
// to the current widget automatically:
//   button("OK") { bg_color(0.2, 0.6, 0.3, 1.0) }

bg_color(_ctx: ptr, r: float, g: float, b: float, a: float) {
    aether_ui_set_bg_color_ctx(_ctx, r, g, b, a)
}

text_color(_ctx: ptr, r: float, g: float, b: float) {
    aether_ui_set_text_color_ctx(_ctx, r, g, b)
}

font_size(_ctx: ptr, size: float) {
    aether_ui_set_font_size_ctx(_ctx, size)
}

font_bold(_ctx: ptr) {
    aether_ui_set_font_bold_ctx(_ctx, 1)
}

corner_radius(_ctx: ptr, radius: float) {
    aether_ui_set_corner_radius_ctx(_ctx, radius)
}

opacity(_ctx: ptr, val: float) {
    aether_ui_set_opacity_ctx(_ctx, val)
}

enabled(_ctx: ptr, val: int) {
    aether_ui_set_enabled_ctx(_ctx, val)
}

tooltip(_ctx: ptr, text: string) {
    aether_ui_set_tooltip_ctx(_ctx, text)
}

onclick(_ctx: ptr, handler: fn) {
    boxed = box_closure(handler)
    aether_ui_set_onclick_ctx(_ctx, boxed)
}

// --- Explicit-handle styling (use outside blocks) ---

// --- Explicit-handle styling (use outside blocks). Each returns its
// handle so calls chain via UFCS: title.style_font_size(20).style_font_bold()
// (x.f(args) desugars to f(x, args) — Aether #928/#934). Existing flat
// calls keep working; UFCS is a last-resort fallback. ---

style_bg_color(handle: int, r: float, g: float, b: float, a: float) -> int {
    aether_ui_set_bg_color(handle, r, g, b, a)
    return handle
}

style_text_color(handle: int, r: float, g: float, b: float) -> int {
    aether_ui_set_text_color(handle, r, g, b)
    return handle
}

style_font_size(handle: int, size: float) -> int {
    aether_ui_set_font_size(handle, size)
    return handle
}

style_font_bold(handle: int) -> int {
    aether_ui_set_font_bold(handle, 1)
    return handle
}
// Two-valued weight — style_font_weight(h, 0) genuinely un-bolds (v1.1).
style_font_weight(handle: int, bold: int) -> int {
    aether_ui_set_font_bold(handle, bold)
    return handle
}
// Widget-level font family (verbatim to the platform: generic CSS families
// resolve on GTK4/macOS; on win32 prefer real face names like "Consolas").
style_font_family(handle: int, family: string) -> int {
    aether_ui_set_font_family(handle, family)
    return handle
}

style_bg_gradient(handle: int, r1: float, g1: float, b1: float,
                   r2: float, g2: float, b2: float, vertical: int) -> int {
    aether_ui_set_bg_gradient(handle, r1, g1, b1, r2, g2, b2, vertical)
    return handle
}

style_corner_radius(handle: int, radius: float) -> int {
    aether_ui_set_corner_radius(handle, radius)
    return handle
}

style_opacity(handle: int, val: float) -> int {
    // Via CSS (not gtk_widget_set_opacity): a registered ui.transition on
    // "opacity" then tweens the change; with no transition it's instant.
    css = "opacity: ${val};"
    aether_ui_widget_apply_css_impl(handle, css)
    return handle
}

style_enabled(handle: int, val: int) -> int {
    aether_ui_set_enabled(handle, val)
    return handle
}

style_tooltip(handle: int, text: string) -> int {
    aether_ui_set_tooltip(handle, text)
    return handle
}

// ── AeCS — Aether Cascading Styles ───────────────────────────────────
// The stylesheet layer: a declarative, cascading styles model over the
// imperative style_* setters, modelled on Swiby's create_styles/apply_styles
// (Jean Lazarou & the Swiby committers, BSD — see docs/design/styling.md). Selectors are widget KINDS as
// the driver reports them ("button", "text", "textfield", …), plus:
//   "root"           — the fallback every unmatched property cascades to
//   "container"      — alias matching vstack/hstack/zstack
//   "cls.kind"/"cls" — class-scoped rules; widgets opt in via add_css_class
// Resolution per property (swiby's order, sans ids): class.kind → class →
// kind → container-alias → root. apply_styles(target, s) walks the LIVE tree
// (0 = everything) and calls the existing setters — so a theme is just a
// sheet, and re-theming a running app is one call.
//
//   s = create_styles()
//   st_font_size(s, "root", 11.0)
//   st_color(s, "button", 0x5C458A)      // swiby blue_theme's button color
//   st_bg(s, "container", 0xD6CFE6)
//   apply_styles(0, s)
struct StyleRule {
    sel: string,
    has_color: int, color: int,     // packed 0xRRGGBB text color
    has_bg: int, bg: int,           // packed 0xRRGGBB background
    has_fs: int, fs: float,         // font size (px)
    has_bold: int, bold: int,       // font weight (1=bold 0=normal; two-valued
                                    //   since v1.1 so re-themes can un-bold)
    has_radius: int, radius: float, // corner radius
    has_family: int, family: string,// font family (verbatim to the platform)
    has_opacity: int, opacity: float,
    has_grad: int, grad1: int, grad2: int,   // vertical bg gradient (packed hex)
    has_insets: int, in_t: float, in_r: float, in_b: float, in_l: float
}

struct StyleSheet { rules: ptr }    // std.list of *StyleRule

create_styles() -> ptr {
    s = malloc(8) as *StyleSheet
    s.rules = list.new()
    return s as ptr
}

// Find a rule (null when absent) / get-or-create for the setters.
_style_find(sp: ptr, sel: string) -> ptr {
    s = sp as *StyleSheet
    n = list.size(s.rules)
    i = 0
    while i < n {
        it, _e = list.get(s.rules, i)
        r = it as *StyleRule
        if string.equals(r.sel, sel) == 1 { return it }
        i = i + 1
    }
    return null
}

_style_rule_of(sp: ptr, sel: string) -> ptr {
    found = _style_find(sp, sel)
    if found != null { return found }
    s = sp as *StyleSheet
    r = malloc(224) as *StyleRule
    r.sel = sel
    r.has_color = 0
    r.has_bg = 0
    r.has_fs = 0
    r.has_bold = 0
    r.has_radius = 0
    r.has_family = 0
    r.has_opacity = 0
    r.has_grad = 0
    r.has_insets = 0
    _ = list.add(s.rules, r as ptr)
    return r as ptr
}

st_color(sp: ptr, sel: string, hex: int) {
    r = _style_rule_of(sp, sel) as *StyleRule
    r.has_color = 1
    r.color = hex
}
st_bg(sp: ptr, sel: string, hex: int) {
    r = _style_rule_of(sp, sel) as *StyleRule
    r.has_bg = 1
    r.bg = hex
}
st_font_size(sp: ptr, sel: string, size: float) {
    r = _style_rule_of(sp, sel) as *StyleRule
    r.has_fs = 1
    r.fs = size
}
// Two-valued weight (v1.1): st_weight(s, sel, 0) un-bolds on a re-theme, so a
// full "default/reset" sheet can genuinely revert what a bolder theme set.
st_weight(sp: ptr, sel: string, bold: int) {
    r = _style_rule_of(sp, sel) as *StyleRule
    r.has_bold = 1
    r.bold = bold
}
st_bold(sp: ptr, sel: string) {
    st_weight(sp, sel, 1)
}
st_font_family(sp: ptr, sel: string, family: string) {
    r = _style_rule_of(sp, sel) as *StyleRule
    r.has_family = 1
    r.family = family
}
st_opacity(sp: ptr, sel: string, val: float) {
    r = _style_rule_of(sp, sel) as *StyleRule
    r.has_opacity = 1
    r.opacity = val
}
// Vertical background gradient, top hex1 → bottom hex2.
st_gradient(sp: ptr, sel: string, hex1: int, hex2: int) {
    r = _style_rule_of(sp, sel) as *StyleRule
    r.has_grad = 1
    r.grad1 = hex1
    r.grad2 = hex2
}
st_insets(sp: ptr, sel: string, top: float, right: float,
          bottom: float, left: float) {
    r = _style_rule_of(sp, sel) as *StyleRule
    r.has_insets = 1
    r.in_t = top
    r.in_r = right
    r.in_b = bottom
    r.in_l = left
}
st_radius(sp: ptr, sel: string, radius: float) {
    r = _style_rule_of(sp, sel) as *StyleRule
    r.has_radius = 1
    r.radius = radius
}

// Property codes for the generic first-match scan.
// 0=color 1=bg 2=font_size 3=weight 4=radius 5=family 6=opacity 7=grad 8=insets
_rule_has(rp: ptr, prop: int) -> int {
    r = rp as *StyleRule
    if prop == 0 { return r.has_color }
    if prop == 1 { return r.has_bg }
    if prop == 2 { return r.has_fs }
    if prop == 3 { return r.has_bold }
    if prop == 4 { return r.has_radius }
    if prop == 5 { return r.has_family }
    if prop == 6 { return r.has_opacity }
    if prop == 7 { return r.has_grad }
    return r.has_insets
}

// A candidate selector defines `prop`? (empty selector never matches)
_style_probe(sp: ptr, prop: int, sel: string) -> ptr {
    if string.length(sel) == 0 { return null }
    r = _style_find(sp, sel)
    if r != null { if _rule_has(r, prop) == 1 { return r } }
    return null
}

// The nth space-separated token of the widget's class list ("" past the end).
// Tokens starting with "#" are IDS (style_id stores them here — one shared,
// driver-visible store on all three backends).
_tok_at(cls: string, want: int) -> string {
    rest = cls
    i = 0
    while i < 32 {
        idx = string.string_index_of(rest, " ")
        tok = rest
        if idx >= 0 { tok = string.string_substring(rest, 0, idx) }
        if i == want { return tok }
        if idx < 0 { return "" }
        rest = string.string_substring(rest, idx + 1, string.length(rest))
        i = i + 1
    }
    return ""
}

_tok_is_id(tok: string) -> int {
    if string.length(tok) == 0 { return 0 }
    if string.string_index_of(tok, "#") == 0 { return 1 }
    return 0
}

// Resolve one property down the full cascade (swiby's order):
//   id ("#name") → class.kind (EVERY class, in add order) → class (every) →
//   kind → container alias → root
_style_resolve(sp: ptr, prop: int, cls: string, kind: string,
               alias: string) -> ptr {
    // ids
    n = 0
    while n < 32 {
        tok = _tok_at(cls, n)
        if string.length(tok) == 0 { break }
        if _tok_is_id(tok) == 1 {
            r = _style_probe(sp, prop, tok)
            if r != null { return r }
        }
        n = n + 1
    }
    // class.kind — all classes, in the order they were added
    n = 0
    while n < 32 {
        tok = _tok_at(cls, n)
        if string.length(tok) == 0 { break }
        if _tok_is_id(tok) == 0 {
            r2 = _style_probe(sp, prop,
                string.concat(tok, string.concat(".", kind)))
            if r2 != null { return r2 }
        }
        n = n + 1
    }
    // bare class
    n = 0
    while n < 32 {
        tok = _tok_at(cls, n)
        if string.length(tok) == 0 { break }
        if _tok_is_id(tok) == 0 {
            r3 = _style_probe(sp, prop, tok)
            if r3 != null { return r3 }
        }
        n = n + 1
    }
    r4 = _style_probe(sp, prop, kind)
    if r4 != null { return r4 }
    r5 = _style_probe(sp, prop, alias)
    if r5 != null { return r5 }
    return _style_probe(sp, prop, "root")
}

_style_is_container(kind: string) -> int {
    if string.equals(kind, "vstack") == 1 { return 1 }
    if string.equals(kind, "hstack") == 1 { return 1 }
    if string.equals(kind, "zstack") == 1 { return 1 }
    return 0
}

// Apply the sheet to ONE widget: resolve each property down the cascade and
// call the imperative setter it lands on.
_style_apply_one(sp: ptr, h: int, kind: string) {
    cls = aether_ui_widget_classes_impl(h)
    alias = ""
    if _style_is_container(kind) == 1 { alias = "container" }

    rc = _style_resolve(sp, 0, cls, kind, alias)
    if rc != null {
        r = rc as *StyleRule
        hex = r.color
        _ = style_text_color(h, ((hex / 65536) % 256) / 255.0,
                                ((hex / 256) % 256) / 255.0,
                                (hex % 256) / 255.0)
    }
    rb = _style_resolve(sp, 1, cls, kind, alias)
    if rb != null {
        r2 = rb as *StyleRule
        hex2 = r2.bg
        _ = style_bg_color(h, ((hex2 / 65536) % 256) / 255.0,
                              ((hex2 / 256) % 256) / 255.0,
                              (hex2 % 256) / 255.0, 1.0)
    }
    rf = _style_resolve(sp, 2, cls, kind, alias)
    if rf != null {
        r3 = rf as *StyleRule
        _ = style_font_size(h, r3.fs)
    }
    rw = _style_resolve(sp, 3, cls, kind, alias)
    if rw != null {
        r5 = rw as *StyleRule
        _ = style_font_weight(h, r5.bold)
    }
    rr = _style_resolve(sp, 4, cls, kind, alias)
    if rr != null {
        r4 = rr as *StyleRule
        _ = style_corner_radius(h, r4.radius)
    }
    rm = _style_resolve(sp, 5, cls, kind, alias)
    if rm != null {
        r6 = rm as *StyleRule
        _ = style_font_family(h, r6.family)
    }
    ro = _style_resolve(sp, 6, cls, kind, alias)
    if ro != null {
        r7 = ro as *StyleRule
        _ = style_opacity(h, r7.opacity)
    }
    rg = _style_resolve(sp, 7, cls, kind, alias)
    if rg != null {
        r8 = rg as *StyleRule
        g1 = r8.grad1
        g2 = r8.grad2
        _ = style_bg_gradient(h,
            ((g1 / 65536) % 256) / 255.0, ((g1 / 256) % 256) / 255.0,
            (g1 % 256) / 255.0,
            ((g2 / 65536) % 256) / 255.0, ((g2 / 256) % 256) / 255.0,
            (g2 % 256) / 255.0, 1)
    }
    ri = _style_resolve(sp, 8, cls, kind, alias)
    if ri != null {
        r9 = ri as *StyleRule
        _ = edge_insets(h, r9.in_t, r9.in_r, r9.in_b, r9.in_l)
    }
}

// Style a JUST-CREATED widget from the current sheet (use_styles). Element/
// container/root rules land here; class and id rules land when
// add_css_class/style_id run (see the re-apply hook there).
_style_on_create(h: int) {
    cur = aether_ui_current_sheet_get_impl()
    if cur == null { return }
    kind = aether_ui_widget_kind_impl(h)
    if string.length(kind) > 0 { _style_apply_one(cur, h, kind) }
}

// style_id(w, "submit") — name a widget for "#submit" sheet rules (highest
// precedence, swiby's :style_id). Stored as a "#"-prefixed token in the
// class list: one shared store, already tracked on all three backends and
// visible in the driver's "classes" field.
style_id(handle: int, name: string) {
    add_css_class(handle, string.concat("#", name))
}

// styles_for_mode(light, dark) — the dark/light pair helper: returns the
// sheet matching the OS appearance right now. Re-call + re-apply on a mode
// flip (there is no appearance-change event yet — poll or re-apply on user
// action).
styles_for_mode(light: ptr, dark: ptr) -> ptr {
    if is_dark_mode() == 1 { return dark }
    return light
}

// True when `h` is `target` or sits under it (parent-chain walk).
_style_is_under(h: int, target: int) -> int {
    p = h
    hops = 0
    while hops < 64 {
        if p == target { return 1 }
        p = aether_ui_widget_parent_impl(p)
        if p == 0 { return 0 }
        hops = hops + 1
    }
    return 0
}

// apply_styles(target, s) — restyle the LIVE tree under `target` (0 = every
// widget) from the sheet. Call again after building new subtrees, and call
// with a different sheet to re-theme a running app (the swiby banking-demo
// move: preview a theme on one panel, then apply it to the whole app).
apply_styles(target: int, sp: ptr) {
    n = aether_ui_widget_count_impl()
    h = 1
    while h <= n {
        kind = aether_ui_widget_kind_impl(h)
        if string.length(kind) > 0 {
            ok = 1
            if target != 0 { ok = _style_is_under(h, target) }
            if ok == 1 { _style_apply_one(sp, h, kind) }
        }
        h = h + 1
    }
}

// use_styles(s) — apply the sheet now AND make it the CURRENT sheet, so
// widgets built afterwards arrive already styled (constructors consult it;
// class/id rules land when add_css_class/style_id run). The swiby
// use_styles, but automatic for new subtrees.
use_styles(sp: ptr) {
    aether_ui_current_sheet_set_impl(sp)
    apply_styles(0, sp)
}

current_styles() -> ptr {
    return aether_ui_current_sheet_get_impl()
}

// on_appearance_change(cb) — cb(|dark: int|) fires when the OS flips
// light/dark (GTK settings notify / win32 WM_SETTINGCHANGE / macOS theme
// notification), or when the driver POSTs /appearance?dark=N. ONE slot:
// the latest registration wins (use_styles_pair claims it).
on_appearance_change(cb: fn) {
    aether_ui_appearance_register_impl(box_closure(cb))
    aether_ui_watch_appearance_impl()
}


// use_styles_pair(light, dark) — the whole dark/light story in one call:
// applies the sheet for the CURRENT mode (as the current sheet) and
// re-themes automatically on every OS mode flip.
use_styles_pair(light: ptr, dark: ptr) {
    use_styles(styles_for_mode(light, dark))
    on_appearance_change(|isdark: int| {
        if isdark == 1 { use_styles(dark) }
        if isdark == 0 { use_styles(light) }
    })
}

// ── load_styles: themes as FILES (swiby's load_styles) ──────────────
// A minimal line format, one declaration per line:
//   // comment
//   text.color       = #5C458A
//   container.bg     = #D6CFE6
//   root.size        = 11
//   header.text.weight = bold        (selector may itself contain dots —
//   #status.color    = #224488        the LAST dot splits off the property)
//   root.family      = monospace
//   hint.text.opacity = 0.6
// Props: color bg size weight radius family opacity. Unknown lines are
// skipped (forward compatibility). Returns a sheet, or null on read error.
_hex6(s: string) -> int {
    hx = s
    if string.string_index_of(hx, "#") == 0 {
        hx = string.string_substring(hx, 1, string.length(hx))
    }
    v, _e = string.to_int_radix(hx, 16)
    return v
}

_style_line(sp: ptr, line: string) {
    l = string.trim(line)
    if string.length(l) == 0 { return }
    if string.string_index_of(l, "//") == 0 { return }
    eq = string.string_index_of(l, "=")
    if eq < 1 { return }
    lhs = string.trim(string.string_substring(l, 0, eq))
    rhs = string.trim(string.string_substring(l, eq + 1, string.length(l)))
    // The LAST dot splits selector from property (selectors carry dots).
    dot = 0 - 1
    i = 0
    n = string.length(lhs)
    while i < n {
        c = string.string_substring(lhs, i, i + 1)
        if string.equals(c, ".") == 1 { dot = i }
        i = i + 1
    }
    if dot < 1 { return }
    sel = string.string_substring(lhs, 0, dot)
    prop = string.string_substring(lhs, dot + 1, n)
    if string.equals(prop, "color") == 1 { st_color(sp, sel, _hex6(rhs)) }
    if string.equals(prop, "bg") == 1 { st_bg(sp, sel, _hex6(rhs)) }
    if string.equals(prop, "size") == 1 {
        v, _e1 = string.to_float(rhs)
        st_font_size(sp, sel, v)
    }
    if string.equals(prop, "weight") == 1 {
        b = 0
        if string.equals(rhs, "bold") == 1 { b = 1 }
        st_weight(sp, sel, b)
    }
    if string.equals(prop, "radius") == 1 {
        v2, _e2 = string.to_float(rhs)
        st_radius(sp, sel, v2)
    }
    if string.equals(prop, "family") == 1 { st_font_family(sp, sel, rhs) }
    if string.equals(prop, "opacity") == 1 {
        v3, _e3 = string.to_float(rhs)
        st_opacity(sp, sel, v3)
    }
}

// ── QML States on AeCS ──────────────────────────────────────────────
// Named states for a widget/subtree — QML's States idea landing on AeCS:
// each state is an AeCS sheet fragment; set_state applies it to the target
// subtree through the existing setters, so properties with a declared
// ui.transition ANIMATE between states and the rest snap. The current
// state is driver-visible as a marker class ("st-<name>" in "classes").
//
//   ws = ui_states(card)
//   add_state(ws, "collapsed", collapsed_sheet)
//   add_state(ws, "expanded", expanded_sheet)
//   set_state(ws, "expanded")        // animates declared properties
struct WStateEntry { name: string, sheet: ptr }
struct WStates { target: int, entries: ptr, cur: string }

ui_states(target: int) -> ptr {
    ws = malloc(24) as *WStates
    ws.target = target
    ws.entries = list.new()
    ws.cur = ""
    return ws as ptr
}

add_state(wsp: ptr, name: string, sheet: ptr) {
    ws = wsp as *WStates
    e = malloc(16) as *WStateEntry
    e.name = name
    e.sheet = sheet
    _ = list.add(ws.entries, e as ptr)
}

current_state(wsp: ptr) -> string {
    ws = wsp as *WStates
    return ws.cur
}

set_state(wsp: ptr, name: string) -> int {
    ws = wsp as *WStates
    n = list.size(ws.entries)
    i = 0
    while i < n {
        it, _e = list.get(ws.entries, i)
        en = it as *WStateEntry
        if string.equals(en.name, name) == 1 {
            // Swap the driver-visible marker class before applying, so
            // class-scoped rules in the state's sheet can target it too.
            if string.length(ws.cur) > 0 {
                remove_css_class(ws.target, string.concat("st-", ws.cur))
            }
            add_css_class(ws.target, string.concat("st-", name))
            ws.cur = name
            apply_styles(ws.target, en.sheet)
            return 1
        }
        i = i + 1
    }
    return 0
}

// ── Undo/Redo (the Swing UndoManager shape) ─────────────────────────
// An app-wide undoable-edit stack (backend-shared store): undoable(label,
// do, undo) RUNS `do` now and records the pair; undo()/redo() step the
// cursor; pushing after undos truncates the redo tail (the classic rule).
// enable_undo_shortcuts() wires Ctrl+Z / Ctrl+Shift+Z. The driver drives
// the same stack via POST /undo, POST /redo, GET /undo_state.
undoable(label: string, do_action: fn, undo_action: fn) {
    do_action()
    aether_ui_undo_push_impl(label, box_closure(undo_action),
                             box_closure(do_action))
}

undo() -> int { return aether_ui_undo_step_impl() }
redo() -> int { return aether_ui_redo_step_impl() }
undo_depth() -> int { return aether_ui_undo_depth_impl() }
redo_depth() -> int { return aether_ui_redo_depth_impl() }
undo_label() -> string { return aether_ui_undo_label_impl() }

enable_undo_shortcuts() {
    shortcut("Ctrl+Z", || {
        _u = aether_ui_undo_step_impl()
    })
    shortcut("Ctrl+Shift+Z", || {
        _r = aether_ui_redo_step_impl()
    })
}

load_styles(path: string) -> ptr {
    content, err = fs.read(path)
    if string.length(err) > 0 { return null }
    sp = create_styles()
    rest = content
    guard = 0
    while guard < 4096 {
        nl = string.string_index_of(rest, "\n")
        if nl < 0 {
            _style_line(sp, rest)
            return sp
        }
        _style_line(sp, string.string_substring(rest, 0, nl))
        rest = string.string_substring(rest, nl + 1, string.length(rest))
        guard = guard + 1
    }
    return sp
}

// ── Accessibility (semantics layer) ──────────────────────────────────
// Set the platform accessible role/name/description on any widget. Native
// widgets already carry sane a11y for free; these OVERRIDE it where the auto
// value is wrong or missing (icon-only buttons, plain containers acting as
// groups/listitems, drawn controls). Backends map to GtkAccessible / MSAA /
// NSAccessibility; the driver reads back the real accessible state via
// GET /widget/{id}/a11y. See docs/design/accessibility.md.
//
// role vocabulary: button checkbox radio link heading image group list
// listitem tab tablist menu menuitem dialog alert textbox slider
// progressbar none  ("none" hides a decorative widget from the a11y tree).
a11y_role(handle: int, role: string) -> int {
    aether_ui_a11y_set_role_impl(handle, role)
    return handle
}

// The accessible NAME (what a screen reader announces).
a11y_label(handle: int, name: string) -> int {
    aether_ui_a11y_set_label_impl(handle, name)
    return handle
}

// A longer accessible description (announced after the name).
a11y_description(handle: int, desc: string) -> int {
    aether_ui_a11y_set_description_impl(handle, desc)
    return handle
}

edge_insets(handle: int, top: float, right: float, bottom: float, left: float) -> int {
    aether_ui_set_edge_insets(handle, top, right, bottom, left)
    return handle
}

width(handle: int, w: int) -> int {
    aether_ui_set_width(handle, w)
    return handle
}

height(handle: int, h: int) -> int {
    aether_ui_set_height(handle, h)
    return handle
}

distribution(handle: int, dist: int) -> int {
    aether_ui_set_distribution(handle, dist)
    return handle
}

alignment(handle: int, align: int) -> int {
    aether_ui_set_alignment(handle, align)
    return handle
}

fill_width(handle: int) -> int {
    aether_ui_match_parent_width(handle)
    return handle
}

fill_height(handle: int) -> int {
    aether_ui_match_parent_height(handle)
    return handle
}

// margin — in-block modifier: applies to the ambient element (_ctx).
// Inside `vstack(4) { margin(12, 12, 12, 12); … }` it pads the vstack,
// no named handle needed (parallels bg_color / onclick). Outside a
// block, `_ctx` is 0 and the call is a no-op; use margin_of for an
// explicit target.
margin(_ctx: ptr, top: int, right: int, bottom: int, left: int) {
    if _ctx != 0 {
        aether_ui_set_margin_ctx(_ctx, top, right, bottom, left)
    }
}

// margin_of — explicit-target form: pad a specific widget handle
// (e.g. a child captured by name, not the ambient one).
margin_of(handle: int, top: int, right: int, bottom: int, left: int) -> int {
    aether_ui_set_margin(handle, top, right, bottom, left)
    return handle
}

// --- System integration (Group 5) ---

alert(title: string, msg: string) {
    aether_ui_alert_impl(title, msg)
}

clipboard_write(text: string) {
    aether_ui_clipboard_write_impl(text)
}

open_url(url: string) {
    aether_ui_open_url_impl(url)
}

// Native file pickers — block, return the chosen path ("" if cancelled).
// GtkFileChooserNative / IFileDialog(GetOpenFileName) / NSOpenPanel|NSSavePanel.
// Headless-no-op (return "") like alert/menu_popup — a modal has no seat on CI.
//   path = open_file("Choose a song")
//   path = save_file("Export as", "untitled.txt")
open_file(title: string) -> string {
    return aether_ui_file_open(title)
}
save_file(title: string, default_name: string) -> string {
    return aether_ui_file_save(title, default_name)
}

is_dark_mode() {
    return aether_ui_dark_mode_check()
}

timer(interval_ms: int, on_tick: fn) {
    boxed = box_closure(on_tick)
    return aether_ui_timer_create_impl(interval_ms, boxed)
}

timer_cancel(timer_id: int) {
    aether_ui_timer_cancel_impl(timer_id)
}

// Multi-window
window_create(title: string, width: int, height: int) {
    return aether_ui_window_create_impl(title, width, height)
}

window_set_body(win_handle: int, root_handle: int) {
    aether_ui_window_set_body_impl(win_handle, root_handle)
}

window_show(win_handle: int) {
    aether_ui_window_show_impl(win_handle)
}

window_close(win_handle: int) {
    aether_ui_window_close_impl(win_handle)
}

// ---------------------------------------------------------------------------
// In-window overlay layer — the Swing JLayeredPane / Flutter Overlay.
//
// Build the content as an ordinary container (vstack/box/vg canvas) then open
// it as an overlay above a window's root. Anchor is one of the 9 combos:
// "top-start" "top" "top-end" "start" "center" "end"
// "bottom-start" "bottom" "bottom-end". dx/dy are signed margins (px).
// ---------------------------------------------------------------------------
overlay_anchor_code(anchor: string) -> int {
    h = 1  // horizontal: 0=start, 1=center, 2=end
    v = 1  // vertical:   0=top,   1=center, 2=bottom
    if string.contains(anchor, "start") == 1 { h = 0 }
    if string.contains(anchor, "end") == 1   { h = 2 }
    if string.contains(anchor, "top") == 1    { v = 0 }
    if string.contains(anchor, "bottom") == 1 { v = 2 }
    return h + v * 4
}

// overlay(win, content, anchor, dx, dy) -> overlay handle. win 0 = main window.
overlay(win_handle: int, content_handle: int, anchor: string, dx: int, dy: int) -> int {
    code = overlay_anchor_code(anchor)
    return aether_ui_overlay_open_impl(win_handle, content_handle, code, dx, dy, 0)
}

// overlay_modal(win, content, anchor, dx, dy, on_dismiss) -> overlay handle.
// Inserts a full-window scrim below the content that eats clicks and fires
// on_dismiss (the glass pane).
overlay_modal(win_handle: int, content_handle: int, anchor: string,
              dx: int, dy: int, on_dismiss: fn) -> int {
    code = overlay_anchor_code(anchor)
    h = aether_ui_overlay_open_impl(win_handle, content_handle, code, dx, dy, 1)
    if h > 0 {
        boxed = box_closure(on_dismiss)
        aether_ui_overlay_set_on_dismiss_impl(h, boxed)
    }
    return h
}

dismiss_overlay(overlay_handle: int) {
    aether_ui_overlay_close_impl(overlay_handle)
}

overlay_is_live(overlay_handle: int) -> int {
    return aether_ui_overlay_is_live_impl(overlay_handle)
}

// transition_overlay(overlay, kind, ms) — declare a per-ENTRY enter+exit
// transition. Enter plays on open; exit plays on dismiss, and the entry is
// only really removed after the exit tween (so overlay_is_exiting reads 1
// during it, then live flips to 0). kind: "fade" | "slide-up" | "slide-down"
// | "scale". AETHER_UI_NO_ANIMATION collapses both to instant (the entry is
// removed immediately on dismiss) so driver suites stay deterministic.
transition_overlay(overlay_handle: int, kind: string, ms: int) {
    aether_ui_overlay_set_transition_impl(overlay_handle, kind, ms)
}

// True while an entry is playing its EXIT transition (dismissed, not yet
// removed). 0 before dismiss and after the tween finishes.
overlay_is_exiting(overlay_handle: int) -> int {
    return aether_ui_overlay_is_exiting_impl(overlay_handle)
}

// overlay_material(overlay, kind) — the visual treatment of a modal's scrim.
// kind: "dim" (default translucent black) | "blur" (frosted backdrop) |
// "tint" (a stronger lighter tint). A real BACKDROP BLUR is only native on
// macOS (NSVisualEffectView); win32/GTK4 degrade "blur" to "tint" (there is no
// in-window blur there). overlay_material_effective reports what was actually
// applied so a spec can assert the degrade. See docs/design/backdrop-material.md.
overlay_material(overlay_handle: int, kind: string) {
    aether_ui_overlay_set_material_impl(overlay_handle, kind)
}

// The material the backend ACTUALLY applied ("dim"|"blur"|"tint") — "blur"
// only on macOS; "tint" is the off-macOS degrade of a requested blur.
overlay_material_effective(overlay_handle: int) -> string {
    return aether_ui_overlay_material_effective_impl(overlay_handle)
}

// toast(win, text, ms) — a transient bottom-center message, auto-dismissed
// after ms. win 0 = main window. Returns the overlay handle.
toast(win_handle: int, text: string, ms: int) -> int {
    return aether_ui_toast_impl(win_handle, text, ms)
}

// ---------------------------------------------------------------------------
// canvas_on_hover — robust enter/leave detection for a canvas-shaped sensor.
//
// Fires cb(1) when the pointer enters `canvas_id`'s bounds, cb(0) when it
// leaves. That's the same contract as plain `on_hover`, but built on
// `canvas_on_move` instead: `on_hover`'s AppKit backing (AetherHoverMonitor)
// captures its NSTrackingArea ONCE at registration and never refreshes it —
// fine for a widget whose geometry never changes again, but silently stale
// (and prone to reading spurious enter/exit pairs) for anything shown/
// hidden/resized/reattached afterward, which is exactly the shape of bug a
// bundled hover-to-reveal panel widget hit here originally (see git history
// / TODO.md). `canvas_on_move`'s tracking area IS kept in sync
// (`updateTrackingAreas` runs on layout, confirmed in aether_ui_macos.m), so
// building on it sidesteps the whole staleness class rather than working
// around one instance of it.
//
// This is deliberately a bare PRIMITIVE, not a widget: no built-in
// "hint"/"panel" pairing, no owned show/hide policy, no overlay of its own.
// You build whatever shape of sensor you want (an edge strip, a corner
// square, a handle) with a plain `canvas_create`, position it however you
// like (overlay(), or as a normal child), and decide entirely for yourself
// what "entered"/"left" means — reveal a hover panel, arm a click-to-open
// affordance, whatever. See examples/auto_hide_demo for two different
// compositions on top of this same primitive: a hover-reveal edge zone, and
// a click-to-open sidebar whose handle follows it.
//
// canvas_on_move has no matching "the pointer left" event of its own, so
// "left" is inferred from a short watchdog timer that every move event
// resets: if it ever actually fires, no move arrived in time, so the
// pointer must have gone. 80ms is comfortably above the gap between
// consecutive move events on a real trackpad/mouse (which fire far more
// often than that) while still reading as instant to a person.
struct CanvasHoverState {
    inside: int
    watchdog: int
}

canvas_on_hover(canvas_id: int, cb: fn) {
    s = malloc(16) as *CanvasHoverState
    s.inside = 0
    s.watchdog = 0

    canvas_on_move(canvas_id) callback |x: float, y: float| {
        if s.inside == 0 {
            s.inside = 1
            call(cb, 1)
        }
        if s.watchdog > 0 {
            timer_cancel(s.watchdog)
        }
        s.watchdog = timer(80) callback {
            // timer() is a REPEATING interval, not one-shot (confirmed the
            // hard way elsewhere in this file) — self-cancel so a single
            // "no move arrived" tick doesn't keep firing cb(0) every 80ms
            // after the pointer has already left.
            timer_cancel(s.watchdog)
            s.inside = 0
            s.watchdog = 0
            call(cb, 0)
        }
    }
}

// vg drawn tooltip — the vg live loop calls these on hover. show near the
// pointer (canvas-local cx,cy); hide when the pointer leaves a tooltipped
// element. vg_tooltip_drawn() gates the whole path (native elsewhere).
vg_tooltip_show(canvas_id: int, text: string, cx: float, cy: float) -> int {
    return aether_ui_vg_tooltip_show_impl(canvas_id, text, cx, cy)
}
vg_tooltip_hide() {
    aether_ui_vg_tooltip_hide_impl()
}
vg_tooltip_drawn() -> int {
    return aether_ui_vg_tooltip_drawn_impl()
}

// ---------------------------------------------------------------------------
// each — dynamic children (roadmap item 3; the ng-repeat half).
//
// The language already gives build-time repetition (loops in immediate
// blocks). `each` is repetition over TIME: re-running the per-item build when
// the LIST changes. It owns a plain group container (vstack/hstack) created
// where the verb appears; each_update(e, items) clears that group and re-runs
// the render closure per item — clear+rebuild, ng-repeat-without-track-by
// semantics (keyed reuse is a later item; see briefs history).
//
//   rows = each("v", 4) callback |item: ptr, i: int, parent: int| {
//       it = item as *MyItem
//       _b = btn(parent, it.name) callback { ...uses it/i... }
//   }
//   ...
//   each_update(rows, my_list)          // explicit, imperative (item 8 will
//                                       // add a binding overload; not yet)
//
// The render closure receives (item, index, parent-container-handle) — the
// 3-arg form; build item widgets into `parent` with the handle-as-first-arg
// pattern. NB (compiler): a `_ =` discard inside a closure-in-closure emits
// broken C — name the discard (`_b =`) in render bodies.
//
// Lifetime notes: removed widgets' handles are weak-ref-nulled by the
// registry; their boxed closures are retained by the C side and are NOT
// freed on removal — a small, bounded leak per removed child (same class as
// every boxed closure today). Requires aether >= 0.390 (closure envs retain
// captured heap strings — PR #1127; on older compilers per-item labels
// dangle).
// ---------------------------------------------------------------------------

struct EachGroup {
    container: int,     // the group box all item widgets live in
    render: ptr,        // boxed render closure |item, i, parent|
    count: int          // last rendered item count
}

// fn-typed-param bridge (the events.ae invoker pattern): stored-ptr → call.
_each_invoke(cb: fn, item: ptr, i: int, parent: int) {
    cb(item, i, parent)
}

// each(orientation "v"|"h", spacing, render) -> each-handle. Creates the group
// container in the enclosing block (auto-attached via _ctx).
each(_ctx: ptr, orientation: string, spacing: int, render: fn) -> ptr {
    h = 0
    if string.equals(orientation, "h") == 1 {
        h = aether_ui_hstack_create(spacing)
    } else {
        h = aether_ui_vstack_create(spacing)
    }
    if _ctx != 0 {
        aether_ui_widget_add_child_ctx(_ctx, h)
    }
    e = malloc(24) as *EachGroup
    e.container = h
    e.render = box_closure(render)
    e.count = 0
    return e as ptr
}

// each_update(e, items) — clear the group, re-run render(item, i, parent) for
// every element of `items` (a std.list of ptr).
each_update(ep: ptr, items: ptr) {
    e = ep as *EachGroup
    aether_ui_clear_children_impl(e.container)
    r = unbox_closure(e.render)
    n = list.size(items)
    i = 0
    while i < n {
        it, _lerr = list.get(items, i)
        _each_invoke(r, it, i, e.container)
        i = i + 1
    }
    e.count = n
}

// Last rendered item count (tests/apps).
each_count(ep: ptr) -> int {
    e = ep as *EachGroup
    return e.count
}

// The group container's widget handle (for styling/driver lookups).
each_parent(ep: ptr) -> int {
    e = ep as *EachGroup
    return e.container
}

// ---------------------------------------------------------------------------
// listbox — rows over a list, selection synced, driver-visible (item 4 D1).
//
// An `each`-backed column of real row widgets inside whatever container the
// verb appears in (put it in a scrollview for long lists). Each row is an
// hstack the USER's render template fills; the listbox wires row-click →
// selection (.aui-row-selected CSS) → the on_select callback. Rows are real
// widgets: the driver clicks a row via POST /widget/{row}/click (the click
// action falls back to gesture handlers on non-buttons) and specs assert
// selection via the row JSON's "classes" field. Data flow matches each:
// explicit listbox_update(lb, items); selection RESETS on update (v1 —
// clear+rebuild has no row identity to preserve; track-by is the later fix).
//
//   people = listbox(4) callback |item: ptr, i: int, row: int| {
//       p = item as *Person
//       _t = text(row, p.name)
//   }
//   on_select(people) callback |i: int| { ... }
//   ...
//   listbox_update(people, people_list)
// ---------------------------------------------------------------------------

struct ListBox {
    group: ptr,        // the underlying each
    rows: ptr,         // intarr of row handles for the CURRENT render, or null
    selected: int,     // single-select: selected row index, -1 = none
    on_sel: ptr,       // boxed |i: int| callback, or null
    user_render: ptr,  // boxed |item, i, row| row template
    multi: int,        // 0 = single-select, 1 = multi-select (toggle rows)
    sel_flags: ptr,    // multi: intarr of 0/1 per row, or null
    on_dbl: ptr,       // boxed |i: int| row double-click callback, or null
    items: ptr,        // reorderable: the OWNED std.list, so move() can reorder
    on_reorder: ptr    // boxed |from, to| move callback, or null
}

_listbox_invoke_render(cb: fn, item: ptr, i: int, row: int) {
    cb(item, i, row)
}

_listbox_invoke_sel(cb: fn, i: int) {
    cb(i)
}

_listbox_apply_selection(lb: *ListBox, i: int) {
    if lb.rows == null { return }
    if lb.multi == 1 {
        // Toggle row i's membership; class follows the flag.
        if lb.sel_flags == null { return }
        cur = intarr_get_raw(lb.sel_flags, i)
        newv = 1
        if cur == 1 { newv = 0 }
        intarr_set_raw(lb.sel_flags, i, newv)
        rowh = intarr_get_raw(lb.rows, i)
        if rowh > 0 {
            if newv == 1 { aether_ui_widget_add_css_class_impl(rowh, "aui-row-selected") }
            else { aether_ui_widget_remove_css_class_impl(rowh, "aui-row-selected") }
        }
        lb.selected = i   // last-touched, for single-select callers
        return
    }
    if lb.selected >= 0 {
        oldh = intarr_get_raw(lb.rows, lb.selected)
        if oldh > 0 { aether_ui_widget_remove_css_class_impl(oldh, "aui-row-selected") }
    }
    lb.selected = i
    if i >= 0 {
        newh = intarr_get_raw(lb.rows, i)
        if newh > 0 { aether_ui_widget_add_css_class_impl(newh, "aui-row-selected") }
    }
}

_listbox_row_clicked(lbp: ptr, i: int) {
    lb = lbp as *ListBox
    _listbox_apply_selection(lb, i)
    if lb.on_sel != null {
        cb = unbox_closure(lb.on_sel)
        _listbox_invoke_sel(cb, i)
    }
}

// listbox(spacing, render) -> listbox-handle. render = |item, i, row|.
listbox(_ctx: ptr, spacing: int, render: fn) -> ptr {
    return _listbox_make(_ctx, spacing, render, 0)
}

// listbox_multi(spacing, render): like listbox but clicking rows TOGGLES their
// selection — any number of rows can be selected at once. listbox_is_selected
// reads a row's state; on_select fires with the toggled row's index.
listbox_multi(_ctx: ptr, spacing: int, render: fn) -> ptr {
    return _listbox_make(_ctx, spacing, render, 1)
}

_listbox_make(_ctx: ptr, spacing: int, render: fn, multi: int) -> ptr {
    lb = malloc(80) as *ListBox
    lb.rows = null
    lb.selected = 0 - 1
    lb.on_sel = null
    lb.user_render = box_closure(render)
    lb.multi = multi
    lb.sel_flags = null
    lb.on_dbl = null
    lb.items = null
    lb.on_reorder = null
    lbp = lb as ptr
    lb.group = each(_ctx, "v", spacing) callback |item: ptr, i: int, parent: int| {
        row = hstack(parent, 8)
        intarr_set_raw(lb.rows, i, row)
        ur = unbox_closure(lb.user_render)
        _listbox_invoke_render(ur, item, i, row)
        _oc = on_click(row) callback { _listbox_row_clicked(lbp, i) }
        _od = on_double_click(row) callback { _listbox_row_double(lbp, i) }
        // Built-in a11y: each row is a listitem so an AT sees list structure.
        _ar = a11y_role(row, "listitem")
    }
    _agl = a11y_role(each_parent(lb.group), "list")
    return lbp
}

_listbox_row_double(lbp: ptr, i: int) {
    lb = lbp as *ListBox
    if lb.on_dbl != null {
        cb = unbox_closure(lb.on_dbl)
        _listbox_invoke_sel(cb, i)
    }
}

// on_row_double_click(lb) callback |i: int| — fires when a row is double-
// clicked (native gesture, or the driver's /widget/{row}/double_click).
on_row_double_click(lbp: ptr, cb: fn) {
    lb = lbp as *ListBox
    lb.on_dbl = box_closure(cb)
}

// listbox_update(lb, items) — re-render the rows; selection resets. The list
// is RETAINED (so a reorderable listbox's move() can reorder it in place).
listbox_update(lbp: ptr, items: ptr) {
    lb = lbp as *ListBox
    if lb.rows != null { intarr_free(lb.rows) }
    n = list.size(items)
    sz = n
    if sz < 1 { sz = 1 }
    lb.rows = intarr_new_raw(sz)
    lb.selected = 0 - 1
    if lb.multi == 1 {
        if lb.sel_flags != null { intarr_free(lb.sel_flags) }
        lb.sel_flags = intarr_new_raw(sz)   // all 0 = nothing selected
    }
    lb.items = items
    each_update(lb.group, items)
}

// listbox_reorderable(spacing, render): a listbox whose rows can be REORDERED.
// listbox_move(from, to) moves an item and re-renders; a native drag gesture
// (GTK4 drag source/target) calls the same move on drop. on_reorder(lb) is
// notified of every move so the app can persist the new order.
listbox_reorderable(_ctx: ptr, spacing: int, render: fn) -> ptr {
    return _listbox_make_reorder(_ctx, spacing, render)
}

// on_reorder(lb) callback |from: int, to: int| — fires after a row moves.
on_reorder(lbp: ptr, cb: fn) {
    lb = lbp as *ListBox
    lb.on_reorder = box_closure(cb)
}

_listbox_invoke_reorder(cb: fn, from: int, to: int) {
    cb(from, to)
}

// Build a reorderable listbox: rows are native drag sources + drop targets, and
// a drop calls listbox_move(source_index, target_index). The drag gesture is
// backend C (GTK4 GtkDragSource/GtkDropTarget); the model reorder is shared.
_listbox_make_reorder(_ctx: ptr, spacing: int, render: fn) -> ptr {
    lb = malloc(80) as *ListBox
    lb.rows = null
    lb.selected = 0 - 1
    lb.on_sel = null
    lb.user_render = box_closure(render)
    lb.multi = 0
    lb.sel_flags = null
    lb.on_dbl = null
    lb.items = null
    lb.on_reorder = null
    lbp = lb as ptr
    lb.group = each(_ctx, "v", spacing) callback |item: ptr, i: int, parent: int| {
        row = hstack(parent, 8)
        intarr_set_raw(lb.rows, i, row)
        ur = unbox_closure(lb.user_render)
        _listbox_invoke_render(ur, item, i, row)
        _oc = on_click(row) callback { _listbox_row_clicked(lbp, i) }
        // Make this row drag-reorderable: on drop of row `src` onto this row
        // (index i), move src → i.
        aether_ui_row_drag_reorder_impl(row, i, box_closure(|src: int| {
            listbox_move(lbp, src, i)
        }))
    }
    return lbp
}

// Move item `from` to index `to` in the listbox's list, re-render, notify.
// std.list has no insert-at-index, so rebuild the list with the item
// repositioned (the app's list is replaced by the reordered one).
listbox_move(lbp: ptr, from: int, to: int) {
    lb = lbp as *ListBox
    if lb.items == null { return }
    n = list.size(lb.items)
    if from < 0 { return }
    if from >= n { return }
    if to < 0 { to = 0 }
    if to >= n { to = n - 1 }
    if from == to { return }
    moved, _me = list.get(lb.items, from)
    out = list.new()
    // Walk the original order, skipping `from`, and splice `moved` in at `to`.
    dst = 0
    i = 0
    while i < n {
        if i == from {
            i = i + 1
            continue
        }
        if dst == to { _ = list.add(out, moved) }
        it, _e = list.get(lb.items, i)
        _ = list.add(out, it)
        dst = dst + 1
        i = i + 1
    }
    // If `to` is at/after the end, append.
    if to >= dst { _ = list.add(out, moved) }
    lb.items = out
    listbox_update(lb as ptr, out)
    if lb.on_reorder != null {
        cb = unbox_closure(lb.on_reorder)
        _listbox_invoke_reorder(cb, from, to)
    }
}

// Multi-select: is row i currently selected? (0/1). Single-select listboxes
// answer via listbox_selected.
listbox_is_selected(lbp: ptr, i: int) -> int {
    lb = lbp as *ListBox
    if lb.multi != 1 { return 0 }
    if lb.sel_flags == null { return 0 }
    return intarr_get_raw(lb.sel_flags, i)
}

// Programmatic selection (same path as a row click, incl. the callback).
listbox_select(lbp: ptr, i: int) {
    _listbox_row_clicked(lbp, i)
}

listbox_selected(lbp: ptr) -> int {
    lb = lbp as *ListBox
    return lb.selected
}

listbox_count(lbp: ptr) -> int {
    lb = lbp as *ListBox
    return each_count(lb.group)
}

// listbox_items(lb) — the listbox's CURRENT backing list. After a reorder the
// listbox owns a rebuilt list (listbox_move replaces it), so read it here
// rather than the app's original list handle, which goes stale.
listbox_items(lbp: ptr) -> ptr {
    lb = lbp as *ListBox
    return lb.items
}

// on_select(lb) callback |i: int| { … } — fires on click AND listbox_select.
on_select(lbp: ptr, cb: fn) {
    lb = lbp as *ListBox
    lb.on_sel = box_closure(cb)
}

// Generic CSS-class styling (the selection-visual primitive, exported for
// apps too; GTK-only — no-op stubs elsewhere).
// transition(handle, prop, ms, easing) — QML-Behavior-style: declare once,
// every subsequent change of `prop` on this widget TWEENS instead of
// snapping. v1 props: "opacity" (style_opacity routes through CSS so the
// transition engine sees it) and "all" (any CSS-driven change, incl. the
// theme's enabled/disabled fade). easing: "linear" | "ease_out".
// AETHER_UI_NO_ANIMATION=1 makes this a no-op — every change is instant
// (ci.sh exports it for spec phases; specs assert END states).
transition(handle: int, prop: string, ms: int, easing: string) -> int {
    if os_getenv("AETHER_UI_NO_ANIMATION") != null { return handle }
    ease = "ease-out"
    if string.equals(easing, "linear") == 1 { ease = "linear" }
    css = "transition: ${prop} ${ms}ms "
    css = string.concat(css, ease)
    css = string.concat(css, ";")
    aether_ui_widget_apply_css_impl(handle, css)
    return handle
}

// style_shadow(handle, dx, dy, blur, css_color) — a CSS box-shadow on a
// native widget (GTK; no-op elsewhere). The vg-side sibling is vg.shadow.
style_shadow(handle: int, dx: int, dy: int, blur: int, color: string) -> int {
    css = "box-shadow: ${dx}px ${dy}px ${blur}px "
    css = string.concat(css, color)
    css = string.concat(css, ";")
    aether_ui_widget_apply_css_impl(handle, css)
    return handle
}

// Canvas group-opacity pair: composite the commands between begin/end
// offscreen and paint ONCE at alpha — overlapping shapes don't double-darken.
canvas_group_begin(canvas_id: int) {
    aether_ui_canvas_group_begin_impl(canvas_id)
}
canvas_group_end(canvas_id: int, alpha: float) {
    aether_ui_canvas_group_end_impl(canvas_id, alpha)
}

// Read one rendered pixel (offscreen replay at w×h) — packed 0xAARRGGBB
// premultiplied, -1 on error. The pixel-assertion primitive for tests.
canvas_read_pixel(canvas_id: int, px: int, py: int, w: int, h: int) -> int {
    return aether_ui_canvas_read_pixel_impl(canvas_id, px, py, w, h)
}

add_css_class(handle: int, cls: string) {
    aether_ui_widget_add_css_class_impl(handle, cls)
    // Class (and #id) rules from the CURRENT sheet land the moment the class
    // is attached — construction-time styling only saw element/root rules.
    _style_on_create(handle)
}
remove_css_class(handle: int, cls: string) {
    aether_ui_widget_remove_css_class_impl(handle, cls)
}

// ---------------------------------------------------------------------------
// table — the column layer over listbox (item 4 D2).
//
// A column spec + a per-cell TEXT template. The header row is buttons firing
// on_sort(col) — the APP re-orders its list and calls table_update; the
// widget never owns the data. Cells are text widgets sized to the column
// width; selection/update/driver surface are the listbox's.
//
//   cols = table_cols()
//   table_col(cols, "Name", 220)
//   table_col(cols, "Size", 90)
//   t = table(cols) callback |item: ptr, c: int| -> string {
//       p = item as *Person
//       if c == 1 { return p.size }
//       return p.name
//   }
//   on_sort(t) callback |c: int| { …sort my list…; table_update(t, my_list) }
//   table_update(t, my_list)
// ---------------------------------------------------------------------------

struct TableCol { title: string, w: int, delegate: ptr }
struct TableDef { cols: ptr, lb: ptr, cell: ptr, sort_cb: ptr }

table_cols() -> ptr { return list.new() }

table_col(cols: ptr, title: string, w: int) {
    c = malloc(24) as *TableCol
    c.title = title
    c.w = w
    c.delegate = null
    _ = list.add(cols, c as ptr)
}

// table_col_delegate(cols, title, w, render): a column whose cells are built by
// `render` (|item, i, cell| — build widgets into `cell`, a per-cell hstack)
// instead of the string cell(). For %-bars, chips, buttons, anything custom.
table_col_delegate(cols: ptr, title: string, w: int, render: fn) {
    c = malloc(24) as *TableCol
    c.title = title
    c.w = w
    c.delegate = box_closure(render)
    _ = list.add(cols, c as ptr)
}

_table_invoke_delegate(cb: fn, item: ptr, i: int, cell: int) {
    cb(item, i, cell)
}

_table_invoke_cell(cb: fn, item: ptr, c: int) -> string {
    return cb(item, c)
}

_table_invoke_sort(cb: fn, c: int) {
    cb(c)
}

// table(cols, cell) -> table-handle. cell = |item, c| -> string.
table(_ctx: ptr, cols: ptr, cell: fn) -> ptr {
    t = malloc(32) as *TableDef
    t.cols = cols
    t.cell = box_closure(cell)
    t.sort_cb = null
    tp = t as ptr
    // ONE widget into the parent: header + body wrapped in a vstack (a
    // scrollview parent takes a single child; two attachments would clobber).
    wrap = vstack(_ctx, 2)
    // Header row: one flat button per column, at the column's width.
    hdr = hstack(wrap, 8)
    nc = list.size(cols)
    ci = 0
    while ci < nc {
        cp, _ce = list.get(cols, ci)
        col = cp as *TableCol
        hb = btn(hdr, col.title) callback { _table_header_clicked(tp, ci) }
        _w1 = width(hb, col.w)
        ci = ci + 1
    }
    // Body: a listbox whose row template renders one cell per column. A plain
    // column shows the string cell(); a delegate column gets a sized hstack the
    // delegate renders widgets into.
    t.lb = listbox(wrap, 2) callback |item: ptr, i: int, row: int| {
        cf = unbox_closure(t.cell)
        cj = 0
        n2 = list.size(t.cols)
        while cj < n2 {
            cp2, _ce2 = list.get(t.cols, cj)
            col2 = cp2 as *TableCol
            if col2.delegate != null {
                dcell = hstack(row, 4)
                _wc = width(dcell, col2.w)
                dg = unbox_closure(col2.delegate)
                _table_invoke_delegate(dg, item, i, dcell)
            } else {
                cell_s = _table_invoke_cell(cf, item, cj)
                tx = text(row, cell_s)
                _w2 = width(tx, col2.w)
            }
            cj = cj + 1
        }
    }
    return tp
}

_table_header_clicked(tp: ptr, c: int) {
    t = tp as *TableDef
    if t.sort_cb != null {
        cb = unbox_closure(t.sort_cb)
        _table_invoke_sort(cb, c)
    }
}

// on_sort(t) callback |c: int| { … } — header click; the app sorts + updates.
on_sort(tp: ptr, cb: fn) {
    t = tp as *TableDef
    t.sort_cb = box_closure(cb)
}

table_update(tp: ptr, items: ptr) {
    t = tp as *TableDef
    listbox_update(t.lb, items)
}

table_select(tp: ptr, i: int) {
    t = tp as *TableDef
    listbox_select(t.lb, i)
}

table_selected(tp: ptr) -> int {
    t = tp as *TableDef
    return listbox_selected(t.lb)
}

table_count(tp: ptr) -> int {
    t = tp as *TableDef
    return listbox_count(t.lb)
}

// ── Tree (hierarchical rows with expand/collapse) ───────────────────
// Build a node model, then render it: each visible node is a row with an
// indent + a disclosure control (▾ expanded / ▸ collapsed / blank leaf) that
// toggles its subtree. The tree flattens the visible nodes into a listbox and
// re-flattens on every toggle.
//   root = tree_node("Documents")
//   kid  = tree_node("report.pdf")
//   tree_add_child(root, kid)
//   roots = list.new(); list.add(roots, root as ptr)
//   t = tree(roots)
struct TreeNode { label: string, children: ptr, expanded: int }
struct TreeDef  { roots: ptr, lb: ptr, flat: ptr }

tree_node(label: string) -> ptr {
    n = malloc(24) as *TreeNode
    n.label = label
    n.children = null
    n.expanded = 0
    return n as ptr
}
tree_add_child(parent: ptr, child: ptr) {
    p = parent as *TreeNode
    if p.children == null { p.children = list.new() }
    _ = list.add(p.children, child)
}

// Depth-first flatten of visible nodes into t.flat; each entry is a boxed
// (node, depth) pair. We store node ptr and depth in parallel via a small
// struct so the row render knows how far to indent.
struct TreeRow { node: ptr, depth: int }

_tree_flatten_into(flat: ptr, nodes: ptr, depth: int) {
    if nodes == null { return }
    n = list.size(nodes)
    i = 0
    while i < n {
        np, _e = list.get(nodes, i)
        node = np as *TreeNode
        tr = malloc(16) as *TreeRow
        tr.node = np
        tr.depth = depth
        _ = list.add(flat, tr as ptr)
        if node.expanded == 1 {
            _tree_flatten_into(flat, node.children, depth + 1)
        }
        i = i + 1
    }
}

_tree_reflatten(tp: ptr) {
    t = tp as *TreeDef
    t.flat = list.new()
    _tree_flatten_into(t.flat, t.roots, 0)
    listbox_update(t.lb, t.flat)
}

tree(_ctx: ptr, roots: ptr) -> ptr {
    t = malloc(24) as *TreeDef
    t.roots = roots
    t.flat = null
    tp = t as ptr
    t.lb = listbox(_ctx, 2) callback |item: ptr, i: int, row: int| {
        tr = item as *TreeRow
        node = tr.node as *TreeNode
        // Indent: one blank spacer-string per depth level.
        pad = ""
        d = 0
        while d < tr.depth {
            pad = string.concat(pad, "    ")
            d = d + 1
        }
        _pad = text(row, pad)
        // Disclosure: a real toggle for parents, blank for leaves.
        has_kids = 0
        if node.children != null { if list.size(node.children) > 0 { has_kids = 1 } }
        if has_kids == 1 {
            glyph = "▸"
            if node.expanded == 1 { glyph = "▾" }
            _dt = btn(row, glyph) callback {
                if node.expanded == 1 { node.expanded = 0 } else { node.expanded = 1 }
                _tree_reflatten(tp)
            }
        } else {
            _lt = text(row, "  ")
        }
        _lbl = text(row, node.label)
    }
    _tree_reflatten(tp)
    return tp
}

// Programmatic expand/collapse + a count of currently-visible rows.
tree_set_expanded(node_p: ptr, expanded: int) {
    n = node_p as *TreeNode
    n.expanded = expanded
}
tree_refresh(tp: ptr) { _tree_reflatten(tp) }
tree_visible_count(tp: ptr) -> int {
    t = tp as *TreeDef
    if t.flat == null { return 0 }
    return list.size(t.flat)
}

// ── Virtualized list (recycled window over a large item list) ───────
// A vlist holds the FULL item list but only ever realizes a window of
// `window` row widgets — the visible slice [first, first+window). Scrolling
// shifts the window and re-renders that slice, so widget count stays bounded
// no matter how many items there are (10k items, ~window widgets). The render
// closure receives the ABSOLUTE index so rows can show their true position.
//   v = vlist("v", 12, |item, i, parent| { text(parent, label_of(item, i)) })
//   vlist_set(v, big_list)          // renders items 0..11
//   vlist_scroll_to(v, 500)         // window slides to 500..511, recycles
struct VList {
    container: int,     // the vstack the window's rows live in
    render: ptr,        // boxed |item, absolute_i, parent|
    items: ptr,         // the full std.list (not owned)
    window: int,        // max rows realized at once
    first: int          // current window start index
}

vlist(_ctx: ptr, orientation: string, window: int, render: fn) -> ptr {
    h = 0
    if string.equals(orientation, "h") == 1 {
        h = aether_ui_hstack_create(2)
    } else {
        h = aether_ui_vstack_create(2)
    }
    if _ctx != 0 {
        aether_ui_widget_add_child_ctx(_ctx, h)
    }
    v = malloc(40) as *VList
    v.container = h
    v.render = box_closure(render)
    v.items = null
    v.window = window
    v.first = 0
    return v as ptr
}

// Render the current window [first, first+window) of `items` into the
// container. Only up to `window` widgets are ever created.
_vlist_render(v: *VList) {
    aether_ui_clear_children_impl(v.container)
    if v.items == null { return }
    r = unbox_closure(v.render)
    n = list.size(v.items)
    i = v.first
    last = v.first + v.window
    if last > n { last = n }
    while i < last {
        it, _e = list.get(v.items, i)
        _each_invoke(r, it, i, v.container)   // absolute index i
        i = i + 1
    }
}

vlist_set(vp: ptr, items: ptr) {
    v = vp as *VList
    v.items = items
    v.first = 0
    _vlist_render(v)
}

// Slide the window so it starts at `index` (clamped so it never runs past the
// end), then re-render. This is the scroll primitive; a native-scroll gesture
// would call it as the viewport moves.
vlist_scroll_to(vp: ptr, index: int) {
    v = vp as *VList
    if v.items == null { return }
    n = list.size(v.items)
    maxfirst = n - v.window
    if maxfirst < 0 { maxfirst = 0 }
    f = index
    if f < 0 { f = 0 }
    if f > maxfirst { f = maxfirst }
    v.first = f
    _vlist_render(v)
}

vlist_count(vp: ptr) -> int {
    v = vp as *VList
    if v.items == null { return 0 }
    return list.size(v.items)
}
vlist_window_first(vp: ptr) -> int {
    v = vp as *VList
    return v.first
}

// vlist_scrollable(v): wire NATIVE scroll (wheel / two-finger / drag) on the
// vlist container to the window. Each scroll step slides the window by `dy`
// rows via vlist_scroll_to (dy>0 = toward the end). The recycling core is
// unchanged — this just feeds it real gestures. Headless, the driver drives a
// step with POST /widget/{id}/scroll?dy=N (a real wheel can't be synthesised
// off-thread), the same path a gesture takes.
vlist_scrollable(vp: ptr) -> ptr {
    v = vp as *VList
    aether_ui_vlist_attach_scroll_impl(v.container, box_closure(|dy: int| {
        vlist_scroll_to(vp, v.first + dy)
    }))
    return vp
}

// The container handle native scroll is attached to (for driver targeting).
vlist_container(vp: ptr) -> int {
    v = vp as *VList
    return v.container
}

// table_on_select(t) callback |i: int| — row selection (delegates to listbox).
table_on_select(tp: ptr, cb: fn) {
    t = tp as *TableDef
    on_select(t.lb, cb)
}

// table_bind(t, list_state): the table tracks a LIST state — every ui_set_list
// re-runs table_update. The each_bind sibling for tables. Seeds once.
table_bind(tp: ptr, list_state: int) {
    aether_ui_state_on_change(list_state, box_closure(|| {
        table_update(tp, aether_ui_state_get_list(list_state))
    }))
    table_update(tp, aether_ui_state_get_list(list_state))
}

// Modal sheet
sheet_create(title: string, width: int, height: int) {
    return aether_ui_sheet_create_impl(title, width, height)
}

sheet_set_body(handle: int, root_handle: int) {
    aether_ui_sheet_set_body_impl(handle, root_handle)
}

sheet_present(handle: int) {
    aether_ui_sheet_present_impl(handle)
}

sheet_dismiss(handle: int) {
    aether_ui_sheet_dismiss_impl(handle)
}

// Image widget
image(_ctx: ptr, filepath: string) {
    handle = aether_ui_image_create(filepath)
    if _ctx != 0 {
        aether_ui_widget_add_child_ctx(_ctx, handle)
    }
    return handle
}

// image_from_bytes(data, length) — decode encoded image bytes (PNG / JPEG /
// GIF / BMP …) straight into an image widget, no temp file. `data` is a
// byte string (binary-safe via the explicit length — e.g. from a network
// fetch, a generated buffer, or an embedded-art blob). GTK4 decodes via
// GdkTexture, win32 via GDI+, macOS via NSImage. Decode failure leaves an
// empty image (the widget still exists, so the tree is stable).
image_from_bytes(_ctx: ptr, data: string, length: int) {
    handle = aether_ui_image_from_bytes(data, length)
    if _ctx != 0 {
        aether_ui_widget_add_child_ctx(_ctx, handle)
    }
    return handle
}

image_size(handle: int, width: int, height: int) {
    aether_ui_image_set_size(handle, width, height)
}

// --- Canvas drawing (Group 6) ---

canvas_create(_ctx: ptr, width: int, height: int) {
    cid = aether_ui_canvas_create_impl(width, height)
    wh = aether_ui_canvas_get_widget(cid)
    if _ctx != 0 {
        aether_ui_widget_add_child_ctx(_ctx, wh)
    }
    return cid
}

canvas_begin_path(cid: int) {
    aether_ui_canvas_begin_path_impl(cid)
}

canvas_move_to(cid: int, x: float, y: float) {
    aether_ui_canvas_move_to_impl(cid, x, y)
}

canvas_line_to(cid: int, x: float, y: float) {
    aether_ui_canvas_line_to_impl(cid, x, y)
}

// Default cap/join (butt/miter — the SVG defaults). For explicit caps/joins
// use canvas_stroke_cj.
canvas_stroke(cid: int, r: float, g: float, b: float, a: float, line_width: float) {
    aether_ui_canvas_stroke_impl(cid, r, g, b, a, line_width, 0, 0)
}

// Stroke with explicit line cap/join. cap: 0=butt 1=round 2=square.
// join: 0=miter 1=round 2=bevel.
canvas_stroke_cj(cid: int, r: float, g: float, b: float, a: float, line_width: float,
                 cap: int, join: int) {
    aether_ui_canvas_stroke_impl(cid, r, g, b, a, line_width, cap, join)
}

canvas_fill_rect(cid: int, x: float, y: float, w: float, h: float,
                  r: float, g: float, b: float, a: float) {
    aether_ui_canvas_fill_rect_impl(cid, x, y, w, h, r, g, b, a)
}

// canvas_clip_rect — intersect the clip region with (x,y,w,h). AeVG emits one
// at scene-flush start to clip to the viewport (SVG overflow:hidden). Persists
// for the rest of the frame's replay.
canvas_clip_rect(cid: int, x: float, y: float, w: float, h: float) {
    aether_ui_canvas_clip_rect_impl(cid, x, y, w, h)
}

// Append a circle/arc to the current path. For a full circle pass
// start=0, end=2π. Fill or stroke afterward.
canvas_arc(cid: int, cx: float, cy: float, radius: float,
           start_angle: float, end_angle: float) {
    aether_ui_canvas_arc_impl(cid, cx, cy, radius, start_angle, end_angle)
}

// Close the current sub-path (connects back to the last move_to).
canvas_close_path(cid: int) {
    aether_ui_canvas_close_path_impl(cid)
}

// Fill the current path with a solid color.
canvas_fill(cid: int, r: float, g: float, b: float, a: float) {
    aether_ui_canvas_fill_impl(cid, r, g, b, a)
}

// Draw text at (x, y) — the text baseline origin — with the given
// font size and color.
// font_flags packs the toy-font selection: bit0 monospace, bit1 bold,
// bit2 italic (see the backend's canvas_select_font).
canvas_fill_text(cid: int, text: string, x: float, y: float, font_size: float,
                 font_flags: int, r: float, g: float, b: float, a: float) {
    aether_ui_canvas_fill_text_impl(cid, text, x, y, font_size, font_flags, r, g, b, a)
}

// Stroke (outline) text at (x, y). Queue after canvas_fill_text for the same
// run so the outline paints over the fill (SVG stroke-on-<text>).
canvas_stroke_text(cid: int, text: string, x: float, y: float, font_size: float,
                   line_width: float, font_flags: int, r: float, g: float, b: float, a: float) {
    aether_ui_canvas_stroke_text_impl(cid, text, x, y, font_size, line_width, font_flags, r, g, b, a)
}

// Blit an RGBA8888 pixel buffer (iw×ih, byte_len = iw*ih*4) at canvas
// position (x, y). `rgba` carries the raw bytes as a binary string.
canvas_draw_image(cid: int, x: float, y: float, iw: int, ih: int,
                  rgba: string, byte_len: int) {
    aether_ui_canvas_draw_image_impl(cid, x, y, iw, ih, rgba, byte_len)
}

// canvas_draw_image_scaled — blit an iw×ih RGBA frame scaled to a dw×dh dest
// rect at (x,y). AeVG live raster regions use this to fit a frame's pixel
// resolution to the region's canvas-px extent.
canvas_draw_image_scaled(cid: int, x: float, y: float, dw: float, dh: float,
                  iw: int, ih: int, rgba: string, byte_len: int) {
    aether_ui_canvas_draw_image_scaled_impl(cid, x, y, dw, dh, iw, ih, rgba, byte_len)
}

// Paint the current path with a linear gradient from (x1,y1) to
// (x2,y2). `offsets` is a floatarr of n_stops stop positions (0..1);
// `rgba` is a floatarr of n_stops*4 colour components (0..1, RGBA).
// line_width = 0 fills the path; > 0 strokes it at that width.
// extend = SVG spreadMethod: 0=pad, 1=reflect, 2=repeat.
canvas_fill_linear_gradient(cid: int, x1: float, y1: float, x2: float, y2: float,
                            n_stops: int, offsets: ptr, rgba: ptr, line_width: float, extend: int) {
    aether_ui_canvas_fill_linear_gradient_impl(cid, x1, y1, x2, y2, n_stops, offsets, rgba, line_width, extend)
}

// Paint the current path with a radial gradient: center (cx,cy),
// radius, focal point (fx,fy). Stops as for the linear variant.
// line_width = 0 fills; > 0 strokes. extend = SVG spreadMethod.
canvas_fill_radial_gradient(cid: int, cx: float, cy: float, radius: float,
                            fx: float, fy: float,
                            n_stops: int, offsets: ptr, rgba: ptr, line_width: float, extend: int) {
    aether_ui_canvas_fill_radial_gradient_impl(cid, cx, cy, radius, fx, fy, n_stops, offsets, rgba, line_width, extend)
}

canvas_clear(cid: int) {
    aether_ui_canvas_clear_impl(cid)
}

canvas_redraw(cid: int) {
    aether_ui_canvas_redraw_impl(cid)
}

// canvas_write_png — render the canvas command buffer to a PNG file off-
// screen (works headless — no window). Returns 1 on success, 0 on failure.
// The self-snapshot primitive: lets tests / the parity harness capture what
// a canvas drew without a live display. Same pixels as on-screen.
canvas_write_png(cid: int, path: string, width: int, height: int) -> int {
    return aether_ui_canvas_write_png_impl(cid, path, width, height)
}

// --- Event handlers ---

on_hover(handle: int, handler: fn) -> int {
    boxed = box_closure(handler)
    aether_ui_on_hover_impl(handle, boxed)
    return handle
}

// edge(side, size, cb) -> (zone, content) — a self-positioning container:
// a thin, always-present detection zone pinned to `side` of a wrapper it
// creates internally, plus a `content` area on the other side for the rest
// of your UI. Fires cb(1) on pointer-enter / cb(0) on pointer-leave. No
// bundled show/hide policy: the caller's cb decides what "entered" means
// (reveal something, arm a debounce, whatever).
//
// Build your own content into the returned `content` handle with explicit-
// parent calls (e.g. text(content, "…"), vstack(content, 10) { … }) — NOT
// by nesting a trailing block on the edge() call itself, since cb already
// occupies that position. Tint the zone with the existing
// style_bg_color(zone, r,g,b,a) — no separate color parameter needed.
//
// v1 built the zone as a plain in-flow sibling and left it to the CALLER to
// place it first-or-last within their own hstack/vstack for correct
// positioning. That was the wrong contract: "left" and "right" (and "top"
// and "bottom") ran IDENTICAL code, so the `side` string didn't actually
// control which edge it landed on — only sibling order did, which edge()
// had no way to see or control. Confirmed the hard way: swapping "left" for
// "right" in a call site that didn't ALSO reorder its siblings kept
// rendering on the left, and "top" (built as a fixed-height row inside an
// hstack meant for "left") rendered vertically centered instead of at the
// true top. Building both the zone AND the content area here, in whichever
// order `side` dictates, means edge() controls that order directly instead
// of hoping the caller's surrounding code matches — `side` alone now fully
// determines position.
//
// Deliberately built on plain on_hover, not canvas_on_hover: the zone never
// moves, resizes, or gets hidden after creation, so on_hover's one-time
// tracking-rect capture (its only documented weakness — see its note
// elsewhere in this file) never goes stale here, and real enter/exit events
// don't have canvas_on_hover's "held still but still inside" false-leave
// risk. Also deliberately in-flow, not overlay() content: overlay()'s
// anchor system is a 9-point grid with no "stretch to fill the cross axis"
// option, so a floating overlay can't become a true full-height edge strip
// anyway — and in-flow content attaches synchronously, with none of
// overlay()'s "called before the window existed" retry-timer need.
//
// fill_height/fill_width alone don't stretch an EMPTY container — they only
// lower its content-hugging priority (stop resisting growth), which does
// nothing without something else creating the pull. A spacer() child is
// that pull (confirmed by running this: without it, the zone measured 24x0
// — width honored, height collapsed to nothing). `content` isn't empty (the
// caller fills it with real widgets), so it doesn't need the same trick.
edge(_ctx: ptr, side: string, size: int, cb: fn) -> (int, int) {
    wrapper = 0
    zone = 0
    content = 0
    if string.equals(side, "left") == 1 {
        wrapper = hstack(_ctx, 0)
        zone = vstack(wrapper, 0)
        width(zone, size)
        fill_height(zone)
        spacer(zone)
        content = vstack(wrapper, 0)
        fill_width(content)
    } else if string.equals(side, "right") == 1 {
        wrapper = hstack(_ctx, 0)
        content = vstack(wrapper, 0)
        fill_width(content)
        zone = vstack(wrapper, 0)
        width(zone, size)
        fill_height(zone)
        spacer(zone)
    } else if string.equals(side, "top") == 1 {
        // zone is built as a vstack, not an hstack, even though it's a
        // horizontal strip: aether_ui_hstack_create hard-codes a low (200)
        // VERTICAL content-hugging priority (deliberately, for grid-row use
        // elsewhere), which fights the explicit height() constraint below
        // and splits the space 50/50 with content instead — confirmed by
        // running this: zone measured 138 tall instead of the declared 24.
        // zone has no children of its own, so its container's internal
        // orientation is irrelevant; vstack just doesn't carry that default.
        wrapper = vstack(_ctx, 0)
        zone = vstack(wrapper, 0)
        height(zone, size)
        fill_width(zone)
        content = vstack(wrapper, 0)
        fill_height(content)
    } else {
        wrapper = vstack(_ctx, 0)
        content = vstack(wrapper, 0)
        fill_height(content)
        zone = vstack(wrapper, 0)
        height(zone, size)
        fill_width(zone)
    }
    on_hover(zone, cb)
    return zone, content
}

on_double_click(handle: int, handler: fn) -> int {
    boxed = box_closure(handler)
    aether_ui_on_double_click_impl(handle, boxed)
    return handle
}

on_click(handle: int, handler: fn) -> int {
    boxed = box_closure(handler)
    aether_ui_on_click_impl(handle, boxed)
    return handle
}

// --- Widget manipulation ---

remove_child(parent_handle: int, child_handle: int) {
    aether_ui_remove_child_impl(parent_handle, child_handle)
}

clear_children(handle: int) {
    aether_ui_clear_children_impl(handle)
}

// --- AetherUIDriver ---

// Enable the AetherUIDriver server. Injects an "Under Remote Control"
// banner into the root widget and starts an HTTP server on the given port.
// The banner cannot be removed or hidden via the test API.
// enable_test_server — in-block form: arms the AetherUIDriver test
// server against the ambient surface root (_ctx). Inside a surface
// block you just write `enable_test_server(9222)` — no named handle.
// Outside a block (_ctx == 0) it's a no-op; use
// enable_test_server_root for an explicit root.
enable_test_server(_ctx: ptr, port: int) {
    if _ctx != 0 {
        aether_ui_enable_test_server_ctx(port, _ctx)
    }
}

// enable_test_server_root — explicit-root form (pre-built trees).
enable_test_server_root(port: int, root_handle: int) {
    aether_ui_enable_test_server_impl(port, root_handle)
}

// Mark a widget as sealed — the test server will refuse to interact with it
// (returns 403 Forbidden). Use this to protect sensitive widgets from
// automation (e.g. a "Delete Account" button during test runs).
seal_widget(handle: int) {
    aether_ui_seal_widget_impl(handle)
}

// Seal an entire subtree — the container and all its descendants become
// non-automatable. Like a sandboxed iFrame in the DOM: the test driver
// cannot see into or interact with anything inside the containment zone.
seal_subtree(handle: int) {
    aether_ui_seal_subtree_impl(handle)
}

// --- Menus ---

// Create a top-level menu bar (to attach to an app window).
menu_bar() {
    return aether_ui_menu_bar_create()
}

// Create a submenu with the given label. Add items with menu_item,
// then attach it to a bar with menu_bar_add.
menu(label: string) {
    return aether_ui_menu_create(label)
}

// Add a selectable item to a menu.
menu_item(menu_handle: int, label: string, on_press: fn) {
    boxed = box_closure(on_press)
    aether_ui_menu_add_item(menu_handle, label, boxed)
}

// menu_item_accel(menu, label, accel, cb): a menu item that ALSO binds its
// accelerator — one call adds the item (with the accel shown after the label,
// e.g. "Save  Ctrl+S") and registers shortcut(accel, cb), so the same action
// fires from the menu OR the keystroke with no separate wiring.
//   menu_item_accel(file, "Save", "Ctrl+S") callback { save() }
menu_item_accel(menu_handle: int, label: string, accel: string, on_press: fn) {
    shown = string.concat(label, string.concat("  ", accel))
    boxed = box_closure(on_press)
    aether_ui_menu_add_item(menu_handle, shown, boxed)
    aether_ui_shortcut_impl(accel, boxed)
}

// Add a horizontal separator between menu items.
menu_separator(menu_handle: int) {
    aether_ui_menu_add_separator(menu_handle)
}

// Attach a submenu to a menu bar.
menu_bar_add(bar_handle: int, menu_handle: int) {
    aether_ui_menu_bar_add_menu(bar_handle, menu_handle)
}

// Attach a menu bar to an app window. Call before app_run.
attach_menu_bar(app_handle: int, bar_handle: int) {
    aether_ui_menu_bar_attach(app_handle, bar_handle)
}

// attach_menu_bar_to_window(win_handle, bar_handle) — a per-window menu bar.
// win_handle is the DRIVER window handle (1 = primary, 2.. = extras from
// window_create). Each window can carry its OWN bar (GTK4: a GtkPopoverMenuBar
// in the window's content; win32: SetMenu on that HWND). macOS's menu bar is
// app-global (the OS menu bar), so there it's the active window's menu — a
// documented platform difference.
attach_menu_bar_to_window(win_handle: int, bar_handle: int) {
    aether_ui_menu_bar_attach_window(win_handle, bar_handle)
}

// Pop up a context menu at the cursor position, anchored to a widget
// (used to determine the owner window for keyboard focus).
menu_popup(menu_handle: int, anchor_widget: int) {
    aether_ui_menu_popup(menu_handle, anchor_widget)
}

// --- Grid layout ---

// Top-level grid (no _ctx parent — for use outside trailing blocks).
root_grid(cols: int, row_spacing: int, col_spacing: int) {
    return aether_ui_grid_create(cols, row_spacing, col_spacing)
}

// Grid container as a child of another widget (trailing-block).
grid(_ctx: ptr, cols: int, row_spacing: int, col_spacing: int) {
    handle = aether_ui_grid_create(cols, row_spacing, col_spacing)
    if _ctx != 0 {
        aether_ui_widget_add_child_ctx(_ctx, handle)
    }
    return handle
}

// Place a previously-created widget into a grid cell. row/col are
// 0-indexed; row_span and col_span are 1-based (1 = fill one cell).
grid_place(grid_handle: int, child_handle: int,
           row: int, col: int, row_span: int, col_span: int) {
    aether_ui_grid_place(grid_handle, child_handle, row, col, row_span, col_span)
}

// --- System tray ---
//
// tray_icon("name") callback { ... } registers an OS status-area
// icon. Right-click conventionally opens the menu set via
// tray_set_menu(); left-click fires the callback passed here.
// On macOS the menu binds to left-click instead (platform
// convention) — the DSL surface stays the same.
tray_icon(name: string, on_left_click: fn) {
    boxed = box_closure(on_left_click)
    return aether_ui_tray_create_impl(name, boxed)
}

// Tray without a left-click handler — for menu-only tray apps where
// every interaction goes through the popup menu.
tray_icon_plain(name: string) {
    return aether_ui_tray_create_impl(name, 0)
}

// The tray setters return the tray_id so they chain via UFCS:
//   tray.tray_set_tooltip("…").tray_set_menu(m).tray_seal()
tray_set_tooltip(tray_id: int, text: string) -> int {
    aether_ui_tray_set_tooltip_impl(tray_id, text)
    return tray_id
}

tray_set_menu(tray_id: int, menu_handle: int) -> int {
    aether_ui_tray_set_menu_impl(tray_id, menu_handle)
    return tray_id
}

// Reactive icon swap. state_handle is a ui_state cell holding 0/1/2
// (clean / busy / conflict). When the state changes, the tray icon
// updates to the matching path.
tray_set_icon_for_state(tray_id: int, state_handle: int,
                        icon_clean: string, icon_busy: string,
                        icon_alert: string) -> int {
    aether_ui_tray_set_icon_for_state_impl(tray_id, state_handle,
                                           icon_clean, icon_busy, icon_alert)
    return tray_id
}

// macOS template-mode toggle. 1 = template (mono adaptive light/dark);
// 0 = full-colour. No-op on Linux/Win.
tray_set_icon_template(tray_id: int, is_template: int) -> int {
    aether_ui_tray_set_icon_template_impl(tray_id, is_template)
    return tray_id
}

// Protect a tray from the AetherUIDriver test API (returns 403).
tray_seal(tray_id: int) -> int {
    aether_ui_tray_seal_impl(tray_id)
    return tray_id
}

// app_run_headless — keep the main loop alive for tray-only apps
// (no root widget). Honours AETHER_UI_HEADLESS for CI.
app_run_headless() {
    aether_ui_app_run_headless_impl()
}

// --- Desktop notifications ---

// Fire-and-forget notification.
notify(title: string, body: string) {
    return aether_ui_notify_impl(title, body)
}

// Notification with optional icon, replace-by-tag, and click callback.
// icon_path and tag may be empty strings to skip.
notify_full(title: string, body: string, icon_path: string, tag: string,
            on_click: fn) {
    boxed = box_closure(on_click)
    return aether_ui_notify_full_impl(title, body, icon_path, tag, boxed)
}

// macOS-only permission prompt. Returns 1 on platforms that don't
// require it (Linux, Win). Apps that want to prompt at startup call
// this; otherwise the first notify_full() is best-effort.
notify_request_permission() {
    return aether_ui_notify_request_permission_impl()
}
