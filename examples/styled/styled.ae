// Aether UI styled example — layout containers and styling.
//
// Build and run:
//   ./build.sh example_styled.ae build/perry_styled

import ui

extern println(s: string)

main() {
    ui.window("Styled Demo", 500, 600) {
    root = ui.vstack(0) {
        // Header with gradient background
        header = ui.hstack(10) {
            title = ui.text("Aether UI Styled Demo")
            // UFCS chain — x.f(a) desugars to f(x, a); each style_* returns
            // its handle so they compose left-to-right.
            title.style_font_size(20).style_font_bold().style_text_color(1.0, 1.0, 1.0)
            ui.spacer()
        }
        header.style_bg_gradient(0.2, 0.4, 0.8, 0.1, 0.2, 0.6, 0).edge_insets(16, 16, 16, 16)

        // Form with sections
        ui.form() {
            ui.section("Personal Info") {
                ui.hstack(8) {
                    ui.text("Name:")
                    ui.textfield("Enter name") callback |val: string| {
                        println("Name: ${val}")
                    }
                }
                ui.hstack(8) {
                    ui.text("Email:")
                    ui.textfield("you@example.com") callback |val: string| {
                        println("Email: ${val}")
                    }
                }
            }

            ui.section("Preferences") {
                ui.toggle("Dark mode") callback |active: int| {
                    println("Dark mode: ${active}")
                }
                ui.toggle("Notifications") callback |active: int| {
                    println("Notifications: ${active}")
                }
            }
        }

        ui.divider()

        // ZStack demo — overlapping elements
        overlay = ui.zstack() {
            bg = ui.vstack(0) {
                ui.spacer()
            }
            bg.style_bg_color(0.9, 0.95, 1.0, 1.0).height(80)

            label = ui.text("Overlaid text on colored background")
            ui.margin_of(label, 20, 20, 20, 20)
        }
        ui.height(overlay, 80)

        ui.spacer()

        // Styled buttons at the bottom
        ui.hstack(8) {
            submit = ui.btn("Submit") callback {
                println("Submitted!")
            }
            submit.style_bg_color(0.2, 0.6, 0.3, 1.0).style_corner_radius(8)
                  .style_tooltip("Click to submit the form")

            cancel = ui.btn("Cancel") callback {
                println("Cancelled")
            }
            cancel.style_corner_radius(8).style_tooltip("Click to cancel")

            ui.spacer()

            disabled_btn = ui.btn("Disabled") callback {
                println("Should not fire")
            }
            ui.style_enabled(disabled_btn, 0)
        }
    }

    ui.margin_of(root, 0, 12, 12, 12)
    }
}
