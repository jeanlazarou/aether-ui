import build
import aether
import aether (source, output, no_closure_regen)
import aetherui (ui_backend)
main() {
    b = build.start()
    root = build._get(b, "root")
    aether.program(b) {
        source("shortcut_demo.ae")
        output("shortcut_demo")
        no_closure_regen()
        ui_backend(root)
    }
    return 0
}
