// Regression test for fs.chmod — issue #391 + #392.
// fs.chmod returns (1, KIND_OK, "") on success or (0, KIND_*, msg)
// on failure. POSIX chmod(2) semantics on Linux/macOS/BSD; on
// Windows only the user-write bit (0o200) is honoured.
//
// What this test guards:
//   1. chmod 0o600 on a regular file → succeeds, mode bits land
//   2. chmod 0o400 (read-only) → succeeds, bits land
//   3. chmod with high bits set (0o7777) → masked to 07777
//   4. chmod on missing path → KIND_NOT_FOUND
//   5. chmod with mode bit cleared (0o000) — file becomes unreadable
//      to owner, but chmod itself succeeds

import std.fs
import std.file

extern exit(code: int)

main() {
    println("=== fs.chmod regression ===")

    tmpdir = "/tmp/aether_fs_chmod_test"
    fs.delete_dir(tmpdir)
    fs.create_dir(tmpdir)

    src1 = "${tmpdir}/probe.txt"
    e1 = fs.write(src1, "x")
    if e1 != "" { println("setup FAIL: ${e1}"); exit(1) }

    // --- Case 1: chmod 0o600 (rw-------) ---
    ok1, kind1, msg1 = fs.chmod(src1, 0o600)
    if kind1 != fs.KIND_OK {
        println("FAIL 1: kind=${kind1} msg=${msg1}, expected KIND_OK"); exit(1)
    }
    if ok1 != 1 {
        println("FAIL 1: ok=${ok1}, expected 1"); exit(1)
    }
    println("  PASS 1: chmod 0o600 succeeds")

    // --- Case 2: chmod 0o400 (read-only) ---
    ok2, kind2, msg2 = fs.chmod(src1, 0o400)
    if kind2 != fs.KIND_OK {
        println("FAIL 2: kind=${kind2} msg=${msg2}, expected KIND_OK"); exit(1)
    }
    println("  PASS 2: chmod 0o400 succeeds")

    // --- Case 3: high bits ignored (only 07777 honoured) ---
    // 0o17777 has set-uid (0o4000) + sgid + sticky + 0o7777 — the
    // 0o10000 high bit is stripped by the (mode & 07777) mask in C.
    ok3, kind3, msg3 = fs.chmod(src1, 0o17777)
    if kind3 != fs.KIND_OK {
        println("FAIL 3: kind=${kind3} msg=${msg3}, expected KIND_OK"); exit(1)
    }
    println("  PASS 3: high bits masked, 0o17777 accepted")

    // Restore writable mode for cleanup.
    ok_restore, _kr, _mr = fs.chmod(src1, 0o600)
    if ok_restore != 1 {
        println("setup FAIL: cannot restore mode for cleanup"); exit(1)
    }

    // --- Case 4: missing path → KIND_NOT_FOUND ---
    ok4, kind4, msg4 = fs.chmod("${tmpdir}/no_such_file_xyz", 0o644)
    if kind4 != fs.KIND_NOT_FOUND {
        println("FAIL 4: kind=${kind4} msg=${msg4}, expected KIND_NOT_FOUND"); exit(1)
    }
    println("  PASS 4: missing path → KIND_NOT_FOUND")

    // --- Case 5: chmod 0o000 on a file owned by us — chmod itself
    //              succeeds; subsequent file.read may or may not fail
    //              depending on the platform's check-effective-uid
    //              shortcut, but the chmod call must return KIND_OK. ---
    ok5, kind5, msg5 = fs.chmod(src1, 0o000)
    if kind5 != fs.KIND_OK {
        println("FAIL 5: kind=${kind5} msg=${msg5}, expected KIND_OK"); exit(1)
    }
    println("  PASS 5: chmod 0o000 itself succeeds")

    // Restore so we can delete.
    ok_restore2, _kr2, _mr2 = fs.chmod(src1, 0o600)
    if ok_restore2 != 1 {
        println("setup FAIL: cannot restore mode after 0o000 case"); exit(1)
    }

    fs.delete(src1)
    fs.delete_dir(tmpdir)

    println("=== All cases passed ===")
}
