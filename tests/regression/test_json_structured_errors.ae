// Regression test for issue #392 — std.json structured-error pilot
// expansion. `parse_strict` returns the canonical (value, kind,
// message) tuple matching std.fs's pilot shape; programmatic
// accessors `last_error_kind` / `last_error_line` / `last_error_col`
// expose the failure context without parsing the human message.
//
// What this test guards:
//   1. Happy path: well-formed JSON → (value, KIND_OK, "")
//   2. Syntax error: malformed JSON → (null, KIND_PARSE_ERROR, "<msg> at L:C")
//   3. Programmatic accessors return the same line/col as embedded
//      in the message
//   4. Cross-call isolation: a successful parse after a failed parse
//      doesn't leak the previous error kind/line/col
//   5. Multiple distinct syntax-error positions all report distinct
//      (line, col) values
//   6. KIND_OK is exactly 0 (callers rely on `kind != 0` as the
//      canonical error check; matches the std.fs pilot value)

import std.json
import std.string

extern exit(code: int)

main() {
    println("=== std.json structured-error pilot ===")

    // Case 1: happy path
    v, kind, msg = json.parse_strict("{\"x\": 42, \"y\": [1, 2, 3]}")
    if kind != json.KIND_OK {
        println("FAIL 1: kind=${kind} msg=${msg}, expected KIND_OK")
        exit(1)
    }
    if v == null {
        println("FAIL 1: returned null on success")
        exit(1)
    }
    json.free(v)
    println("  PASS 1: happy path → KIND_OK")

    // Case 2: syntax error
    v2, kind2, msg2 = json.parse_strict("{not_json}")
    if kind2 != json.KIND_PARSE_ERROR {
        println("FAIL 2: kind=${kind2}, expected KIND_PARSE_ERROR")
        exit(1)
    }
    if v2 != null {
        println("FAIL 2: returned non-null on failure")
        exit(1)
    }
    if string.length(msg2) == 0 {
        println("FAIL 2: empty error message on failure")
        exit(1)
    }
    println("  PASS 2: syntax error → KIND_PARSE_ERROR")

    // Case 3: accessors agree with embedded line:col
    line = json.last_error_line()
    col  = json.last_error_col()
    if line == 0 {
        println("FAIL 3: line accessor returned 0")
        exit(1)
    }
    if col == 0 {
        println("FAIL 3: col accessor returned 0")
        exit(1)
    }
    println("  PASS 3: line/col accessors return positive values (line=${line}, col=${col})")

    // Case 4: cross-call isolation
    v_ok, kind_ok, _ = json.parse_strict("[1, 2, 3]")
    if kind_ok != json.KIND_OK {
        println("FAIL 4: success-after-failure didn't reset kind")
        exit(1)
    }
    json.free(v_ok)
    println("  PASS 4: success after failure → kind reset")

    // Case 5: distinct positions for distinct errors
    v_a, _, _ = json.parse_strict("{\"x\":")  // unterminated, line 1
    line_a = json.last_error_line()
    col_a  = json.last_error_col()
    if v_a != null { json.free(v_a) }

    v_b, _, _ = json.parse_strict("{\n\"x\": 1,\n\"y\":\n}")  // unexpected '}' on line 4
    line_b = json.last_error_line()
    col_b  = json.last_error_col()
    if v_b != null { json.free(v_b) }

    if line_a == line_b && col_a == col_b {
        println("FAIL 5: distinct errors reported same position (${line_a}:${col_a})")
        exit(1)
    }
    println("  PASS 5: distinct positions for distinct errors (a=${line_a}:${col_a}, b=${line_b}:${col_b})")

    // Case 6: KIND_OK == 0 contract
    if json.KIND_OK != 0 {
        println("FAIL 6: KIND_OK=${json.KIND_OK}, expected 0")
        exit(1)
    }
    if json.KIND_PARSE_ERROR == 0 {
        println("FAIL 6: KIND_PARSE_ERROR == 0 (must be non-zero)")
        exit(1)
    }
    println("  PASS 6: KIND_OK == 0; KIND_PARSE_ERROR != 0")

    println("=== All cases passed ===")
}
