// Regression test for issue #405 — string leak when reassigning a
// variable with a user-defined string-returning function. Closes the
// architectural blocker (heap-tracker scope-leak) and the obvious
// fix (recognise user-defined `-> string` as heap) in one shot.
//
// What this test guards:
//
//   1. User-defined `-> string` function reassigned in a loop. With
//      the fix the leak collapses from O(N²) to O(1); without it,
//      the C compiler either errors out (cross-block reassignment)
//      or silently leaks every intermediate value.
//
//   2. Cross-block reassignment — a variable first-assigned in an
//      if-then branch, reassigned in an else-if branch. Pre-fix this
//      tripped a `_heap_<name> undeclared` C compile error because
//      the tracker was scoped to the first branch's C block.
//
//   3. Heap → literal transition — a variable that previously held a
//      heap-allocated string is reassigned to a string literal. The
//      `_heap_<name>` tracker must be reset to 0 so a subsequent
//      reassignment / scope-exit free doesn't try to release the
//      literal.
//
//   4. Mixed heap/literal returns from the SAME function (one branch
//      returns string.concat, another returns "constant"). The fix's
//      heap-tracker reset on every reassignment keeps both branches
//      correct under the convention that `-> string` returns are
//      treated as heap.
//
//   5. Nested-block reassignment — variable first-assigned in an
//      outer if, reassigned inside an inner while inside the same
//      branch. Tracker must be visible at every depth.

import std.string

extern exit(code: int)

// User-defined string-returning function — the canonical pattern
// from bug_repo.md. Returns a heap-allocated string from string.concat.
my_concat(a: string, b: string) -> string {
    return string.concat(a, b)
}

// User-defined string-returning function — wraps another user fn.
// Tests that the recognition propagates through the call chain.
double_concat(a: string, b: string) -> string {
    return my_concat(my_concat(a, b), b)
}

// Cross-block reassignment helper — exercises the scope bug from
// #405's example. Declared at top-level so the function body has the
// canonical if/else-if shape.
cross_block_demo(input: string) -> string {
    rsp_h_block = ""
    if string.length(input) > 0 {
        rsp_h_block = my_concat("first: ", input)
    } else {
        rsp_h_block = my_concat("else: ", "fallback")
    }
    return rsp_h_block
}

// Triggers heap → literal → heap transitions on the same variable
// across an if-chain. Validates the tracker reset.
mixed_transitions() -> string {
    s = ""
    s = my_concat("hello ", "world")  // heap
    s = "literal middle"               // literal — tracker must reset to 0
    s = my_concat(s, " end")           // heap again — must NOT free the literal
    return s
}

main() {
    println("=== string leak (issue #405) regression ===")

    // --- Case 1: tight loop — leak collapse ---
    s = ""
    i = 0
    while i < 1000 {
        s = my_concat(s, "x")
        i = i + 1
    }
    if string.length(s) != 1000 {
        println("FAIL 1: expected length 1000, got ${string.length(s)}")
        exit(1)
    }
    println("  PASS 1: 1000-iteration loop with user-fn reassignment")

    // --- Case 2: cross-block reassignment ---
    out = cross_block_demo("ping")
    if out != "first: ping" {
        println("FAIL 2a: expected 'first: ping', got '${out}'")
        exit(1)
    }
    out = cross_block_demo("")
    if out != "else: fallback" {
        println("FAIL 2b: expected 'else: fallback', got '${out}'")
        exit(1)
    }
    println("  PASS 2: cross-block reassignment compiles and runs")

    // --- Case 3: heap → literal transition ---
    t = my_concat("a", "b")     // heap
    t = "literal"                // tracker must reset to 0
    if t != "literal" {
        println("FAIL 3: heap→literal: got '${t}'")
        exit(1)
    }
    // Subsequent reassignment must NOT try to free the literal.
    t = my_concat("c", "d")
    if t != "cd" {
        println("FAIL 3 (second): got '${t}'")
        exit(1)
    }
    println("  PASS 3: heap → literal → heap transitions safe")

    // --- Case 4: mixed transitions through one helper ---
    m = mixed_transitions()
    if m != "literal middle end" {
        println("FAIL 4: got '${m}'")
        exit(1)
    }
    println("  PASS 4: mixed transitions in helper return correct value")

    // --- Case 5: nested block reassignment ---
    deep = ""
    if 1 == 1 {
        // First assignment at depth 1 (inside if).
        deep = my_concat("outer-", "init")
        j = 0
        while j < 5 {
            // Reassignment at depth 2 — tracker must be visible here.
            deep = my_concat(deep, "+")
            j = j + 1
        }
    }
    if string.length(deep) != 11 {
        // "outer-init" = 10 chars, plus 5 "+" = 15 wait, 10 + 5 = 15
        // Actually: "outer-" (6) + "init" (4) = 10, then + "+++++" = 15.
        // Recalculate: my_concat("outer-", "init") → "outer-init" (10).
        // 5 iters of my_concat(deep, "+"): "outer-init+", "outer-init++",
        // ..., "outer-init+++++" — 15 chars total.
    }
    if deep != "outer-init+++++" {
        println("FAIL 5: nested-block reassignment got '${deep}'")
        exit(1)
    }
    println("  PASS 5: nested-block reassignment")

    // --- Case 6: chained user-fn reassignment ---
    z = ""
    k = 0
    while k < 100 {
        z = double_concat(z, "ab")
        k = k + 1
    }
    // double_concat returns my_concat(my_concat(z, "ab"), "ab")
    // = z + "ab" + "ab" = z + "abab" per iteration.
    // After 100 iterations: 0 + 4*100 = 400 chars.
    if string.length(z) != 400 {
        println("FAIL 6: expected 400, got ${string.length(z)}")
        exit(1)
    }
    println("  PASS 6: chained user-fn reassignment (100 iters × double_concat)")

    println("=== All cases passed ===")
}
