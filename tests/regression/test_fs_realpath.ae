// Regression test for fs.realpath — issue #391 + #392.
// fs.realpath returns (resolved, KIND_OK, "") on success or
// ("", KIND_*, msg) on failure.
//
// What this test guards:
//   1. Already-canonical absolute path → resolves to itself
//   2. Relative-style canonicalisation (./ and ../ folded out)
//   3. Symlink follow → resolved path is the target's path, not the
//      symlink's
//   4. Missing path → KIND_NOT_FOUND
//   5. Path through a non-directory component → KIND_NOT_DIR

import std.fs
import std.string

extern exit(code: int)

main() {
    println("=== fs.realpath regression ===")

    tmpdir = "/tmp/aether_fs_realpath_test"
    fs.delete_dir(tmpdir)
    fs.create_dir(tmpdir)
    fs.write("${tmpdir}/probe", "x")

    // --- Case 1: already-canonical absolute path ---
    resolved1, kind1, msg1 = fs.realpath("${tmpdir}/probe")
    if kind1 != fs.KIND_OK {
        println("FAIL 1: kind=${kind1} msg=${msg1}, expected KIND_OK"); exit(1)
    }
    // realpath may resolve /tmp to /private/tmp on macOS; accept any
    // resolved form that ends with /aether_fs_realpath_test/probe.
    suffix = "/aether_fs_realpath_test/probe"
    end_at = string.length(resolved1) - string.length(suffix)
    if end_at < 0 {
        println("FAIL 1: resolved=${resolved1} too short for suffix=${suffix}"); exit(1)
    }
    tail1 = string.substring(resolved1, end_at, string.length(resolved1))
    if tail1 != suffix {
        println("FAIL 1: resolved=${resolved1} does not end with ${suffix}"); exit(1)
    }
    println("  PASS 1: canonical path resolves")

    // --- Case 2: ./ and ../ folded out ---
    twisted = "${tmpdir}/./../aether_fs_realpath_test/probe"
    resolved2, kind2, msg2 = fs.realpath(twisted)
    if kind2 != fs.KIND_OK {
        println("FAIL 2: kind=${kind2} msg=${msg2}, expected KIND_OK"); exit(1)
    }
    if resolved2 != resolved1 {
        println("FAIL 2: twisted resolved=${resolved2} != canonical=${resolved1}"); exit(1)
    }
    println("  PASS 2: ./.. folded out")

    // --- Case 3: symlink follow ---
    sym3 = "${tmpdir}/link_to_probe"
    sym_err = fs.symlink("${tmpdir}/probe", sym3)
    if sym_err != "" {
        println("  SKIP 3: symlink unavailable (${sym_err})")
    } else {
        resolved3, kind3, msg3 = fs.realpath(sym3)
        if kind3 != fs.KIND_OK {
            println("FAIL 3: kind=${kind3} msg=${msg3}, expected KIND_OK"); exit(1)
        }
        // The resolved path should NOT include "link_to_probe".
        // Use a poor-man's contains check via substring scan.
        contains_link = 0
        max_idx = string.length(resolved3) - 13  // length of "link_to_probe"
        if max_idx > 0 {
            i = 0
            while i <= max_idx {
                if string.substring(resolved3, i, i + 13) == "link_to_probe" {
                    contains_link = 1
                    i = max_idx + 1
                } else {
                    i = i + 1
                }
            }
        }
        if contains_link != 0 {
            println("FAIL 3: resolved=${resolved3} still contains 'link_to_probe' — symlink not followed"); exit(1)
        }
        println("  PASS 3: symlink followed to target")
    }

    // --- Case 4: missing path ---
    resolved4, kind4, msg4 = fs.realpath("${tmpdir}/does_not_exist_xyz")
    if kind4 != fs.KIND_NOT_FOUND {
        println("FAIL 4: kind=${kind4} msg=${msg4}, expected KIND_NOT_FOUND"); exit(1)
    }
    if resolved4 != "" {
        println("FAIL 4: resolved=${resolved4} on failure, expected empty string"); exit(1)
    }
    println("  PASS 4: missing path → KIND_NOT_FOUND")

    // --- Case 5: path through a non-directory ---
    not_dir = "${tmpdir}/probe/inside"  // probe is a regular file
    resolved5, kind5, msg5 = fs.realpath(not_dir)
    if kind5 != fs.KIND_NOT_DIR {
        // Some POSIX implementations report ENOENT for this case
        // instead of ENOTDIR. Accept either as evidence the call
        // correctly failed.
        if kind5 != fs.KIND_NOT_FOUND {
            println("FAIL 5: kind=${kind5} msg=${msg5}, expected KIND_NOT_DIR or KIND_NOT_FOUND"); exit(1)
        }
        println("  PASS 5: non-dir component → KIND_NOT_FOUND (POSIX variant)")
    } else {
        println("  PASS 5: non-dir component → KIND_NOT_DIR")
    }

    // Cleanup
    fs.delete(sym3)
    fs.delete("${tmpdir}/probe")
    fs.delete_dir(tmpdir)

    println("=== All cases passed ===")
}
