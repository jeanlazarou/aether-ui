// Regression test for the contract const-fold optimization
// (companion to #348). When a `requires` / `ensures` predicate is
// provably constant-true at compile time, the codegen elides the
// runtime check entirely — the generated C is byte-for-byte
// identical to a function written without the clause. The user
// keeps the documentation; the binary takes zero overhead.
//
// Const-fold subset supported (matches `try_fold_predicate` in
// compiler/codegen/codegen_stmt.c):
//   - bool literals: `true`, `false`
//   - integer/float literals
//   - comparison ops on constant operands: <, <=, >, >=, ==, !=
//   - logical ops: &&, ||
//   - arithmetic ops: +, -, *, /, %
//   - unary `!` and unary `-`
//
// Anything outside this subset (identifier references, function
// calls, member access, etc.) keeps the runtime check.
//
// What this test guards:
//
//   1. `requires true` — vacuous precondition, call returns
//   2. `ensures true` — vacuous postcondition, call returns
//   3. `requires 1 > 0` — folded comparison, call returns
//   4. `ensures !false` — folded unary, call returns
//   5. `requires 1 + 1 == 2` — folded arithmetic + comparison
//   6. `requires true && (3 > 2)` — folded short-circuit
//   7. Mixed: one folded clause + one runtime clause on the same
//      function — runtime check still fires on a real violation
//   8. The constant-true clause does NOT cause a compile error or
//      any visible difference at the call site

import std.string

extern exit(code: int)

// Case 1: vacuous precondition.
inc1(x: int) -> int
    requires true
{
    return x + 1
}

// Case 2: vacuous postcondition.
inc2(x: int) -> int
    ensures true
{
    return x + 1
}

// Case 3: folded comparison.
inc3(x: int) -> int
    requires 1 > 0
{
    return x + 1
}

// Case 4: folded unary.
inc4(x: int) -> int
    ensures !false
{
    return x + 1
}

// Case 5: folded arithmetic + comparison.
inc5(x: int) -> int
    requires 1 + 1 == 2
{
    return x + 1
}

// Case 6: folded short-circuit.
inc6(x: int) -> int
    requires true && (3 > 2)
    ensures result > x || true
{
    return x + 1
}

// Case 7: mix of folded + runtime clause. Real violation still
// surfaces — folded clause is gone but runtime one remains.
checked(x: int) -> int
    requires true
    requires x >= 0
{
    return x
}

main() {
    println("=== contract const-fold ===")

    if inc1(5) != 6 { println("FAIL 1: inc1");  exit(1) }
    println("  PASS 1: requires true")

    if inc2(5) != 6 { println("FAIL 2: inc2");  exit(1) }
    println("  PASS 2: ensures true")

    if inc3(5) != 6 { println("FAIL 3: inc3");  exit(1) }
    println("  PASS 3: requires 1 > 0")

    if inc4(5) != 6 { println("FAIL 4: inc4");  exit(1) }
    println("  PASS 4: ensures !false")

    if inc5(5) != 6 { println("FAIL 5: inc5");  exit(1) }
    println("  PASS 5: requires 1+1 == 2")

    if inc6(5) != 6 { println("FAIL 6: inc6");  exit(1) }
    println("  PASS 6: requires true && (3 > 2)")

    if checked(0) != 0 { println("FAIL 7: checked(0)"); exit(1) }
    if checked(7) != 7 { println("FAIL 7: checked(7)"); exit(1) }
    println("  PASS 7: mixed folded + runtime")

    println("=== ALL 7 PASS ===")
}
