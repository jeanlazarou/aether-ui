// Regression test for issue #348 — Eiffel-style `requires` /
// `ensures` runtime contracts.
//
// Surface:
//   add(a: int, b: int) -> int
//       requires a >= 0
//       requires b >= 0
//       ensures result >= a
//       ensures result >= b
//   {
//       return a + b
//   }
//
// Lowering (codegen):
//   `requires <expr>` → `if (!(<expr>)) aether_panic("precondition violation: <text> in <fn>");`
//                       at function entry, after parameters declared.
//   `ensures <expr>`  → emitted before each `return <expr>`, wrapped in
//                       a fresh C scope `{ <T> result = <expr>;
//                       <checks>; return result; }` so `result` is
//                       a local in the predicate's scope.
//
// What this test guards (positive cases — the negative cases trip
// `aether_panic` and live in the integration suite where we can
// assert on the panic message):
//
//   1. Single-clause precondition, satisfied → call returns
//   2. Multiple-clause precondition (one `requires` per line), all
//      satisfied → call returns
//   3. Single-clause postcondition with `result` binding, satisfied
//      → call returns the right value
//   4. Multiple postconditions, all satisfied → call returns
//   5. Mixed `requires` + `ensures` on the same function
//   6. Contracts on a function with multiple return paths (early
//      return inside an `if`) — every return site gets the
//      postcondition checks
//   7. Predicate referencing parameters and `result` simultaneously
//   8. Boolean predicate (no comparison operator) — `requires
//      enabled`

import std.string

extern exit(code: int)

// Case 1: single-clause precondition.
inc(x: int) -> int
    requires x >= 0
{
    return x + 1
}

// Case 2: multiple-clause precondition.
clamp(x: int, lo: int, hi: int) -> int
    requires lo <= hi
{
    if x < lo {
        return lo
    }
    if x > hi {
        return hi
    }
    return x
}

// Case 3: single-clause postcondition with `result`.
abs_int(x: int) -> int
    ensures result >= 0
{
    if x < 0 {
        return 0 - x
    }
    return x
}

// Case 4: multiple postconditions.
add(a: int, b: int) -> int
    ensures result >= a
    ensures result >= b
{
    return a + b
}

// Case 5: mixed pre + post.
safe_div(a: int, b: int) -> int
    requires b != 0
    ensures result == a / b
{
    return a / b
}

// Case 6: multiple return sites — checks fire at each.
sign(x: int) -> int
    ensures result >= 0 - 1
    ensures result <= 1
{
    if x > 0 {
        return 1
    }
    if x < 0 {
        return 0 - 1
    }
    return 0
}

// Case 7: predicate referencing both a parameter and `result`.
add_capped(x: int, cap: int) -> int
    requires cap >= x
    ensures result >= x
    ensures result <= cap
{
    return cap
}

// Case 8: boolean-only predicate.
toggle(enabled: bool) -> bool
    requires enabled
    ensures result == false
{
    return false
}

main() {
    println("=== requires / ensures contracts ===")

    // 1. Single-clause precondition satisfied.
    if inc(0) != 1 { println("FAIL 1: inc(0) != 1");      exit(1) }
    if inc(99) != 100 { println("FAIL 1: inc(99) != 100"); exit(1) }
    println("  PASS 1: single precondition")

    // 2. Multiple-clause precondition.
    if clamp(5, 0, 10) != 5  { println("FAIL 2a"); exit(1) }
    if clamp(-1, 0, 10) != 0 { println("FAIL 2b"); exit(1) }
    if clamp(99, 0, 10) != 10 { println("FAIL 2c"); exit(1) }
    println("  PASS 2: multiple preconditions")

    // 3. Postcondition with `result`.
    if abs_int(5) != 5 { println("FAIL 3a"); exit(1) }
    if abs_int(0) != 0 { println("FAIL 3b"); exit(1) }
    if abs_int(0 - 7) != 7 { println("FAIL 3c"); exit(1) }
    println("  PASS 3: postcondition with `result`")

    // 4. Multiple postconditions.
    if add(3, 4) != 7 { println("FAIL 4a"); exit(1) }
    if add(0, 0) != 0 { println("FAIL 4b"); exit(1) }
    println("  PASS 4: multiple postconditions")

    // 5. Mixed pre + post.
    if safe_div(10, 2) != 5  { println("FAIL 5a"); exit(1) }
    if safe_div(0, 7) != 0   { println("FAIL 5b"); exit(1) }
    println("  PASS 5: mixed pre + post")

    // 6. Multiple return sites.
    if sign(5)  != 1     { println("FAIL 6a"); exit(1) }
    if sign(0 - 5) != 0 - 1 { println("FAIL 6b"); exit(1) }
    if sign(0)  != 0     { println("FAIL 6c"); exit(1) }
    println("  PASS 6: multiple return sites")

    // 7. Predicate referencing parameter + result.
    if add_capped(3, 100) != 100 { println("FAIL 7"); exit(1) }
    println("  PASS 7: predicate over param + result")

    // 8. Boolean-only predicate.
    if toggle(true) != false { println("FAIL 8"); exit(1) }
    println("  PASS 8: boolean predicate")

    println("=== All cases passed ===")
}
