// Sanity test for the std.fs KIND_* enum constants. The pilot
// (issue #392) makes the (value, kind, message) tuple a stable
// surface contract, so callers writing
//
//   if kind == fs.KIND_NOT_FOUND { ... }
//
// must keep working across releases. This test guards each KIND_*
// at its committed integer value — additive new kinds may be
// appended (always at fresh integers above the existing range), but
// the values defined here are part of the surface contract and may
// not change.

import std.fs

extern exit(code: int)

assert_eq(name: string, got: int, expected: int) {
    if got != expected {
        println("FAIL: ${name} = ${got}, expected ${expected}")
        exit(1)
    }
}

main() {
    println("=== std.fs KIND_* constants ===")

    assert_eq("KIND_OK",                fs.KIND_OK,                0)
    assert_eq("KIND_NOT_FOUND",         fs.KIND_NOT_FOUND,         1)
    assert_eq("KIND_PERMISSION_DENIED", fs.KIND_PERMISSION_DENIED, 2)
    assert_eq("KIND_EXISTS",            fs.KIND_EXISTS,            3)
    assert_eq("KIND_CROSS_DEVICE",      fs.KIND_CROSS_DEVICE,      4)
    assert_eq("KIND_IO",                fs.KIND_IO,                5)
    assert_eq("KIND_INVALID",           fs.KIND_INVALID,           6)
    assert_eq("KIND_LOOP",              fs.KIND_LOOP,              7)
    assert_eq("KIND_NAME_TOO_LONG",     fs.KIND_NAME_TOO_LONG,     8)
    assert_eq("KIND_NO_SPACE",          fs.KIND_NO_SPACE,          9)
    assert_eq("KIND_IS_DIR",            fs.KIND_IS_DIR,            10)
    assert_eq("KIND_NOT_DIR",           fs.KIND_NOT_DIR,           11)
    assert_eq("KIND_UNAVAILABLE",       fs.KIND_UNAVAILABLE,       99)

    println("  PASS: all 13 KIND_* values match committed contract")
    println("=== All cases passed ===")
}
