// spec_weightclamp_demo.ae — weight min-clamping.
// Two weighted children (weight 1 each) share a row; A has min-width 220.
// Narrow the window so each 1/2 share would be < 220 — A must clamp UP to its
// minimum (220), and B takes the remainder. (Geometry spec: resize first,
// then assert — house rule 6.)
import aeocha
import uidriver
import std.string

width_of(label: string) -> int {
    id = uidriver.widget_id_by_text(label)
    return uidriver.widget_int_field_by_id(id, "w")
}

main() {
    fw = aeocha.init()
    uidriver.wait_server()

    aeocha.describe(fw, "weight min-clamp over AetherUIDriver") {
        aeocha.it("a weighted child is not squeezed below its min-width") callback {
            // Narrow row: 320px total; each 1/2 share (~150) < A's min 220.
            uidriver.resize_window(320, 200)
            // A clamps to its minimum.
            wa = width_of("AAAA")
            aeocha.assert_true(wa >= 220, "A held its min-width (got ${wa}, min 220)")
            // B is the flexible one and takes what's left (> 0, < A).
            wb = width_of("BBBB")
            aeocha.assert_true(wb > 0, "B still gets space (got ${wb})")
            aeocha.assert_true(wb < wa, "B (flexible) is narrower than the clamped A")
        }

        aeocha.it("with room, both weighted children share equally") callback {
            // Wide row: 800px; each 1/2 share (~390) > A's min, so no clamp.
            uidriver.resize_window(800, 200)
            wa = width_of("AAAA")
            wb = width_of("BBBB")
            // Roughly equal (within a small slack for spacing/rounding).
            d = wa - wb
            if d < 0 { d = 0 - d }
            aeocha.assert_true(d <= 20, "equal split when there's room (A=${wa} B=${wb})")
        }
    }
    aeocha.run_summary(fw)
}
