// Builder for the kind-predicate + deep-free safety test. Returns a
// nested map containing scalars, a sub-map, and a sub-list. The C
// host walks it with `aether_value_kind()`, asserts every value's
// kind matches what the script stored, then calls
// `aether_config_free_deep()` and asserts the same predicate now
// reports AETHER_KIND_UNKNOWN on the root (proving the use-after-
// free guard works — the magic was cleared on free).

import std.map
import std.list

build_tree() {
    root = map_new()

    // A scalar string (heap-allocated AetherString or borrowed
    // const char* — either way, NOT a container).
    map_put(root, "name", "alice")

    // A scalar int — stored as (void*)(intptr_t)42, definitely
    // NOT a container; the kind probe must return UNKNOWN.
    map_put(root, "age", 42)

    // A nested map.
    addr = map_new()
    map_put(addr, "city", "berlin")
    map_put(root, "addr", addr)

    // A nested list.
    tags = list.new()
    list.add(tags, "admin")
    list.add(tags, "beta")
    map_put(root, "tags", tags)

    return root
}

main() { println("skipped in lib mode") }
