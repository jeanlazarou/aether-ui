// In-process gateway host — issue #384.
//
// Boots an HTTP server on $1 (port) and mounts $2 (path/to/script.so)
// at prefix "/gateway/". Also registers a static fallback route at
// "/static" so we can prove the gateway short-circuits *only* paths
// that match the prefix.

import std.http
import std.http.script_gateway
import std.os
import std.string

extern http_server_start_raw(server: ptr) -> int
extern exit(code: int)

// Path: /static — used to prove the gateway middleware does NOT
// short-circuit non-matching paths. The script.so handler should
// never run for /static.
handle_static(req: ptr, res: ptr, ud: ptr) {
    http.response_set_status(res, 200)
    http.response_set_header(res, "Content-Type", "text/plain")
    http.response_set_header(res, "X-Handler", "static")
    http.response_set_body(res, "static fallback\n")
}

main() {
    n = aether_args_count()
    if n < 3 {
        println("FAIL: usage: host <port> <so_path>")
        exit(1)
    }
    port_str = aether_args_get(1)
    so_path = aether_args_get(2)
    port, perr = string.to_int(port_str)
    if perr != "" {
        println("FAIL: invalid port '${port_str}': ${perr}")
        exit(1)
    }

    s = http.server_create(port)
    if s == 0 { println("FAIL: server_create"); exit(1) }
    http.server_set_host(s, "127.0.0.1")

    // Static-fallback route. Mounted BEFORE the script-gateway
    // middleware registration is a deliberate test: middleware runs
    // before route dispatch, so the gateway must reject /static
    // (its prefix doesn't match) and the static handler then runs.
    http.server_get(s, "/static", handle_static, 0)

    // Mount script.so at /gateway/* via the in-process gateway.
    ok, kind, msg = script_gateway.mount(s, "/gateway", so_path)
    if kind != script_gateway.KIND_OK {
        println("FAIL: mount kind=${kind} msg=${msg}")
        exit(1)
    }

    println("READY")
    http_server_start_raw(s)
}
