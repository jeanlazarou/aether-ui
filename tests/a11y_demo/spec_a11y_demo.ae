// spec_a11y_demo.ae — drives the accessibility example over the AetherUIDriver.
// Proves the semantics layer (roadmap: Accessibility):
//   * native widgets carry a11y for FREE — a plain button reports role
//     "button" and its label as the accessible name, with nothing set;
//   * a11y_label OVERRIDES the auto name — an icon-only button reports the
//     supplied name (not its glyph), plus a11y_description;
//   * a11y_role tags a plain text as a "heading";
//   * listbox rows are auto-tagged "listitem" (built-in a11y).
//
// The values are read back from the REAL backend accessible state:
// GET /widget/{id}/a11y → {role,name,description}. GTK4 sets them via
// gtk_accessible_update_property; win32 via MSAA Dynamic Annotation; macOS via
// NSAccessibility. See docs/design/accessibility.md.
//
// Run via ci.sh, or by hand:
//   AETHER_UI_TEST_PORT=9222 ./target/build/examples/a11y_demo/bin/a11y_demo &
//   UI_SPEC=a11y_demo/spec_a11y_demo tests/run_spec.sh
import aeocha
import uidriver
import std.string

// The row hstack containing label `txt` (rows carry no text of their own).
row_of(txt: string) -> int {
    lbl = uidriver.widget_id_by_text(txt)
    if lbl == 0 { return 0 }
    return uidriver.widget_int_field_by_id(lbl, "parent")
}

main() {
    fw = aeocha.init()
    uidriver.wait_server()

    aeocha.describe(fw, "accessibility semantics over AetherUIDriver") {
        aeocha.it("a plain button gets role+name for free") callback {
            b = uidriver.widget_id_by_text("Save")
            aeocha.assert_gt(b, 0, "Save button found")
            r = uidriver.get_body("/widget/${b}/a11y")
            aeocha.assert_contains(r, "\"role\":\"button\"", "auto role is button")
            aeocha.assert_contains(r, "\"name\":\"Save\"", "auto name is the label")
        }

        aeocha.it("a11y_label overrides the accessible name (icon button)") callback {
            g = uidriver.widget_id_by_text("⚙")
            aeocha.assert_gt(g, 0, "gear button found")
            r = uidriver.get_body("/widget/${g}/a11y")
            aeocha.assert_contains(r, "\"name\":\"Settings\"", "name is the override, not the glyph")
            aeocha.assert_contains(r, "\"description\":\"Open the settings panel\"",
                "description is set")
        }

        aeocha.it("a11y_role tags a text as a heading") callback {
            t = uidriver.widget_id_by_text("Accessibility demo")
            aeocha.assert_gt(t, 0, "title text found")
            r = uidriver.get_body("/widget/${t}/a11y")
            aeocha.assert_contains(r, "\"role\":\"heading\"", "title reports heading role")
        }

        aeocha.it("listbox rows are auto-tagged listitem") callback {
            row = row_of("Beta")
            aeocha.assert_gt(row, 0, "row of Beta found")
            r = uidriver.get_body("/widget/${row}/a11y")
            aeocha.assert_contains(r, "\"role\":\"listitem\"", "each row is a listitem")
        }

        aeocha.it("role + a11y_name also surface in /widgets") callback {
            b = uidriver.widget_id_by_text("Save")
            body = uidriver.get_body("/widgets")
            // The buffer is large; just assert the button's a11y fields appear.
            aeocha.assert_contains(body, "\"a11y_name\":\"Settings\"",
                "the gear's override name is in /widgets")
            aeocha.assert_contains(body, "\"role\":\"heading\"",
                "the heading role is in /widgets")
        }
    }
    aeocha.run_summary(fw)
}
