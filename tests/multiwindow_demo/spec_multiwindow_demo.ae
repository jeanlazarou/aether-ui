// spec_multiwindow_demo.ae — co-equal multi-window.
// A main window opens a second top-level window; GET /windows lists both,
// widgets carry a "window":N tag, cross-window state updates both windows, and
// closing the second leaves the first live (the loop keeps running).
import aeocha
import uidriver
import std.string

main() {
    fw = aeocha.init()
    uidriver.wait_server()

    aeocha.describe(fw, "multi-window over AetherUIDriver") {
        aeocha.it("starts with one window") callback {
            b = uidriver.get_body("/windows")
            aeocha.assert_contains(b, "\"id\":1", "primary window present")
            aeocha.assert_contains(b, "\"live\":true", "primary is live")
            two = string.contains(b, "\"id\":2")
            aeocha.assert_eq(two, 0, "no second window yet")
        }

        aeocha.it("opening a window adds a co-equal top-level") callback {
            o = uidriver.widget_id_by_text("open window 2")
            uidriver.post_ok("/widget/${o}/click", "open window 2")
            ok = uidriver.wait_body_contains("/windows", "\"id\":2", 20)
            aeocha.assert_true(ok, "second window opened")
            b = uidriver.get_body("/windows")
            aeocha.assert_contains(b, "\"title\":\"Window 2\"", "its title")
        }

        aeocha.it("widgets are tagged with their window") callback {
            b = uidriver.get_body("/widgets")
            // "Main window" text is window 1; "Second window" text is window 2.
            aeocha.assert_contains(b, "\"text\":\"Second window\",\"visible\":true", "2nd window's label exists")
            // Its window field is 2 (the tag follows the label in the JSON).
            aeocha.assert_contains(b, "\"text\":\"Second window\"", "second label present")
            id2 = uidriver.widget_id_by_text("Second window")
            w = uidriver.widget_int_field_by_id(id2, "window")
            aeocha.assert_eq(w, 2, "Second-window label is in window 2")
            id1 = uidriver.widget_id_by_text("Main window")
            w1 = uidriver.widget_int_field_by_id(id1, "window")
            aeocha.assert_eq(w1, 1, "Main-window label is in window 1")
        }

        aeocha.it("cross-window state updates both windows") callback {
            bmp = uidriver.widget_id_by_text("bump")
            uidriver.post_ok("/widget/${bmp}/click", "bump the shared counter")
            ok = uidriver.wait_body_contains("/widgets", "\"text\":\"count: 1\"", 20)
            aeocha.assert_true(ok, "counter updated")
            // Both windows show count: 1 — count how many "count: 1" labels.
            b = uidriver.get_body("/widgets")
            n = 0
            rest = b
            while string.contains(rest, "\"text\":\"count: 1\"") == 1 {
                n = n + 1
                idx = string.string_index_of(rest, "\"text\":\"count: 1\"")
                rest = string.string_substring(rest, idx + 18, string.length(rest))
            }
            aeocha.assert_eq(n, 2, "the shared count shows in both windows")
        }

        aeocha.it("closing the second window leaves the first live") callback {
            uidriver.post_ok("/window/2/close", "close window 2")
            ok = uidriver.wait_body_contains("/windows", "\"id\":2,\"title\":\"Window 2\",\"live\":false", 20)
            aeocha.assert_true(ok, "window 2 is closed")
            b = uidriver.get_body("/windows")
            aeocha.assert_contains(b, "\"id\":1,\"title\":\"Multi-window demo\",\"live\":true", "window 1 still live")
        }
    }
    aeocha.run_summary(fw)
}
