// aevg/test_grammar_interaction.ae — cursor + tooltip resolution parity.
//
// Headless port of the CVG interaction suites that the windowed TS tests
// exercise under a real pointer:
//   - svg-cursor.test.ts                 (per-element cursor, hover-driven)
//   - svg-dblclick-rtclick-tooltip.test.ts (tooltip presence on hover)
//
// The windowed tests assert "hover element X → cursor becomes Y / tooltip
// shows Z". The cursor/tooltip change is driven by the topmost HOVERABLE
// element at the pointer, where hoverable = has-hover-handler OR has-tooltip
// OR has-cursor (grammar-context.ts dispatchHover ~L105). We verify that
// resolution logic directly via events.cursor_at / tooltip_at and the
// stateful hover transitions, no window required.

import vg.grammar.events
import vg.grammar.context
import vg.grammar.element
import vg.geom.transform
import std.string

extern exit(code: int)
extern malloc(size: int) -> ptr

assert_eq_int(label: string, got: int, want: int) {
    if got == want { println("  PASS: ${label} (${got})") }
    else { println("  FAIL: ${label}: got ${got} want ${want}"); exit(1) }
}

assert_eq_str(label: string, got: string, want: string) {
    if string.equals(got, want) == 1 { println("  PASS: ${label} (${got})") }
    else { println("  FAIL: ${label}: got '${got}' want '${want}'"); exit(1) }
}

mk_test_ctx() -> ptr {
    id = transform.affine_identity()
    m = context.mapping_new(
        0.0, 0.0, 100.0, 100.0,
        100.0, 100.0,
        1.0, 0.0, 0.0,
        id
    )
    return context.new_context(m)
}

mk_tracked(ctx: ptr, x: float, y: float, w: float, h: float) -> ptr {
    sentinel = malloc(8)
    el = element.element_new(sentinel)
    element.element_set_bounds(el, x, y, w, h)
    events.track_element(ctx, el)
    return el
}

struct Recorder { n_calls: int last_hovered: int }
mk_recorder() -> *Recorder { r = malloc(16) as *Recorder; r.n_calls = 0; r.last_hovered = 0 - 1; return r }

// Captured key strings. A closure stores via string.copy (the struct-string
// idiom from test_grammar_bind) so the value survives past the handler.
struct KeyLog { down: string up: string }
mk_keylog() -> *KeyLog { k = malloc(16) as *KeyLog; k.down = ""; k.up = ""; return k }

main() {
    println("=== test_grammar_interaction ===")

    // ─── Cursor: per-element cursor resolves on hover ────────────
    // Layout mirrors svg-cursor.test.ts: a background (no cursor → default),
    // a button (pointer), an input (text), a resizer (hResize), a crosshair.
    ctx = mk_test_ctx()

    _bg    = mk_tracked(ctx, 0.0, 0.0, 100.0, 100.0)   // background, no cursor
    button = mk_tracked(ctx, 0.0, 0.0, 20.0, 20.0)
    element.element_set_cursor(button, "pointer")
    input  = mk_tracked(ctx, 30.0, 0.0, 20.0, 20.0)
    element.element_set_cursor(input, "text")
    resizer = mk_tracked(ctx, 60.0, 0.0, 10.0, 10.0)
    element.element_set_cursor(resizer, "hResize")
    cross  = mk_tracked(ctx, 80.0, 0.0, 15.0, 15.0)
    element.element_set_cursor(cross, "crosshair")

    assert_eq_str("cursor over button",   events.cursor_at(ctx, 10.0, 10.0), "pointer")
    assert_eq_str("cursor over input",    events.cursor_at(ctx, 40.0, 10.0), "text")
    assert_eq_str("cursor over resizer",  events.cursor_at(ctx, 65.0, 5.0),  "hResize")
    assert_eq_str("cursor over crosshair",events.cursor_at(ctx, 85.0, 5.0),  "crosshair")
    // Over the background only (a region none of the cursor rects cover):
    // bg has no cursor → "default".
    assert_eq_str("cursor over bg only",  events.cursor_at(ctx, 10.0, 60.0), "default")
    // Fully outside the scene → "default".
    assert_eq_str("cursor outside scene", events.cursor_at(ctx, 200.0, 200.0), "default")

    // ─── Topmost wins: a later cursor rect over the button ───────
    overlay = mk_tracked(ctx, 0.0, 0.0, 20.0, 20.0)
    element.element_set_cursor(overlay, "crosshair")
    assert_eq_str("topmost cursor wins", events.cursor_at(ctx, 10.0, 10.0), "crosshair")

    // ─── Tooltip resolution ──────────────────────────────────────
    ctx2 = mk_test_ctx()
    help = mk_tracked(ctx2, 0.0, 0.0, 30.0, 30.0)
    element.element_set_tooltip(help, "Click to save")
    _plain = mk_tracked(ctx2, 40.0, 0.0, 30.0, 30.0)   // no tooltip

    assert_eq_str("tooltip over help",  events.tooltip_at(ctx2, 15.0, 15.0), "Click to save")
    assert_eq_str("tooltip over plain", events.tooltip_at(ctx2, 50.0, 15.0), "")
    assert_eq_str("tooltip empty space",events.tooltip_at(ctx2, 90.0, 90.0), "")

    // ─── Cursor-only element still drives hover enter/leave ──────
    // svg-cursor.test.ts records 4 hover-in / 4 hover-out: the hovered
    // element transitions even when it has ONLY a cursor (no onHover). Here
    // we give a cursor-only element a hover handler too and confirm it fires
    // (the handler is optional in CVG; the transition itself must occur).
    ctx3 = mk_test_ctx()
    es3 = events.event_state_new()
    rec = mk_recorder()
    btn = mk_tracked(ctx3, 0.0, 0.0, 30.0, 30.0)
    element.element_set_cursor(btn, "pointer")
    element.element_on_hover(btn) callback |hovered: int| {
        rec.n_calls = rec.n_calls + 1
        rec.last_hovered = hovered
    }
    // A pure cursor-only neighbour (no hover handler) — must still become the
    // hovered element (so its cursor would apply), exercising the widened
    // hoverable predicate.
    cursoronly = mk_tracked(ctx3, 40.0, 0.0, 30.0, 30.0)
    element.element_set_cursor(cursoronly, "text")

    events.dispatch_hover(es3, ctx3, 15.0, 15.0)   // into btn
    assert_eq_int("hover into btn: handler fired", rec.n_calls, 1)
    assert_eq_int("hover into btn: hovered=1",      rec.last_hovered, 1)

    // Move onto the cursor-only element: btn must get a leave (transition to
    // a different hovered element even though that element has no handler).
    events.dispatch_hover(es3, ctx3, 55.0, 15.0)
    assert_eq_int("btn leave when moving to cursor-only", rec.n_calls, 2)
    assert_eq_int("btn leave: hovered=0",                 rec.last_hovered, 0)
    if events.event_state_hovered(es3) == cursoronly {
        println("  PASS: cursor-only element captured hover")
    } else {
        println("  FAIL: cursor-only element should be hovered")
        exit(1)
    }
    // And its cursor resolves at that point.
    assert_eq_str("cursor-only resolves", events.cursor_at(ctx3, 55.0, 15.0), "text")

    // ─── Keyboard: scene-wide key-down / key-up ──────────────────
    // Port of svg-drag-scroll-keys.test.ts "onKeyDown/onKeyUp fire on
    // CvgContext": dispatch ArrowUp↓, ArrowUp↑, Space↓ → down=[ArrowUp,Space],
    // up=[ArrowUp]. Keyboard is scene-level (no hit-test), handlers on the
    // event state. We record count + last key per stream.
    _ctx4 = mk_test_ctx()
    es4 = events.event_state_new()
    kd = mk_recorder()
    ku = mk_recorder()
    klog = mk_keylog()
    // Reuse Recorder.n_calls as count; capture last key in the KeyLog struct.
    events.event_on_key_down(es4) callback |key: string| {
        kd.n_calls = kd.n_calls + 1
        klog.down = string.copy(key)
    }
    events.event_on_key_up(es4) callback |key: string| {
        ku.n_calls = ku.n_calls + 1
        klog.up = string.copy(key)
    }

    events.dispatch_key_down(es4, "ArrowUp")
    assert_eq_int("keydown ArrowUp: count 1", kd.n_calls, 1)
    assert_eq_str("keydown ArrowUp: key",     klog.down, "ArrowUp")

    events.dispatch_key_up(es4, "ArrowUp")
    assert_eq_int("keyup ArrowUp: count 1",   ku.n_calls, 1)
    assert_eq_str("keyup ArrowUp: key",       klog.up, "ArrowUp")

    events.dispatch_key_down(es4, "Space")
    assert_eq_int("keydown Space: count 2",   kd.n_calls, 2)
    assert_eq_str("keydown Space: key",       klog.down, "Space")
    // keysDown == [ArrowUp, Space] (2), keysUp == [ArrowUp] (1).
    assert_eq_int("total key-downs",          kd.n_calls, 2)
    assert_eq_int("total key-ups",            ku.n_calls, 1)

    // No handler registered → dispatch is a safe no-op.
    es5 = events.event_state_new()
    events.dispatch_key_down(es5, "Escape")   // must not crash
    events.dispatch_key_up(es5, "Escape")
    println("  PASS: key dispatch with no handler is a no-op")

    println("=== test_grammar_interaction passed ===")
}
