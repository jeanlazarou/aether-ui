// aevg/test_gradient_fill.ae — gradient fill descriptor emission.
//
// Verifies that shape_path, when its fill references a registered
// gradient (fill=url(#id)), emits a gradient descriptor into the
// backend opts (gradType + geometry + gradStops) instead of a solid
// fillColor — and that plain fills still emit fillColor. Mirrors the
// TS resolveGradientFill + buildFillGradient path.

import std.string
import std.map
import vg.grammar.shapes
import vg.grammar.context
import vg.grammar.defs
import vg.backend.record
import vg.svg.parser
import vg.geom.transform

extern exit(code: int)

assert_eq_str(label: string, got: string, want: string) {
    if string.equals(got, want) == 1 { println("  PASS: ${label} ('${got}')") }
    else { println("  FAIL: ${label}: got '${got}' want '${want}'"); exit(1) }
}

assert_opt_near(label: string, b: ptr, i: int, key: string, want: float) {
    s = record.backend_opt_get(b, i, key)
    got, e = string.to_double(s)
    if e != "" { println("  FAIL: ${label}: parse '${s}'"); exit(1) }
    d = got - want
    if d < 0.0 { d = 0.0 - d }
    if d < 0.5 { println("  PASS: ${label} (${got})") }
    else { println("  FAIL: ${label}: got ${got} want ${want}"); exit(1) }
}

assert_nonempty(label: string, b: ptr, i: int, key: string) {
    s = record.backend_opt_get(b, i, key)
    if string.length(s) > 0 { println("  PASS: ${label} ('${s}')") }
    else { println("  FAIL: ${label}: empty"); exit(1) }
}

assert_empty(label: string, b: ptr, i: int, key: string) {
    s = record.backend_opt_get(b, i, key)
    if string.length(s) == 0 { println("  PASS: ${label} (empty)") }
    else { println("  FAIL: ${label}: got '${s}'"); exit(1) }
}

mk_ctx() -> ptr {
    id = transform.affine_identity()
    m = context.mapping_new(
        0.0, 0.0, 100.0, 100.0,
        100.0, 100.0,
        1.0, 0.0, 0.0,
        id
    )
    return context.new_context(m)
}

// Register a linear gradient (objectBoundingBox, 0,0→1,0) with two
// stops red→blue.
register_linear(ctx: ptr, id: string) {
    a = string.concat("<svg><defs><linearGradient id='", id)
    a = string.concat(a, "' x1='0' y1='0' x2='1' y2='0'>")
    a = string.concat(a, "<stop offset='0' stop-color='#ff0000'/>")
    a = string.concat(a, "<stop offset='1' stop-color='#0000ff'/>")
    a = string.concat(a, "</linearGradient></defs></svg>")
    root = parser.parse_svg(a)
    defs_node = parser.node_child_at(root, 0)
    grad_node = parser.node_child_at(defs_node, 0)
    _ = defs.parse_gradient(ctx, grad_node)
}

// Register a radial gradient (objectBoundingBox).
register_radial(ctx: ptr, id: string) {
    a = string.concat("<svg><defs><radialGradient id='", id)
    a = string.concat(a, "' cx='0.5' cy='0.5' r='0.5'>")
    a = string.concat(a, "<stop offset='0' stop-color='#ffffff'/>")
    a = string.concat(a, "<stop offset='1' stop-color='#000000'/>")
    a = string.concat(a, "</radialGradient></defs></svg>")
    root = parser.parse_svg(a)
    defs_node = parser.node_child_at(root, 0)
    grad_node = parser.node_child_at(defs_node, 0)
    _ = defs.parse_gradient(ctx, grad_node)
}

mk_path_attrs(d: string, fill: string) -> ptr {
    m = map.new()
    _ = map.put(m, "d", d)
    _ = map.put(m, "fill", fill)
    return m
}

main() {
    println("=== test_gradient_fill ===")

    // ─── Plain fill → fillColor, no gradType ──────────────────
    ctx1 = mk_ctx()
    bk1 = record.backend_new()
    a1 = mk_path_attrs("M 0 0 L 100 0 L 100 100 Z", "yellow")
    _ = shapes.shape_path(ctx1, bk1, a1)
    assert_nonempty("plain: fillColor present", bk1, 0, "fillColor")
    assert_empty("plain: no gradType", bk1, 0, "gradType")

    // ─── Linear gradient fill → gradType=linear, stops, no fill ─
    ctx2 = mk_ctx()
    bk2 = record.backend_new()
    register_linear(ctx2, "g1")
    a2 = mk_path_attrs("M 0 0 L 100 0 L 100 100 Z", "url(#g1)")
    _ = shapes.shape_path(ctx2, bk2, a2)
    assert_eq_str("linear: gradType", record.backend_kind(bk2, 0), "path")
    assert_eq_str("linear: gradType=linear",
                  record.backend_opt_get(bk2, 0, "gradType"), "linear")
    assert_empty("linear: fillColor omitted", bk2, 0, "fillColor")
    assert_nonempty("linear: gradStops present", bk2, 0, "gradStops")
    // objectBoundingBox 0,0→1,0 over bbox (0,0,100,100): X1=0, X2=100.
    assert_opt_near("linear: gradX1=0",   bk2, 0, "gradX1", 0.0)
    assert_opt_near("linear: gradX2=100", bk2, 0, "gradX2", 100.0)
    assert_opt_near("linear: gradY1=0",   bk2, 0, "gradY1", 0.0)
    // Stops string: "0,255,0,0,255 1,0,0,255,255"
    assert_eq_str("linear: gradStops value",
                  record.backend_opt_get(bk2, 0, "gradStops"),
                  "0,255,0,0,255 1,0,0,255,255")

    // ─── Radial gradient fill → gradType=radial ───────────────
    ctx3 = mk_ctx()
    bk3 = record.backend_new()
    register_radial(ctx3, "g2")
    a3 = mk_path_attrs("M 0 0 L 100 0 L 100 100 Z", "url(#g2)")
    _ = shapes.shape_path(ctx3, bk3, a3)
    assert_eq_str("radial: gradType=radial",
                  record.backend_opt_get(bk3, 0, "gradType"), "radial")
    // cx/cy 0.5 over bbox (0,0,100,100): 50,50; r 0.5*100 = 50.
    assert_opt_near("radial: gradCX=50", bk3, 0, "gradCX", 50.0)
    assert_opt_near("radial: gradCY=50", bk3, 0, "gradCY", 50.0)
    assert_opt_near("radial: gradR=50",  bk3, 0, "gradR",  50.0)
    // No spreadMethod attr → defaults to "pad".
    assert_eq_str("radial: gradSpread default pad",
                  record.backend_opt_get(bk3, 0, "gradSpread"), "pad")

    // ─── spreadMethod="reflect" → gradSpread=reflect ──────────
    ctx_sp = mk_ctx()
    bk_sp = record.backend_new()
    sp = "<svg><defs><radialGradient id='sp' cx='0.5' cy='0.5' r='0.5' spreadMethod='reflect'><stop offset='0' stop-color='#fff'/><stop offset='1' stop-color='#000'/></radialGradient></defs></svg>"
    root_sp = parser.parse_svg(sp)
    defs_sp = parser.node_child_at(root_sp, 0)
    _ = defs.parse_gradient(ctx_sp, parser.node_child_at(defs_sp, 0))
    a_sp = mk_path_attrs("M 0 0 L 100 0 L 100 100 Z", "url(#sp)")
    _ = shapes.shape_path(ctx_sp, bk_sp, a_sp)
    assert_eq_str("spread: gradSpread=reflect",
                  record.backend_opt_get(bk_sp, 0, "gradSpread"), "reflect")

    // ─── Gradient stroke → strokeGradType + strokeGradStops ───
    ctx4 = mk_ctx()
    bk4 = record.backend_new()
    register_linear(ctx4, "g3")
    a4 = map.new()
    _ = map.put(a4, "d", "M 0 0 L 100 0 L 100 100 Z")
    _ = map.put(a4, "fill", "none")
    _ = map.put(a4, "stroke", "url(#g3)")
    _ = map.put(a4, "stroke-width", "4")
    _ = shapes.shape_path(ctx4, bk4, a4)
    assert_eq_str("stroke-grad: strokeGradType=linear",
                  record.backend_opt_get(bk4, 0, "strokeGradType"), "linear")
    assert_nonempty("stroke-grad: strokeGradStops present", bk4, 0, "strokeGradStops")
    assert_empty("stroke-grad: strokeColor omitted", bk4, 0, "strokeColor")

    // ─── Gradient-filled rect → routes through path ───────────
    // A rect with fill=url(#id) builds a rect path and delegates to
    // shape_path, so the dispatch kind is "path" (not "rectangle")
    // and carries the gradient descriptor.
    ctx5 = mk_ctx()
    bk5 = record.backend_new()
    register_linear(ctx5, "g4")
    a5 = map.new()
    _ = map.put(a5, "x", "10")
    _ = map.put(a5, "y", "10")
    _ = map.put(a5, "width", "80")
    _ = map.put(a5, "height", "40")
    _ = map.put(a5, "fill", "url(#g4)")
    _ = shapes.shape_rectangle(ctx5, bk5, a5)
    assert_eq_str("grad rect: routed to path", record.backend_kind(bk5, 0), "path")
    assert_eq_str("grad rect: gradType=linear",
                  record.backend_opt_get(bk5, 0, "gradType"), "linear")

    // ─── Gradient-filled circle → routes through path ─────────
    // Previously a circle with fill=url(#id) emitted a SOLID fillColor (→
    // black): only shape_path emits gradient opts. Now shape_circle delegates
    // to a path (ellipse rx==ry) when the fill is a gradient.
    ctx_cg = mk_ctx()
    bk_cg = record.backend_new()
    register_radial(ctx_cg, "cg")
    a_cg = map.new()
    _ = map.put(a_cg, "cx", "50")
    _ = map.put(a_cg, "cy", "50")
    _ = map.put(a_cg, "r", "40")
    _ = map.put(a_cg, "fill", "url(#cg)")
    _ = shapes.shape_circle(ctx_cg, bk_cg, a_cg)
    assert_eq_str("grad circle: routed to path", record.backend_kind(bk_cg, 0), "path")
    assert_eq_str("grad circle: gradType=radial",
                  record.backend_opt_get(bk_cg, 0, "gradType"), "radial")
    assert_nonempty("grad circle: gradStops present", bk_cg, 0, "gradStops")
    assert_empty("grad circle: no solid fillColor", bk_cg, 0, "fillColor")

    // ─── Rounded rect → routes through path ───────────────────
    ctx6 = mk_ctx()
    bk6 = record.backend_new()
    a6 = map.new()
    _ = map.put(a6, "x", "10")
    _ = map.put(a6, "y", "10")
    _ = map.put(a6, "width", "80")
    _ = map.put(a6, "height", "40")
    _ = map.put(a6, "rx", "8")
    _ = map.put(a6, "fill", "orange")
    _ = shapes.shape_rectangle(ctx6, bk6, a6)
    assert_eq_str("rounded rect: routed to path", record.backend_kind(bk6, 0), "path")
    // Rounded corners flatten arcs → many points; just confirm non-empty.
    assert_nonempty("rounded rect: points present", bk6, 0, "points")

    // ─── Plain rect (no grad/round/rotation) → stays rectangle ─
    ctx7 = mk_ctx()
    bk7 = record.backend_new()
    a7 = map.new()
    _ = map.put(a7, "x", "10")
    _ = map.put(a7, "y", "10")
    _ = map.put(a7, "width", "80")
    _ = map.put(a7, "height", "40")
    _ = map.put(a7, "fill", "teal")
    _ = shapes.shape_rectangle(ctx7, bk7, a7)
    assert_eq_str("plain rect: stays rectangle", record.backend_kind(bk7, 0), "rectangle")

    println("=== test_gradient_fill passed ===")
}
