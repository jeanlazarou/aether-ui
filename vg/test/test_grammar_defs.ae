// aevg/test_grammar_defs.ae — regression test for defs.ae.
//
// Covers gradient parsing + registration:
//   - linearGradient with explicit x1/y1/x2/y2
//   - linearGradient with default coords
//   - linearGradient with "%" values
//   - radialGradient with cx/cy/r
//   - radialGradient defaults: fx = cx, fy = cy
//   - Stops: offset/color/stop-opacity round-trip
//   - units + spreadMethod pass-through
//   - gradientTransform applies to coords
//   - Missing id → no registration
//
// End-to-end via loader: <svg><defs><linearGradient/></defs></svg>
// parses, walks, registers — verified through ctx.gradients lookup.

import vg.grammar.defs
import vg.grammar.context
import vg.svg.loader
import vg.backend.record
import vg.svg.parser
import std.list
import std.string
import std.math
import vg.geom.transform

extern exit(code: int)
extern malloc(size: int) -> ptr

assert_eq_int(label: string, got: int, want: int) {
    if got == want { println("  PASS: ${label} (${got})") }
    else { println("  FAIL: ${label}: got ${got} want ${want}"); exit(1) }
}

assert_eq_str(label: string, got: string, want: string) {
    if string.equals(got, want) == 1 { println("  PASS: ${label} ('${got}')") }
    else { println("  FAIL: ${label}: got '${got}' want '${want}'"); exit(1) }
}

assert_near(label: string, got: float, want: float) {
    if math.abs_float(got - want) < 0.001 { println("  PASS: ${label} (${got})") }
    else { println("  FAIL: ${label}: got ${got} want ${want}"); exit(1) }
}

assert_not_null(label: string, p: ptr) {
    if p == null { println("  FAIL: ${label}: null"); exit(1) }
    else { println("  PASS: ${label} (non-null)") }
}

mk_test_ctx() -> ptr {
    id = transform.affine_identity()
    m = context.mapping_new(
        0.0, 0.0, 100.0, 100.0,
        100.0, 100.0,
        1.0, 0.0, 0.0,
        id
    )
    return context.new_context(m)
}

main() {
    println("=== test_grammar_defs ===")

    // ─── Linear gradient: explicit coords + 2 stops ──────────────
    ctx1 = mk_test_ctx()
    svg1 = "<svg><defs><linearGradient id='g1' x1='0' y1='0' x2='1' y2='0'><stop offset='0' stop-color='red'/><stop offset='1' stop-color='blue'/></linearGradient></defs></svg>"
    root1 = parser.parse_svg(svg1)
    // <defs> is the first child; descend manually.
    defs_node = parser.node_child_at(root1, 0)
    grad_node = parser.node_child_at(defs_node, 0)
    g1 = defs.parse_gradient(ctx1, grad_node)

    assert_not_null("linear g1 returned", g1)
    assert_eq_int("g1 registered (has_gradient)",
                   context.has_gradient(ctx1, "g1"), 1)
    assert_eq_int("g1 type = linear",
                   defs.gradient_type(g1),
                   defs.GRADIENT_LINEAR())
    assert_near("g1 x1", defs.gradient_x1(g1), 0.0)
    assert_near("g1 y1", defs.gradient_y1(g1), 0.0)
    assert_near("g1 x2", defs.gradient_x2(g1), 1.0)
    assert_near("g1 y2", defs.gradient_y2(g1), 0.0)
    assert_eq_int("g1 stop count = 2", defs.gradient_stop_count(g1), 2)

    // Stop 0: offset 0, color red
    stops = defs.gradient_stops(g1)
    s0_item, _ = list.get(stops, 0)
    assert_near("g1 stop[0].offset", defs.stop_offset(s0_item), 0.0)
    assert_eq_str("g1 stop[0].color", defs.stop_color(s0_item), "red")
    s1_item, _ = list.get(stops, 1)
    assert_near("g1 stop[1].offset", defs.stop_offset(s1_item), 1.0)
    assert_eq_str("g1 stop[1].color", defs.stop_color(s1_item), "blue")

    // ─── Linear gradient: default coords (x1=0,y1=0,x2=1,y2=0) ───
    ctx2 = mk_test_ctx()
    svg2 = "<svg><defs><linearGradient id='g2'><stop offset='0' stop-color='black'/><stop offset='1' stop-color='white'/></linearGradient></defs></svg>"
    root2 = parser.parse_svg(svg2)
    g2 = defs.parse_gradient(ctx2,
        parser.node_child_at(parser.node_child_at(root2, 0), 0))
    assert_near("g2 default x1", defs.gradient_x1(g2), 0.0)
    assert_near("g2 default x2", defs.gradient_x2(g2), 1.0)

    // ─── "%" coord parsing: x1='0%' x2='100%' ────────────────────
    ctx3 = mk_test_ctx()
    svg3 = "<svg><defs><linearGradient id='g3' x1='0%' y1='0%' x2='100%' y2='0%'><stop offset='50%' stop-color='gray'/></linearGradient></defs></svg>"
    root3 = parser.parse_svg(svg3)
    g3 = defs.parse_gradient(ctx3,
        parser.node_child_at(parser.node_child_at(root3, 0), 0))
    assert_near("g3 x1='0%'",  defs.gradient_x1(g3), 0.0)
    assert_near("g3 x2='100%'", defs.gradient_x2(g3), 1.0)
    // Stop offset='50%' → 0.5
    s50, _ = list.get(defs.gradient_stops(g3), 0)
    assert_near("g3 stop offset='50%'", defs.stop_offset(s50), 0.5)

    // ─── Stop with stop-opacity bakes into rgba(...) ─────────────
    ctx4 = mk_test_ctx()
    svg4 = "<svg><defs><linearGradient id='g4'><stop offset='0' stop-color='red' stop-opacity='0.5'/></linearGradient></defs></svg>"
    root4 = parser.parse_svg(svg4)
    g4 = defs.parse_gradient(ctx4,
        parser.node_child_at(parser.node_child_at(root4, 0), 0))
    op_stop, _ = list.get(defs.gradient_stops(g4), 0)
    // apply_opacity_to_color emits "rgba(255, 0, 0, 0.5)" for red+0.5.
    assert_eq_str("g4 opacity-baked stop", defs.stop_color(op_stop),
                   "rgba(255, 0, 0, 0.5)")

    // ─── units + spreadMethod pass-through ───────────────────────
    ctx5 = mk_test_ctx()
    svg5 = "<svg><defs><linearGradient id='g5' gradientUnits='userSpaceOnUse' spreadMethod='reflect'><stop offset='0' stop-color='red'/></linearGradient></defs></svg>"
    root5 = parser.parse_svg(svg5)
    g5 = defs.parse_gradient(ctx5,
        parser.node_child_at(parser.node_child_at(root5, 0), 0))
    assert_eq_str("g5 units",         defs.gradient_units(g5),         "userSpaceOnUse")
    assert_eq_str("g5 spreadMethod",  defs.gradient_spread_method(g5), "reflect")

    // ─── Radial gradient: cx/cy/r + default fx,fy ────────────────
    ctx6 = mk_test_ctx()
    svg6 = "<svg><defs><radialGradient id='g6' cx='0.5' cy='0.5' r='0.5'><stop offset='0' stop-color='white'/><stop offset='1' stop-color='black'/></radialGradient></defs></svg>"
    root6 = parser.parse_svg(svg6)
    g6 = defs.parse_gradient(ctx6,
        parser.node_child_at(parser.node_child_at(root6, 0), 0))
    assert_eq_int("g6 type = radial",
                   defs.gradient_type(g6),
                   defs.GRADIENT_RADIAL())
    assert_near("g6 cx", defs.gradient_cx(g6), 0.5)
    assert_near("g6 cy", defs.gradient_cy(g6), 0.5)
    assert_near("g6 r",  defs.gradient_r(g6),  0.5)
    // fx/fy default to cx/cy
    assert_near("g6 fx default = cx", defs.gradient_fx(g6), 0.5)
    assert_near("g6 fy default = cy", defs.gradient_fy(g6), 0.5)

    // ─── gradientTransform applies to coords ─────────────────────
    // translate(10 5) on linear (0,0)→(1,0) maps to (10,5)→(11,5).
    ctx7 = mk_test_ctx()
    svg7 = "<svg><defs><linearGradient id='g7' x1='0' y1='0' x2='1' y2='0' gradientTransform='translate(10 5)'><stop offset='0' stop-color='red'/></linearGradient></defs></svg>"
    root7 = parser.parse_svg(svg7)
    g7 = defs.parse_gradient(ctx7,
        parser.node_child_at(parser.node_child_at(root7, 0), 0))
    assert_near("g7 x1 after translate", defs.gradient_x1(g7), 10.0)
    assert_near("g7 y1 after translate", defs.gradient_y1(g7), 5.0)
    assert_near("g7 x2 after translate", defs.gradient_x2(g7), 11.0)
    assert_near("g7 y2 after translate", defs.gradient_y2(g7), 5.0)

    // ─── No id → no registration ─────────────────────────────────
    ctx8 = mk_test_ctx()
    svg8 = "<svg><defs><linearGradient><stop offset='0' stop-color='red'/></linearGradient></defs></svg>"
    root8 = parser.parse_svg(svg8)
    g8 = defs.parse_gradient(ctx8,
        parser.node_child_at(parser.node_child_at(root8, 0), 0))
    if g8 == null {
        println("  PASS: no id → null returned")
    } else {
        println("  FAIL: no id → expected null")
        exit(1)
    }

    // ─── Filter: <filter id='f1' x='-10%' y='-10%' width='120%' height='120%'> ──
    ctx_f1 = mk_test_ctx()
    svg_f1 = "<svg><defs><filter id='f1' x='-10%' y='-10%' width='120%' height='120%'><feGaussianBlur stdDeviation='3'/></filter></defs></svg>"
    root_f1 = parser.parse_svg(svg_f1)
    f1 = defs.parse_filter(ctx_f1,
        parser.node_child_at(parser.node_child_at(root_f1, 0), 0))
    assert_not_null("filter f1 returned", f1)
    assert_eq_int("f1 registered", context.has_filter(ctx_f1, "f1"), 1)
    assert_near("f1 region_x = -0.1",  defs.filter_region_x(f1),      0.0 - 0.1)
    assert_near("f1 region_w = 1.2",   defs.filter_region_width(f1),  1.2)
    assert_eq_int("f1 has blur",       defs.filter_has_blur(f1),      1)
    assert_near("f1 blur sigma_x = 3", defs.filter_blur_sigma_x(f1),  3.0)
    assert_near("f1 blur sigma_y = 3 (default = x)",
                                       defs.filter_blur_sigma_y(f1),  3.0)

    // Filter with separate x/y sigmas: "5 2"
    ctx_f2 = mk_test_ctx()
    svg_f2 = "<svg><defs><filter id='f2'><feGaussianBlur stdDeviation='5 2'/></filter></defs></svg>"
    root_f2 = parser.parse_svg(svg_f2)
    f2 = defs.parse_filter(ctx_f2,
        parser.node_child_at(parser.node_child_at(root_f2, 0), 0))
    assert_near("f2 sigma_x = 5", defs.filter_blur_sigma_x(f2), 5.0)
    assert_near("f2 sigma_y = 2", defs.filter_blur_sigma_y(f2), 2.0)

    // Filter with no feGaussianBlur child: region defaults applied,
    // has_blur stays 0.
    ctx_f3 = mk_test_ctx()
    svg_f3 = "<svg><defs><filter id='f3'/></defs></svg>"
    root_f3 = parser.parse_svg(svg_f3)
    f3 = defs.parse_filter(ctx_f3,
        parser.node_child_at(parser.node_child_at(root_f3, 0), 0))
    assert_eq_int("f3 has_blur = 0 (no fe child)", defs.filter_has_blur(f3), 0)
    assert_near("f3 default region_x = -0.1", defs.filter_region_x(f3),     0.0 - 0.1)
    assert_near("f3 default region_w = 1.2",  defs.filter_region_width(f3), 1.2)

    // Filter region with fractional (non-%) values
    ctx_f4 = mk_test_ctx()
    svg_f4 = "<svg><defs><filter id='f4' x='0' y='0' width='1' height='1'><feGaussianBlur stdDeviation='1'/></filter></defs></svg>"
    root_f4 = parser.parse_svg(svg_f4)
    f4 = defs.parse_filter(ctx_f4,
        parser.node_child_at(parser.node_child_at(root_f4, 0), 0))
    assert_near("f4 region_x = 0",  defs.filter_region_x(f4),     0.0)
    assert_near("f4 region_w = 1",  defs.filter_region_width(f4), 1.0)

    // ─── ClipPath: <clipPath><rect/></clipPath> ──────────────────
    ctx_cp1 = mk_test_ctx()
    svg_cp1 = "<svg><defs><clipPath id='cp1'><rect x='10' y='20' width='30' height='40'/></clipPath></defs></svg>"
    root_cp1 = parser.parse_svg(svg_cp1)
    cp1 = defs.parse_clip_path(ctx_cp1,
        parser.node_child_at(parser.node_child_at(root_cp1, 0), 0))
    assert_not_null("clipPath cp1 returned", cp1)
    assert_eq_int("cp1 registered",          context.has_clip_path(ctx_cp1, "cp1"), 1)
    assert_eq_int("cp1 shape count = 1",     defs.clip_path_shape_count(cp1), 1)
    cp1_shape0 = defs.clip_path_shape_at(cp1, 0)
    assert_eq_int("cp1[0] is rect",          defs.clip_shape_kind(cp1_shape0),
                                              defs.CLIP_SHAPE_RECT())
    assert_near("cp1[0].x",                  defs.clip_shape_x(cp1_shape0),      10.0)
    assert_near("cp1[0].y",                  defs.clip_shape_y(cp1_shape0),      20.0)
    assert_near("cp1[0].width",              defs.clip_shape_width(cp1_shape0),  30.0)
    assert_near("cp1[0].height",             defs.clip_shape_height(cp1_shape0), 40.0)

    // ClipPath with a circle + a rect + a polygon (ignored)
    ctx_cp2 = mk_test_ctx()
    svg_cp2 = "<svg><defs><clipPath id='cp2'><circle cx='5' cy='6' r='7'/><polygon points='0,0 1,1'/><rect x='0' y='0' width='10' height='10'/></clipPath></defs></svg>"
    root_cp2 = parser.parse_svg(svg_cp2)
    cp2 = defs.parse_clip_path(ctx_cp2,
        parser.node_child_at(parser.node_child_at(root_cp2, 0), 0))
    assert_eq_int("cp2 shape count = 2 (polygon skipped)",
                   defs.clip_path_shape_count(cp2), 2)
    cp2_s0 = defs.clip_path_shape_at(cp2, 0)
    assert_eq_int("cp2[0] is circle", defs.clip_shape_kind(cp2_s0),
                                       defs.CLIP_SHAPE_CIRCLE())
    assert_near("cp2[0].cx", defs.clip_shape_cx(cp2_s0), 5.0)
    assert_near("cp2[0].cy", defs.clip_shape_cy(cp2_s0), 6.0)
    assert_near("cp2[0].r",  defs.clip_shape_r(cp2_s0),  7.0)
    cp2_s1 = defs.clip_path_shape_at(cp2, 1)
    assert_eq_int("cp2[1] is rect", defs.clip_shape_kind(cp2_s1),
                                     defs.CLIP_SHAPE_RECT())

    // Missing id → null returned
    ctx_cp3 = mk_test_ctx()
    svg_cp3 = "<svg><defs><clipPath><rect/></clipPath></defs></svg>"
    root_cp3 = parser.parse_svg(svg_cp3)
    cp3 = defs.parse_clip_path(ctx_cp3,
        parser.node_child_at(parser.node_child_at(root_cp3, 0), 0))
    if cp3 == null {
        println("  PASS: clipPath no id → null")
    } else {
        println("  FAIL: clipPath no id → expected null")
        exit(1)
    }

    // ─── End-to-end via loader: <defs><linearGradient/></defs> ───
    bk = record.backend_new()
    svg_e2e = "<svg viewBox='0 0 100 100' width='100' height='100'><defs><linearGradient id='myGrad' x1='0' y1='0' x2='1' y2='1'><stop offset='0' stop-color='red'/><stop offset='1' stop-color='blue'/></linearGradient></defs><rect x='10' y='10' width='30' height='30' fill='green'/></svg>"
    ctx_e2e = loader.load_svg(bk, svg_e2e, 100.0, 100.0)
    // The rect renders; the gradient is in the registry.
    assert_eq_int("e2e: rect rendered",        record.backend_call_count(bk), 1)
    assert_eq_int("e2e: gradient registered",  context.has_gradient(ctx_e2e, "myGrad"), 1)
    g_e2e = context.get_gradient(ctx_e2e, "myGrad")
    assert_not_null("e2e: gradient lookup",     g_e2e)
    assert_eq_int("e2e: gradient stop count",  defs.gradient_stop_count(g_e2e), 2)

    // ─── End-to-end with filter + clipPath ───────────────────────
    bk2 = record.backend_new()
    svg_e2e2 = "<svg viewBox='0 0 100 100' width='100' height='100'><defs><filter id='blur5'><feGaussianBlur stdDeviation='5'/></filter><clipPath id='clip1'><rect x='10' y='10' width='80' height='80'/></clipPath></defs><rect x='0' y='0' width='100' height='100' fill='black'/></svg>"
    ctx_e2e2 = loader.load_svg(bk2, svg_e2e2, 100.0, 100.0)
    assert_eq_int("e2e2: filter registered",     context.has_filter(ctx_e2e2, "blur5"), 1)
    assert_eq_int("e2e2: clipPath registered",   context.has_clip_path(ctx_e2e2, "clip1"), 1)
    assert_eq_int("e2e2: rect rendered",         record.backend_call_count(bk2), 1)

    f_e2e = context.get_filter(ctx_e2e2, "blur5")
    assert_near("e2e2: filter sigma_x = 5",      defs.filter_blur_sigma_x(f_e2e), 5.0)

    cp_e2e = context.get_clip_path(ctx_e2e2, "clip1")
    assert_eq_int("e2e2: clipPath 1 shape",      defs.clip_path_shape_count(cp_e2e), 1)

    // ─── Gradient xlink:href stop inheritance ────────────────────
    // A radialGradient with href to a base linearGradient (carrying the
    // stops) and no own <stop>s inherits the base's stops. The base node must
    // be registered (the loader does this via index_nodes); we mimic that.
    ctx_href = mk_test_ctx()
    svg_href = "<svg><defs><linearGradient id='base'><stop offset='0' stop-color='#0a0'/><stop offset='1' stop-color='#00a'/></linearGradient><radialGradient id='rg' xlink:href='#base' cx='0.5' cy='0.5' r='0.5'/></defs></svg>"
    root_href = parser.parse_svg(svg_href)
    defs_href = parser.node_child_at(root_href, 0)
    base_node = parser.node_child_at(defs_href, 0)
    rg_node = parser.node_child_at(defs_href, 1)
    context.register_node(ctx_href, "base", base_node)
    _ = defs.parse_gradient(ctx_href, base_node)
    g_rg = defs.parse_gradient(ctx_href, rg_node)
    assert_not_null("href: radial gradient returned", g_rg)
    assert_eq_int("href: radial is radial",
                  defs.gradient_type(g_rg), defs.GRADIENT_RADIAL())
    assert_eq_int("href: inherited 2 stops from base",
                  defs.gradient_stop_count(g_rg), 2)
    rg_stops = defs.gradient_stops(g_rg)
    rs0, _ = list.get(rg_stops, 0)
    assert_eq_str("href: inherited stop[0] color",
                  defs.stop_color(rs0), "#0a0")

    println("=== test_grammar_defs passed ===")
}
