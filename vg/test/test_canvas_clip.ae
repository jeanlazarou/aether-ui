// aevg/test_canvas_clip.ae — the CANVAS_CLIP_RECT primitive clips drawing.
//
// Headless pixel test of the new clip primitive (the risky new C code):
// clip to a small rect, fill a large rect over the whole canvas, render to a
// PNG offscreen, and assert a pixel INSIDE the clip is the fill colour while a
// pixel OUTSIDE it is background. This is what the vg scene's viewport clip
// relies on (overflow:hidden); the visual end-to-end is driver-verified by
// example_aevg_clip.

import ui (canvas_create, canvas_clip_rect, canvas_fill_rect, canvas_write_png)
import std.string

extern exit(code: int)
extern getenv(name: string) -> string

main() {
    println("=== test_canvas_clip ===")

    cid = canvas_create(100, 100)
    // Clip to the top-left 50×50 quadrant.
    canvas_clip_rect(cid, 0.0, 0.0, 50.0, 50.0)
    // Fill the WHOLE canvas red — only the clipped quadrant should paint.
    canvas_fill_rect(cid, 0.0, 0.0, 100.0, 100.0, 1.0, 0.0, 0.0, 1.0)

    out = getenv("AEVG_OUT")
    if string.length(out) == 0 { out = "/tmp/test_canvas_clip.png" }
    ok = canvas_write_png(cid, out, 100, 100)
    if ok == 1 {
        println("  PASS: rendered ${out} (inspect: red only in top-left 50x50)")
    } else {
        println("  FAIL: canvas_write_png failed")
        exit(1)
    }
    println("=== test_canvas_clip passed ===")
}
