// aevg/test_backend_dispatch.ae — the backend dispatch table.
//
// Verifies that backend_dispatch routes each dispatch_* entry point
// to the correct op in the registered closure, threading the
// concrete backend handle (be) and opts through. Uses a tiny
// in-test backend that just records (op, opts) so we can assert the
// routing without a display.

import std.list
import std.map
import std.string
import backend_dispatch

extern exit(code: int)
extern malloc(size: int) -> ptr

assert_eq_int(label: string, got: int, want: int) {
    if got == want { println("  PASS: ${label} (${got})") }
    else { println("  FAIL: ${label}: got ${got} want ${want}"); exit(1) }
}

assert_eq_str(label: string, got: string, want: string) {
    if string.equals(got, want) == 1 { println("  PASS: ${label} ('${got}')") }
    else { println("  FAIL: ${label}: got '${got}' want '${want}'"); exit(1) }
}

// A minimal recording backend: a list of op-ints + a list of the
// opts ptrs, so we can confirm routing + that `be`/opts threaded
// through correctly.
struct Rec {
    ops: ptr      // list of *Tag markers, one per dispatch call
    last_opts: ptr
}

// A returned handle tagged with the op it was produced for, so the
// test can confirm dispatch_* routed to the right op.
struct Tag {
    op: int
}

mk_rec() -> ptr {
    r = malloc(16) as *Rec
    r.ops = list.new()
    r.last_opts = null
    return r
}

mk_tag(op: int) -> ptr {
    t = malloc(8) as *Tag
    t.op = op
    return t
}

tag_op(p: ptr) -> int {
    t = p as *Tag
    return t.op
}

main() {
    println("=== test_backend_dispatch ===")

    rec = mk_rec()

    // Build a dispatch table whose closure records (op) into the Rec
    // and stashes the opts ptr. Returns a fresh handle per call so we
    // can confirm the return value flows back.
    b = backend_dispatch.backend_make(rec) callback |be: ptr, op: int, opts: ptr| {
        rc = be as *Rec
        h = mk_tag(op)
        ig = list.add(rc.ops, h)
        rc.last_opts = opts
        return h
    }

    // backend_self round-trips the concrete handle.
    got_self = backend_dispatch.backend_self(b)
    if got_self == rec {
        println("  PASS: backend_self returns the concrete handle")
    } else {
        println("  FAIL: backend_self mismatch"); exit(1)
    }

    // Each dispatch_* routes to the matching op (the returned handle's
    // tag equals the op selector).
    o1 = map.new()
    h0 = backend_dispatch.dispatch_circle(b, o1)
    assert_eq_int("dispatch_circle → op 0", tag_op(h0), 0)

    h1 = backend_dispatch.dispatch_rectangle(b, o1)
    assert_eq_int("dispatch_rectangle → op 1", tag_op(h1), 1)

    h2 = backend_dispatch.dispatch_line(b, o1)
    assert_eq_int("dispatch_line → op 2", tag_op(h2), 2)

    h3 = backend_dispatch.dispatch_path(b, o1)
    assert_eq_int("dispatch_path → op 3", tag_op(h3), 3)

    h4 = backend_dispatch.dispatch_text(b, o1)
    assert_eq_int("dispatch_text → op 4", tag_op(h4), 4)

    h5 = backend_dispatch.dispatch_raster(b, o1)
    assert_eq_int("dispatch_raster → op 5", tag_op(h5), 5)

    h6 = backend_dispatch.dispatch_tappable_raster(b, o1)
    assert_eq_int("dispatch_tappable_raster → op 6", tag_op(h6), 6)

    // 7 calls recorded.
    r = rec as *Rec
    assert_eq_int("7 ops recorded", list.size(r.ops), 7)

    // opts threaded through (last call's opts == o1).
    if r.last_opts == o1 {
        println("  PASS: opts threaded through to the closure")
    } else {
        println("  FAIL: opts not threaded"); exit(1)
    }

    // The op selector constants are stable.
    assert_eq_int("OP_CIRCLE",   backend_dispatch.OP_CIRCLE(),   0)
    assert_eq_int("OP_TAPPABLE", backend_dispatch.OP_TAPPABLE(), 6)

    println("=== test_backend_dispatch passed ===")
}
