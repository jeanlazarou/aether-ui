// aevg/test_grammar_factories.ae — regression test for grammar_factories.ae.
//
// Covers create_aevg_context for the canonical viewBox-mapping cases:
//   - Default options (no viewBox, no width/height) → canvas
//     defaults to 400×400; viewBox 0,0,400,400; identity mapping
//   - viewBox "0 0 100 100" with canvas 100×100 (1:1)
//   - viewBox "0 0 100 50" with canvas 200×200 (uniform scale 2,
//     letterboxed: meet with Mid alignment puts vb in the middle
//     of the canvas)
//   - Non-origin viewBox "-10 -5 100 50" — origin offset baked
//     into the transform
//   - preserveAspectRatio "xMinYMin meet" — no centering offset
//
// And then the end-to-end "build a small SVG via the factory and
// confirm the recorded backend calls match expectations" smoke test.

import grammar_factories
import grammar_context
import grammar_rendering
import grammar_shapes
import aevg_backend
import transform
import std.string
import std.map
import std.math

extern exit(code: int)
extern malloc(size: int) -> ptr

assert_eq_int(label: string, got: int, want: int) {
    if got == want { println("  PASS: ${label} (${got})") }
    else { println("  FAIL: ${label}: got ${got} want ${want}"); exit(1) }
}

assert_eq_str(label: string, got: string, want: string) {
    if string.equals(got, want) == 1 { println("  PASS: ${label} ('${got}')") }
    else { println("  FAIL: ${label}: got '${got}' want '${want}'"); exit(1) }
}

assert_near(label: string, got: float, want: float) {
    if math.abs_float(got - want) < 0.001 { println("  PASS: ${label} (${got})") }
    else { println("  FAIL: ${label}: got ${got} want ${want}"); exit(1) }
}

assert_opt_near(label: string, b: ptr, i: int, key: string, want: float) {
    s = aevg_backend.backend_opt_get(b, i, key)
    got, e = string.to_double(s)
    if e != "" { println("  FAIL: ${label}: parse '${s}' → ${e}"); exit(1) }
    if math.abs_float(got - want) < 0.01 { println("  PASS: ${label} (${got})") }
    else { println("  FAIL: ${label}: got ${got} want ${want}"); exit(1) }
}

// Build attrs from key/value lists.
mk_attrs4(k1: string, v1: string, k2: string, v2: string,
          k3: string, v3: string, k4: string, v4: string) -> ptr {
    m = map.new()
    _ = map.put(m, k1, v1)
    _ = map.put(m, k2, v2)
    _ = map.put(m, k3, v3)
    _ = map.put(m, k4, v4)
    return m
}

main() {
    println("=== test_grammar_factories ===")

    // ─── Default options: 400×400 canvas, viewBox = canvas ───────
    o1 = grammar_factories.opts_new()
    ctx1 = grammar_factories.create_aevg_context(o1)
    m1 = grammar_context.ctx_mapping(ctx1)
    assert_near("default canvas_width",  grammar_context.mapping_canvas_width(m1), 400.0)
    assert_near("default canvas_height", grammar_context.mapping_canvas_height(m1), 400.0)
    assert_near("default vb_width",      grammar_context.mapping_vb_width(m1), 400.0)
    assert_near("default vb_height",     grammar_context.mapping_vb_height(m1), 400.0)
    assert_near("default scale",         grammar_context.mapping_scale(m1), 1.0)
    // viewBox=canvas → mapping transform is the identity.
    x_at_origin = grammar_rendering.map_x(ctx1, 0.0)
    y_at_origin = grammar_rendering.map_y(ctx1, 0.0)
    assert_near("default map_x(0)", x_at_origin, 0.0)
    assert_near("default map_y(0)", y_at_origin, 0.0)

    // ─── viewBox 0,0,100,100 with 100×100 canvas (1:1) ───────────
    o2 = grammar_factories.opts_new()
    grammar_factories.opts_set_view_box(o2, "0 0 100 100")
    grammar_factories.opts_set_width(o2, 100.0)
    grammar_factories.opts_set_height(o2, 100.0)
    ctx2 = grammar_factories.create_aevg_context(o2)
    assert_near("1:1 map_x(0)",   grammar_rendering.map_x(ctx2, 0.0),   0.0)
    assert_near("1:1 map_x(50)",  grammar_rendering.map_x(ctx2, 50.0),  50.0)
    assert_near("1:1 map_y(100)", grammar_rendering.map_y(ctx2, 100.0), 100.0)

    // ─── viewBox 0,0,100,50 with 200×200 canvas — uniform scale 2,
    //     letterbox (vb is 2:1; meet → fits to width=2, vp height=100,
    //     centered vertically with 50px top/bottom margin) ──────────
    o3 = grammar_factories.opts_new()
    grammar_factories.opts_set_view_box(o3, "0 0 100 50")
    grammar_factories.opts_set_width(o3, 200.0)
    grammar_factories.opts_set_height(o3, 200.0)
    ctx3 = grammar_factories.create_aevg_context(o3)
    m3 = grammar_context.ctx_mapping(ctx3)
    // scale_x = 200/100 = 2; scale_y = 200/50 = 4. Meet → min = 2.
    assert_near("letterbox scale", grammar_context.mapping_scale(m3), 2.0)
    // After scale, vb_w * 2 = 200 fills the width; vb_h * 2 = 100,
    // leaves 100px in the height to split. Mid alignment → 50px each
    // side, so offset_y = 50.
    assert_near("letterbox offset_y", grammar_context.mapping_offset_y(m3), 50.0)
    // map_x(0) = scale*0 + offset_x = 0; map_y(0) = 2*0 + 50 = 50.
    assert_near("letterbox map_x(0)",   grammar_rendering.map_x(ctx3, 0.0), 0.0)
    assert_near("letterbox map_y(0)",   grammar_rendering.map_y(ctx3, 0.0), 50.0)
    assert_near("letterbox map_y(50)",  grammar_rendering.map_y(ctx3, 50.0), 150.0)

    // ─── Non-origin viewBox "-10 -5 100 50" — origin offset ──────
    o4 = grammar_factories.opts_new()
    grammar_factories.opts_set_view_box(o4, "-10 -5 100 50")
    grammar_factories.opts_set_width(o4, 100.0)
    grammar_factories.opts_set_height(o4, 50.0)
    ctx4 = grammar_factories.create_aevg_context(o4)
    // map_x(-10) = 0 (the viewBox origin lands at canvas origin)
    assert_near("origin-vb map_x(-10)", grammar_rendering.map_x(ctx4, 0.0 - 10.0), 0.0)
    assert_near("origin-vb map_y(-5)",  grammar_rendering.map_y(ctx4, 0.0 - 5.0), 0.0)
    // map_x(90) = (90 - (-10)) * 1 = 100 (the far edge)
    assert_near("origin-vb map_x(90)",  grammar_rendering.map_x(ctx4, 90.0), 100.0)

    // ─── preserveAspectRatio "xMinYMin meet" — no centering ──────
    o5 = grammar_factories.opts_new()
    grammar_factories.opts_set_view_box(o5, "0 0 100 50")
    grammar_factories.opts_set_width(o5, 200.0)
    grammar_factories.opts_set_height(o5, 200.0)
    grammar_factories.opts_set_preserve_aspect_ratio(o5, "xMinYMin meet")
    ctx5 = grammar_factories.create_aevg_context(o5)
    m5 = grammar_context.ctx_mapping(ctx5)
    // Same uniform-scale-to-meet (2.0) but no offset.
    assert_near("xMinYMin scale",    grammar_context.mapping_scale(m5),    2.0)
    assert_near("xMinYMin offset_y", grammar_context.mapping_offset_y(m5), 0.0)
    assert_near("xMinYMin offset_x", grammar_context.mapping_offset_x(m5), 0.0)

    // ─── End-to-end smoke: build an SVG and inspect backend ──────
    // Set up a 100×100 viewBox=100×100 (1:1) canvas, then issue
    // three shape factory calls and verify the recorded backend
    // sequence.
    o_e2e = grammar_factories.opts_new()
    grammar_factories.opts_set_view_box(o_e2e, "0 0 100 100")
    grammar_factories.opts_set_width(o_e2e, 100.0)
    grammar_factories.opts_set_height(o_e2e, 100.0)
    ctx_e2e = grammar_factories.create_aevg_context(o_e2e)
    bk = aevg_backend.backend_new()

    a_circle = mk_attrs4("cx", "50", "cy", "50", "r", "25", "fill", "red")
    a_rect   = mk_attrs4("x", "10", "y", "10", "width", "30", "height", "30")
    _ = map.put(a_rect, "fill", "blue")
    a_line   = mk_attrs4("x1", "0", "y1", "0", "x2", "100", "y2", "100")
    _ = map.put(a_line, "stroke", "black")

    _c = grammar_shapes.shape_circle(ctx_e2e, bk, a_circle)
    _r = grammar_shapes.shape_rectangle(ctx_e2e, bk, a_rect)
    _l = grammar_shapes.shape_line(ctx_e2e, bk, a_line)

    assert_eq_int("e2e: 3 backend calls", aevg_backend.backend_call_count(bk), 3)
    assert_eq_str("e2e: call 0 = circle",  aevg_backend.backend_kind(bk, 0), "circle")
    assert_eq_str("e2e: call 1 = rect",    aevg_backend.backend_kind(bk, 1), "rectangle")
    assert_eq_str("e2e: call 2 = line",    aevg_backend.backend_kind(bk, 2), "line")
    assert_opt_near("e2e: circle.x",  bk, 0, "x",  25.0)
    assert_opt_near("e2e: circle.x2", bk, 0, "x2", 75.0)
    assert_opt_near("e2e: rect.x",    bk, 1, "x",  10.0)
    assert_opt_near("e2e: rect.x2",   bk, 1, "x2", 40.0)
    assert_opt_near("e2e: line.x1",   bk, 2, "x1", 0.0)
    assert_opt_near("e2e: line.x2",   bk, 2, "x2", 100.0)

    println("=== test_grammar_factories passed ===")
}
