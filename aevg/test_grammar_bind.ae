// aevg/test_grammar_bind.ae — binding regions diff-and-render.
//
// Validates the data-driven element-region machinery:
//   - new_region: initial render walks items() and records keys
//   - refresh_all: diff adds new keys, removes vanished keys, calls
//     update() for surviving keys
//   - trackby string returns no longer segfault (verifies the
//     fn_return_float_cast.md layer-1 fix is taking effect here)
//
// User "items" are plain pointers to test-local DataItem structs.
// "Elements" are sentinel ptrs (mock *AevgElement) — we don't need
// real elements to exercise the diff machinery, just unique ptrs we
// can identity-compare across refresh calls.

import std.string
import std.list
import std.map
import grammar_bind
import grammar_context
import transform

extern exit(code: int)
extern malloc(size: int) -> ptr

assert_eq_int(label: string, got: int, want: int) {
    if got == want { println("  PASS: ${label} (${got})") }
    else { println("  FAIL: ${label}: got ${got} want ${want}"); exit(1) }
}

assert_eq_str(label: string, got: string, want: string) {
    if string.equals(got, want) == 1 { println("  PASS: ${label} ('${got}')") }
    else { println("  FAIL: ${label}: got '${got}' want '${want}'"); exit(1) }
}

assert_not_null(label: string, got: ptr) {
    if got != null { println("  PASS: ${label} (non-null)") }
    else { println("  FAIL: ${label}: null"); exit(1) }
}

assert_eq_ptr(label: string, got: ptr, want: ptr) {
    if got == want { println("  PASS: ${label}") }
    else { println("  FAIL: ${label}: ptrs differ"); exit(1) }
}

// ─── User data shape ─────────────────────────────────────────────

struct DataItem {
    id: string
    value: int
}

mk_item(id: string, value: int) -> ptr {
    d = malloc(16) as *DataItem
    d.id = string.copy(id)
    d.value = value
    return d
}

item_id(p: ptr) -> string { d = p as *DataItem; return d.id }
item_value(p: ptr) -> int { d = p as *DataItem; return d.value }

set_item_value(p: ptr, v: int) {
    d = p as *DataItem
    d.value = v
}

// ─── Mock context ────────────────────────────────────────────────

mk_test_ctx() -> ptr {
    id = transform.affine_identity()
    m = grammar_context.mapping_new(
        0.0, 0.0, 100.0, 100.0,
        100.0, 100.0,
        1.0, 0.0, 0.0,
        id
    )
    return grammar_context.new_context(m)
}

// ─── Test 1: initial render populates current ───────────────────

main() {
    println("=== test_grammar_bind ===")

    // ─── Data store: a 3-item list of DataItem ────────────────
    items = list.new()
    a = mk_item("a", 1)
    b = mk_item("b", 2)
    c = mk_item("c", 3)
    _ = list.add(items, a)
    _ = list.add(items, b)
    _ = list.add(items, c)

    // Track how many times render/update fire by appending a sentinel
    // ptr to a captured std.list each call; list.size() is the count.
    //
    // We use std.list rather than std.intarr because std.intarr handles
    // get mis-captured as int (their ptr type is back-inferred from the
    // inner intarr_get_unchecked's int-return — see
    // aether/closure_capture_int_inference.md). std.list dodges that.
    render_log = list.new()
    update_log = list.new()

    ctx = mk_test_ctx()

    // ─── Register region — one trailing-callback per setter ───
    region = grammar_bind.new_region()
    assert_not_null("region created", region)

    grammar_bind.region_set_items(region) callback {
        return items
    }
    grammar_bind.region_set_render(region) callback |item: ptr, idx: int| {
        // Mock element — fresh malloc gives a unique ptr we can
        // identity-compare across refresh calls. 24 bytes is
        // arbitrary; just need a unique heap ptr.
        el = malloc(24)
        ignored = list.add(render_log, el)
        return el
    }
    grammar_bind.region_set_trackby(region) callback |item: ptr| {
        return item_id(item)
    }
    grammar_bind.region_set_update(region) callback |item: ptr, el: ptr| {
        ignored = list.add(update_log, item)
    }

    grammar_bind.region_init(ctx, region)

    // ─── Initial render: 3 items → 3 current entries ──────────
    assert_eq_int("initial: current count", grammar_bind.region_current_count(region), 3)
    assert_eq_int("initial: render called 3×", list.size(render_log), 3)
    assert_eq_int("initial: update not called", list.size(update_log), 0)

    // Snapshot the three element ptrs so we can verify they survive
    // a refresh that only triggers updates.
    el_a_before = grammar_bind.region_current_get_el(region, "a")
    el_b_before = grammar_bind.region_current_get_el(region, "b")
    el_c_before = grammar_bind.region_current_get_el(region, "c")
    assert_not_null("el for 'a'", el_a_before)
    assert_not_null("el for 'b'", el_b_before)
    assert_not_null("el for 'c'", el_c_before)

    // ─── Refresh with same data: no render, 3 updates ─────────
    set_item_value(a, 11)
    set_item_value(b, 22)
    set_item_value(c, 33)

    grammar_bind.refresh_all(ctx)

    assert_eq_int("refresh same: current count", grammar_bind.region_current_count(region), 3)
    assert_eq_int("refresh same: render still 3×", list.size(render_log), 3)
    assert_eq_int("refresh same: update called 3×", list.size(update_log), 3)

    // Elements survived (identity).
    el_a_after = grammar_bind.region_current_get_el(region, "a")
    el_b_after = grammar_bind.region_current_get_el(region, "b")
    assert_eq_ptr("el 'a' preserved", el_a_after, el_a_before)
    assert_eq_ptr("el 'b' preserved", el_b_after, el_b_before)

    // ─── Refresh with 'b' removed, 'd' added ──────────────────
    items2 = list.new()
    _ = list.add(items2, a)        // keep
    _ = list.add(items2, c)        // keep
    d = mk_item("d", 4)
    _ = list.add(items2, d)        // new

    // Re-bind items() closure to the new list (TS source pattern:
    // the items closure typically reads a captured state variable
    // that changes). We model this with a second region instead.
    // Actually, the existing region's items closure returns `items`
    // — which is still the 3-element list. We need to mutate that
    // list to drive the refresh. Easier: clear the existing list
    // and re-populate.
    list.clear(items)
    _ = list.add(items, a)
    _ = list.add(items, c)
    _ = list.add(items, d)

    grammar_bind.refresh_all(ctx)

    // Now: a kept, b removed, c kept, d added.
    assert_eq_int("refresh add/rm: current count", grammar_bind.region_current_count(region), 3)

    assert_eq_int("refresh add/rm: render 4× (1 new)", list.size(render_log), 4)

    // 'b' should be gone, 'd' should be present, 'a'/'c' preserved.
    el_b_gone = grammar_bind.region_current_get_el(region, "b")
    if el_b_gone == null { println("  PASS: 'b' removed") }
    else { println("  FAIL: 'b' still present"); exit(1) }

    el_d = grammar_bind.region_current_get_el(region, "d")
    assert_not_null("el for 'd' added", el_d)

    el_a_after2 = grammar_bind.region_current_get_el(region, "a")
    el_c_after2 = grammar_bind.region_current_get_el(region, "c")
    assert_eq_ptr("el 'a' preserved across add/rm", el_a_after2, el_a_before)
    assert_eq_ptr("el 'c' preserved across add/rm", el_c_after2, el_c_before)

    // ─── Verify ctx-side registry tracks the region ───────────
    assert_eq_int("ctx binding_regions count", grammar_context.binding_regions_count(ctx), 1)
    same = grammar_context.binding_regions_at(ctx, 0)
    assert_eq_ptr("ctx region ptr matches", same, region)

    println("=== test_grammar_bind passed ===")
}
