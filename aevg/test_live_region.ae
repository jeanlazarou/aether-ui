// aevg/test_live_region.ae — live regions: registration, draw-callback firing,
// always-animating, raster buffer shape.
//
// The pixel composite (raster blit + draw shapes into one atomic backbuffer) is
// verified by the headless-PNG composite test in commit 2 and the windowed
// demo; here we pin the pure machinery: a registered live region makes the
// scene animate, a DRAW region's callback fires with the supplied t (drawing
// real vg shapes against the eager sub-scene), and a RASTER region carries a
// correctly-sized buffer.

import vg
import live_region
import aevg_backend
import grammar_context
import transform
import std.string

extern exit(code: int)
extern malloc(size: int) -> ptr

assert_eq_int(label: string, got: int, want: int) {
    if got == want { println("  PASS: ${label} (${got})") }
    else { println("  FAIL: ${label}: got ${got} want ${want}"); exit(1) }
}

assert_near(label: string, got: float, want: float) {
    d = got - want
    if d < 0.0 { d = 0.0 - d }
    if d < 0.01 { println("  PASS: ${label} (${got})") }
    else { println("  FAIL: ${label}: got ${got} want ${want}"); exit(1) }
}

mk_ctx() -> ptr {
    id = transform.affine_identity()
    m = grammar_context.mapping_new(0.0, 0.0, 100.0, 100.0, 100.0, 100.0, 1.0, 0.0, 0.0, id)
    return grammar_context.new_context(m)
}

// A recorder the draw callback writes to (capture-free closures get the region;
// the recorder is a stable heap object, fine to capture).
struct Rec { calls: int last_t: float drew: int }
mk_rec() -> *Rec { r = malloc(16) as *Rec; r.calls = 0; r.last_t = 0.0; r.drew = 0; return r }

main() {
    println("=== test_live_region ===")

    ctx = mk_ctx()
    bk = aevg_backend.backend_new()
    scene = vg.scene_new(ctx, bk)

    // No live regions yet → not animating.
    assert_eq_int("no live regions: not animating", vg.scene_is_animating(scene), 0)

    // ─── RASTER region: push a generated frame ──────────────────
    // extent (viewBox) 25×15 at (10,20); frame buffer 40×30 px (independent).
    rr = live_region.live_raster_new(10.0, 20.0, 25.0, 15.0, 40, 30)
    assert_eq_int("raster kind", live_region.region_kind(rr), live_region.LIVE_RASTER())
    assert_near("raster x", live_region.region_x(rr), 10.0)
    assert_near("raster y", live_region.region_y(rr), 20.0)
    assert_near("raster extent w", live_region.region_w(rr), 25.0)
    assert_near("raster extent h", live_region.region_h(rr), 15.0)
    assert_eq_int("raster pixel w", live_region.region_pw(rr), 40)
    assert_eq_int("raster pixel h", live_region.region_ph(rr), 30)
    assert_eq_int("no frame yet: len 0", live_region.region_frame_len(rr), 0)

    // Build + push a frame; the region carries it for the blit.
    buf = live_region.new_frame_buffer(40, 30)
    live_region.buf_set_px(buf, 0, 1, 2, 3, 4)
    fr = live_region.frame_finish(buf, 40, 30)
    live_region.region_push(rr, fr, 40 * 30 * 4)
    assert_eq_int("after push: frame_len = 40*30*4", live_region.region_frame_len(rr), 4800)

    vg.scene_add_live_region(scene, rr)
    assert_eq_int("after raster add: animating", vg.scene_is_animating(scene), 1)

    // ─── DRAW region: callback fires with t, draws shapes ───────
    // The callback captures `rec` (a stable heap object) and receives the eager
    // root node `rn` — it records the call and draws one circle via the vg verb.
    rec = mk_rec()
    dr = live_region.live_draw_new(0.0, 0.0, 50.0, 50.0) callback |rn: ptr, t: float| {
        rec.calls = rec.calls + 1
        rec.last_t = t
        _ = vg.circle(rn, 25.0, 25.0, 10.0)
    }
    vg.scene_add_live_region(scene, dr)

    // Render the draw regions at t=0.25 → callback fires once, sees t, and its
    // shape dispatched to the (eager) backend.
    n_before = aevg_backend.backend_call_count(bk)
    vg.scene_render_live_draws(scene, 0.25)
    assert_eq_int("draw callback fired once", rec.calls, 1)
    assert_near("draw callback saw t=0.25", rec.last_t, 0.25)
    n_after = aevg_backend.backend_call_count(bk)
    assert_eq_int("draw region dispatched 1 shape", n_after - n_before, 1)

    // Render again at t=0.75 → fires again (transient, no accumulation).
    vg.scene_render_live_draws(scene, 0.75)
    assert_eq_int("draw callback fired twice", rec.calls, 2)
    assert_near("draw callback saw t=0.75", rec.last_t, 0.75)

    // Two live regions registered.
    if vg.scene_live_regions(scene) != null { println("  PASS: live_regions list present") }
    else { println("  FAIL: live_regions null"); exit(1) }

    // ─── z-index: default 0; set/get; draw regions render in z order ──
    assert_eq_int("default z = 0", live_region.region_z(dr), 0)
    live_region.region_set_z(dr, 7)
    assert_eq_int("after set_z(7)", live_region.region_z(dr), 7)

    // Two draw regions added z=5 then z=2; the z-ordered render must invoke the
    // z=2 one first. The shared recorder logs each region's z as it fires.
    ctx2 = mk_ctx()
    bk2 = aevg_backend.backend_new()
    scene2 = vg.scene_new(ctx2, bk2)
    zlog = mk_rec()   // reuse: last_t holds the z of the most-recent callback
    a = live_region.live_draw_new(0.0, 0.0, 10.0, 10.0) callback |rn: ptr, t: float| {
        zlog.calls = zlog.calls + 1
        zlog.last_t = 5.0   // this region's z, recorded when it fires
    }
    live_region.region_set_z(a, 5)
    b = live_region.live_draw_new(0.0, 0.0, 10.0, 10.0) callback |rn: ptr, t: float| {
        zlog.calls = zlog.calls + 1
        zlog.last_t = 2.0
    }
    live_region.region_set_z(b, 2)
    vg.scene_add_live_region(scene2, a)
    vg.scene_add_live_region(scene2, b)
    // render_one_draw doesn't z-sort (that's the live driver's job), so drive
    // them in z order by hand to prove region_z reads back correctly and the
    // lower-z fires first when ordered. (The full z-ordered walk is exercised
    // live in _render_live_z_ordered; here we pin the z accessors + ordering.)
    vg.render_one_draw(scene2, lowest_z(a, b), 0.0)
    assert_near("lowest-z (b, z=2) rendered first", zlog.last_t, 2.0)
    vg.render_one_draw(scene2, highest_z(a, b), 0.0)
    assert_near("highest-z (a, z=5) rendered second", zlog.last_t, 5.0)
    assert_eq_int("both z regions fired", zlog.calls, 2)

    println("=== test_live_region passed ===")
}

lowest_z(a: ptr, b: ptr) -> ptr {
    if live_region.region_z(a) <= live_region.region_z(b) { return a }
    return b
}
highest_z(a: ptr, b: ptr) -> ptr {
    if live_region.region_z(a) > live_region.region_z(b) { return a }
    return b
}
