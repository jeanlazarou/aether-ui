import build
import aether
import aether (source, output, no_closure_regen, lib)
import aetherui (ui_backend)

main() {
    b = build.start()
    root = build._get(b, "root")
    aether.program(b) {
        source("vg_demo.ae")
        output("vg_demo")
        lib("${root}/aevg")        // sibling modules: vg, vg_live, loader, …
        no_closure_regen()
        ui_backend(root)
    }
    return 0
}
