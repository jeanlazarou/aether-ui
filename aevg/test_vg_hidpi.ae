// aevg/test_vg_hidpi.ae — HiDPI-aware viewBox→canvas coordinate mapping.
//
// Headless port of svg-hidpi-scaling.test.ts. The "HiDPI" motivation is that
// on a high-DPI display the canvas is larger than the viewBox, so coordinates
// must scale by the ratio. The substance is a matrix of square-aspect scale
// ratios — for each, a viewBox coordinate (x) must map to canvas px (x*scale),
// and a dispatched rect/path must land at scaled bounds. Square viewBox+canvas
// means uniform scale, no letterbox, so offsets are 0 and the math is clean.

import grammar_factories
import grammar_context
import grammar_rendering
import grammar_shapes
import grammar_element
import aevg_backend
import std.string
import std.map

extern exit(code: int)
extern malloc(size: int) -> ptr

assert_near(label: string, got: float, want: float) {
    d = got - want
    if d < 0.0 { d = 0.0 - d }
    if d < 0.5 { println("  PASS: ${label} (${got})") }
    else { println("  FAIL: ${label}: got ${got} want ${want}"); exit(1) }
}

// Build a context for viewBox "0 0 vb vb" on a w×w canvas (square → uniform
// scale = w/vb, no letterbox).
mk_ctx(vb: string, w: float) -> ptr {
    o = grammar_factories.opts_new()
    grammar_factories.opts_set_view_box(o, vb)
    grammar_factories.opts_set_width(o, w)
    grammar_factories.opts_set_height(o, w)
    return grammar_factories.create_aevg_context(o)
}

// Assert map_x/map_y scale a viewBox coord by `scale` (offset 0 for square).
check_scale(name: string, vb: string, vbsize: float, w: float, scale: float) {
    ctx = mk_ctx(vb, w)
    m = grammar_context.ctx_mapping(ctx)
    assert_near("${name}: mapping scale", grammar_context.mapping_scale(m), scale)
    // Origin maps to origin; an interior coord maps to coord*scale.
    assert_near("${name}: map_x(0)",  grammar_rendering.map_x(ctx, 0.0), 0.0)
    half = vbsize / 2.0
    assert_near("${name}: map_x(half)", grammar_rendering.map_x(ctx, half), half * scale)
    assert_near("${name}: map_y(half)", grammar_rendering.map_y(ctx, half), half * scale)
}

mk_rect_attrs(x: string, y: string, w: string, h: string) -> ptr {
    m = map.new()
    _ = map.put(m, "x", x)
    _ = map.put(m, "y", y)
    _ = map.put(m, "width", w)
    _ = map.put(m, "height", h)
    return m
}

main() {
    println("=== test_vg_hidpi ===")

    // ─── Coordinate-mapping matrix (the CVG scale table) ──────────
    check_scale("1:1",   "0 0 100 100", 100.0, 100.0, 1.0)
    check_scale("2x",    "0 0 100 100", 100.0, 200.0, 2.0)
    check_scale("4x",    "0 0 100 100", 100.0, 400.0, 4.0)
    check_scale("0.5x",  "0 0 100 100", 100.0, 50.0,  0.5)
    check_scale("1.5x",  "0 0 200 200", 200.0, 300.0, 1.5)
    check_scale("10x",   "0 0 50 50",   50.0,  500.0, 10.0)
    check_scale("chess", "0 0 360 360", 360.0, 800.0, 800.0 / 360.0)

    // ─── Dispatched shape honours the scale (2x + 4x) ─────────────
    // A rect at viewBox (20,30,10,10) on a 200px canvas (scale 2) must have
    // canvas-px bounds (40,60,20,20). shape_rectangle sets element bounds in
    // canvas space, so this proves the whole dispatch path scales — not just
    // map_x in isolation.
    ctx2 = mk_ctx("0 0 100 100", 200.0)
    bk2 = aevg_backend.backend_new()
    a2 = mk_rect_attrs("20", "30", "10", "10")
    el2 = grammar_shapes.shape_rectangle(ctx2, bk2, a2)
    assert_near("2x rect bounds_x", grammar_element.element_bounds_x(el2), 40.0)
    assert_near("2x rect bounds_y", grammar_element.element_bounds_y(el2), 60.0)
    assert_near("2x rect bounds_w", grammar_element.element_bounds_width(el2), 20.0)
    assert_near("2x rect bounds_h", grammar_element.element_bounds_height(el2), 20.0)

    ctx4 = mk_ctx("0 0 100 100", 400.0)
    bk4 = aevg_backend.backend_new()
    a4 = mk_rect_attrs("20", "30", "10", "10")
    el4 = grammar_shapes.shape_rectangle(ctx4, bk4, a4)
    assert_near("4x rect bounds_x", grammar_element.element_bounds_x(el4), 80.0)
    assert_near("4x rect bounds_y", grammar_element.element_bounds_y(el4), 120.0)
    assert_near("4x rect bounds_w", grammar_element.element_bounds_width(el4), 40.0)
    assert_near("4x rect bounds_h", grammar_element.element_bounds_height(el4), 40.0)

    println("=== test_vg_hidpi passed ===")
}
