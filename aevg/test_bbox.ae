// aevg/test_bbox.ae — regression test for bbox.ae.
//
// Validates compute_content_bounds end-to-end: feeds raw SVG strings
// through parser.parse_svg → bbox.compute_content_bounds and asserts
// the resulting AABB. Covers each element kind, transform cascade,
// stroke-width margin, SKIP_TAGS skipping, and the multi-element
// union case.

import bbox
import parser
import std.math

extern exit(code: int)

EPS() -> float { return 0.001 }

near(a: float, b: float) -> int {
    if math.abs_float(a - b) < EPS() { return 1 }
    return 0
}

assert_near(label: string, got: float, want: float) {
    if near(got, want) == 1 {
        println("  PASS: ${label} (${got})")
    } else {
        println("  FAIL: ${label}: got ${got} want ${want}")
        exit(1)
    }
}

assert_eq_int(label: string, got: int, want: int) {
    if got == want {
        println("  PASS: ${label} (${got})")
    } else {
        println("  FAIL: ${label}: got ${got} want ${want}")
        exit(1)
    }
}

check_bounds(label: string, b: ptr, minx: float, miny: float, maxx: float, maxy: float) {
    if bbox.bounds_is_null(b) == 1 {
        println("  FAIL: ${label}: bounds is null")
        exit(1)
    }
    assert_near("${label}.minX", bbox.bounds_min_x(b), minx)
    assert_near("${label}.minY", bbox.bounds_min_y(b), miny)
    assert_near("${label}.maxX", bbox.bounds_max_x(b), maxx)
    assert_near("${label}.maxY", bbox.bounds_max_y(b), maxy)
}

main() {
    println("=== test_bbox ===")

    // ─── rect ────────────────────────────────────────────────────
    rect_doc = "<svg><rect x='10' y='20' width='30' height='40'/></svg>"
    r_root = parser.parse_svg(rect_doc)
    rb = bbox.compute_content_bounds(r_root)
    check_bounds("rect", rb, 10.0, 20.0, 40.0, 60.0)

    // ─── circle ──────────────────────────────────────────────────
    c_doc = "<svg><circle cx='50' cy='50' r='25'/></svg>"
    cb = bbox.compute_content_bounds(parser.parse_svg(c_doc))
    check_bounds("circle", cb, 25.0, 25.0, 75.0, 75.0)

    // ─── ellipse ─────────────────────────────────────────────────
    e_doc = "<svg><ellipse cx='10' cy='20' rx='5' ry='3'/></svg>"
    eb = bbox.compute_content_bounds(parser.parse_svg(e_doc))
    check_bounds("ellipse", eb, 5.0, 17.0, 15.0, 23.0)

    // ─── line ────────────────────────────────────────────────────
    l_doc = "<svg><line x1='10' y1='20' x2='30' y2='5'/></svg>"
    lb = bbox.compute_content_bounds(parser.parse_svg(l_doc))
    check_bounds("line", lb, 10.0, 5.0, 30.0, 20.0)

    // ─── polyline ────────────────────────────────────────────────
    pl_doc = "<svg><polyline points='0,0 10,5 20,15 5,20'/></svg>"
    plb = bbox.compute_content_bounds(parser.parse_svg(pl_doc))
    check_bounds("polyline", plb, 0.0, 0.0, 20.0, 20.0)

    // ─── polygon (same code path) ────────────────────────────────
    pg_doc = "<svg><polygon points='0 0 100 0 50 86.6'/></svg>"
    pgb = bbox.compute_content_bounds(parser.parse_svg(pg_doc))
    check_bounds("polygon", pgb, 0.0, 0.0, 100.0, 86.6)

    // ─── path ────────────────────────────────────────────────────
    // Simple absolute moves: M 5 5 L 25 5 L 25 25 L 5 25 Z → [5,5,25,25]
    path_doc = "<svg><path d='M 5 5 L 25 5 L 25 25 L 5 25 Z'/></svg>"
    pb = bbox.compute_content_bounds(parser.parse_svg(path_doc))
    check_bounds("path", pb, 5.0, 5.0, 25.0, 25.0)

    // Cubic Bezier: the bbox of a cubic walks all control points
    // (TS approximation; matches what bbox.ts does). M 0 0 C 0 100 100 100 100 0
    // → AABB includes (0,100) and (100,100), so [0, 0, 100, 100].
    cu_doc = "<svg><path d='M 0 0 C 0 100 100 100 100 0'/></svg>"
    cub = bbox.compute_content_bounds(parser.parse_svg(cu_doc))
    check_bounds("cubic path", cub, 0.0, 0.0, 100.0, 100.0)

    // ─── group + nested transforms ────────────────────────────────
    // <g transform="translate(100, 200)"><rect x='0' y='0' w='10' h='10'/></g>
    // → AABB [100, 200, 110, 210]
    grp_doc = "<svg><g transform='translate(100 200)'><rect x='0' y='0' width='10' height='10'/></g></svg>"
    gb = bbox.compute_content_bounds(parser.parse_svg(grp_doc))
    check_bounds("translated rect", gb, 100.0, 200.0, 110.0, 210.0)

    // Scale transform: rect 0,0,10,10 scaled 2x → 0,0,20,20
    sc_doc = "<svg><g transform='scale(2)'><rect x='0' y='0' width='10' height='10'/></g></svg>"
    sb = bbox.compute_content_bounds(parser.parse_svg(sc_doc))
    check_bounds("scaled rect", sb, 0.0, 0.0, 20.0, 20.0)

    // ─── stroke-width adds half-width to each side ────────────────
    // rect 10,10,20,20 with stroke-width=4 → bounds expand by 2 on each side
    sw_doc = "<svg><rect x='10' y='10' width='20' height='20' stroke-width='4'/></svg>"
    swb = bbox.compute_content_bounds(parser.parse_svg(sw_doc))
    check_bounds("stroke-width attr", swb, 8.0, 8.0, 32.0, 32.0)

    // Same, via inline style
    swst_doc = "<svg><rect x='10' y='10' width='20' height='20' style='stroke-width:4;fill:red'/></svg>"
    swstb = bbox.compute_content_bounds(parser.parse_svg(swst_doc))
    check_bounds("stroke-width style", swstb, 8.0, 8.0, 32.0, 32.0)

    // ─── union of multiple elements ──────────────────────────────
    // <rect 0,0,10,10/> + <rect 50,50,10,10/> → [0, 0, 60, 60]
    multi_doc = "<svg><rect x='0' y='0' width='10' height='10'/><rect x='50' y='50' width='10' height='10'/></svg>"
    mb = bbox.compute_content_bounds(parser.parse_svg(multi_doc))
    check_bounds("multi-rect union", mb, 0.0, 0.0, 60.0, 60.0)

    // ─── SKIP_TAGS: defs / desc / metadata are not included ──────
    // The defs <rect> should be IGNORED; only the visible <rect> contributes.
    skip_doc = "<svg><defs><rect x='1000' y='1000' width='10' height='10'/></defs><rect x='5' y='5' width='10' height='10'/></svg>"
    sb_skip = bbox.compute_content_bounds(parser.parse_svg(skip_doc))
    check_bounds("defs is skipped", sb_skip, 5.0, 5.0, 15.0, 15.0)

    // ─── degenerate (zero radius) → null ─────────────────────────
    // A single circle with r=0 yields no bounds.
    zero_doc = "<svg><circle cx='5' cy='5' r='0'/></svg>"
    zb = bbox.compute_content_bounds(parser.parse_svg(zero_doc))
    assert_eq_int("zero-radius circle is null", bbox.bounds_is_null(zb), 1)

    // ─── empty <svg/> → null ─────────────────────────────────────
    empty = bbox.compute_content_bounds(parser.parse_svg("<svg/>"))
    assert_eq_int("empty svg is null", bbox.bounds_is_null(empty), 1)

    // ─── CSS length units ────────────────────────────────────────
    // rect with width=1in (=96px) and height=2cm (~75.59px)
    unit_doc = "<svg><rect x='0' y='0' width='1in' height='2cm'/></svg>"
    ub = bbox.compute_content_bounds(parser.parse_svg(unit_doc))
    assert_near("1in width = 96px", bbox.bounds_max_x(ub), 96.0)
    assert_near("2cm height ≈ 75.59", bbox.bounds_max_y(ub), 75.5906)

    println("=== test_bbox passed ===")
}
