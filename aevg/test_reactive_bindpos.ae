// aevg/test_reactive_bindpos.ae — bindPos drives bounds + hit-test.
//
// The reactive refresh pass evaluates a .bindPos closure and merges
// its result into the element's SVG-space geometry, then recomputes
// canvas-space bounds (grammar_reactive.recompute_bounds). This test
// verifies that hit-testing follows a moving bound:
//
//   1. Create a circle at (50, 50) r=25 via shape_circle, so the
//      element carries real shape geometry + initial bounds.
//   2. Hit-test (50, 50) → inside; (90, 90) → outside.
//   3. Attach a bindPos that moves cx/cy to (90, 90).
//   4. Refresh → recompute_bounds re-maps and updates bounds.
//   5. Hit-test (90, 90) → now inside; (50, 50) → now outside.
//
// The test context uses an identity viewBox (100×100 → 100×100,
// scale 1.0), so SVG coords == canvas coords and the expected
// bounds are easy to reason about.

import std.string
import std.list
import std.map
import grammar_element
import grammar_context
import grammar_reactive
import grammar_shapes
import aevg_backend
import transform

extern exit(code: int)
extern malloc(size: int) -> ptr

assert_eq_int(label: string, got: int, want: int) {
    if got == want { println("  PASS: ${label} (${got})") }
    else { println("  FAIL: ${label}: got ${got} want ${want}"); exit(1) }
}

assert_near(label: string, got: float, want: float) {
    d = got - want
    if d < 0.0 { d = 0.0 - d }
    if d < 0.5 { println("  PASS: ${label} (${got})") }
    else { println("  FAIL: ${label}: got ${got} want ${want}"); exit(1) }
}

mk_test_ctx() -> ptr {
    id = transform.affine_identity()
    m = grammar_context.mapping_new(
        0.0, 0.0, 100.0, 100.0,
        100.0, 100.0,
        1.0, 0.0, 0.0,
        id
    )
    return grammar_context.new_context(m)
}

mk_attrs4(k1: string, v1: string, k2: string, v2: string,
          k3: string, v3: string, k4: string, v4: string) -> ptr {
    m = map.new()
    _ = map.put(m, k1, v1)
    _ = map.put(m, k2, v2)
    _ = map.put(m, k3, v3)
    _ = map.put(m, k4, v4)
    return m
}

main() {
    println("=== test_reactive_bindpos ===")

    ctx = mk_test_ctx()
    bk = aevg_backend.backend_new()

    // ─── Circle at (50, 50), r=25 ─────────────────────────────
    attrs = mk_attrs4("cx", "50", "cy", "50", "r", "25", "fill", "red")
    el = grammar_shapes.shape_circle(ctx, bk, attrs)
    grammar_context.ctx_track_element(ctx, el)

    // Initial shape geometry recorded?
    assert_eq_int("shape_type = circle",
                  grammar_element.element_shape_type(el),
                  grammar_element.SHAPE_CIRCLE())
    assert_near("geo0 (cx) = 50", grammar_element.element_geo0(el), 50.0)
    assert_near("geo1 (cy) = 50", grammar_element.element_geo1(el), 50.0)
    assert_near("geo2 (r) = 25",  grammar_element.element_geo2(el), 25.0)

    // Initial bounds: (25, 25, 50, 50).
    assert_near("init bounds_x = 25", grammar_element.element_bounds_x(el), 25.0)
    assert_near("init bounds_y = 25", grammar_element.element_bounds_y(el), 25.0)

    // Hit-test at center (50,50) → inside; (90,90) → outside.
    assert_eq_int("init hit (50,50) inside", grammar_element.element_hit_test(el, 50.0, 50.0), 1)
    assert_eq_int("init hit (90,90) outside", grammar_element.element_hit_test(el, 90.0, 90.0), 0)

    // ─── Attach bindPos moving the circle to (90, 90) ─────────
    grammar_element.element_bind_pos(el) callback {
        m = map.new()
        ig1 = map.put(m, "cx", "90")
        ig2 = map.put(m, "cy", "90")
        return m
    }

    // ─── Refresh: recompute_bounds re-maps to canvas space ────
    _ = grammar_reactive.refresh_all_elements(ctx)

    // Geometry merged: cx/cy now 90, r unchanged (25).
    assert_near("after: geo0 (cx) = 90", grammar_element.element_geo0(el), 90.0)
    assert_near("after: geo1 (cy) = 90", grammar_element.element_geo1(el), 90.0)
    assert_near("after: geo2 (r) = 25",  grammar_element.element_geo2(el), 25.0)

    // Bounds moved to (65, 65, 50, 50).
    assert_near("after bounds_x = 65", grammar_element.element_bounds_x(el), 65.0)
    assert_near("after bounds_y = 65", grammar_element.element_bounds_y(el), 65.0)
    assert_near("after bounds_w = 50", grammar_element.element_bounds_width(el),  50.0)
    assert_near("after bounds_h = 50", grammar_element.element_bounds_height(el), 50.0)

    // Hit-test follows: (90,90) now inside; (50,50) now outside.
    assert_eq_int("after hit (90,90) inside",  grammar_element.element_hit_test(el, 90.0, 90.0), 1)
    assert_eq_int("after hit (50,50) outside", grammar_element.element_hit_test(el, 50.0, 50.0), 0)

    // ─── Partial pos update: only r changes ───────────────────
    // bindPos can return a subset; missing keys keep prior geo.
    grammar_element.element_bind_pos(el) callback {
        m = map.new()
        ig3 = map.put(m, "r", "10")
        return m
    }
    _ = grammar_reactive.refresh_all_elements(ctx)

    // cx/cy still 90 (not in the new map), r now 10.
    assert_near("partial: geo0 (cx) still 90", grammar_element.element_geo0(el), 90.0)
    assert_near("partial: geo2 (r) = 10",      grammar_element.element_geo2(el), 10.0)
    // Bounds shrink to (80, 80, 20, 20).
    assert_near("partial bounds_x = 80", grammar_element.element_bounds_x(el), 80.0)
    assert_near("partial bounds_w = 20", grammar_element.element_bounds_width(el), 20.0)

    println("=== test_reactive_bindpos passed ===")
}
